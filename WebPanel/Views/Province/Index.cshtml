@model Entities.DTOs.Web.Common.ProvincePageDto
@{
    ViewData["Title"] = "لیست استانها";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    int i = ((Model.Provinces.PageNumber - 1) * Model.Provinces.PageSize) + 1;
}

<div class="col-lg-12">
    <div class="card">
        <div class="card-header pb-1">
            <div class="d-flex justify-content-between">
                <h3 class="title">
                    <i class="icon-frane"></i> لیست استانها ( تعداد کل @Model.AllProvinceCount.ToPrice() )
                </h3>
                <div>
                    <button type="button" class="alert-icon btn btn-primary round btn-add-province"> <i class="icon-plus align-middle"></i> استان جدید </button>
                </div>
            </div>
        </div>
        <div class="card-body pt-0">
            <form id="formFilter" asp-action="Index" asp-route-p="" method="post">
                <input name="p" id="pageNumber" hidden />
                <div class="form-body">
                    <div class="row">
                        <div class="form-group col-md-3">
                            <label>کشور</label>
                            <div class="input-group">
                                <select asp-for="Filter.CountryId" class="form-control select2" id="Filter_CountryId">
                                    <option value="">همه کشورها</option>
                                    @if (Model.Countries != null)
                                    {
                                        @foreach (var country in Model.Countries)
                                        {
                                            <option value="@country.Id">@country.CountryNameFa</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="form-group col-md-3">
                            <label>جستجو</label>
                            <div class="input-group">
                                <input type="text" asp-for="Filter.Search" class="form-control"/>
                            </div>
                        </div>
                        <div class="col-md-1">
                            <button style="border-radius:5px; margin-top:30px"
                                    class="alert-icon btn btn-success"
                                    type="submit">
                                <p class="px-3"> فیلتر</p>
                            </button>
                        </div>
                    </div>
                </div>
            </form>
            <div id="table-container">
                @await Html.PartialAsync("_ProvinceTable", Model)
            </div>
        </div>
    </div>
</div>

<!-- Modal for Create/Edit Province -->
<div class="modal fade" id="provinceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">ثبت/ویرایش استان</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body"></div>
        </div>
    </div>
</div>

@section script {
    <script>
        var currentPage = @Model.Provinces.PageNumber;
        var currentSortColumn = '@(Model.Filter?.SortColumn ?? "namefa")';
        var currentSortDirection = '@(Model.Filter?.SortDirection ?? "asc")';

        $(document).ready(function () {
            $('.select2').select2();

            $('select[class*="provincemodal"].select2').select2({
                dropdownParent: $('#provinceModal')
            });
        });

        function getFilterData() {
            var selectedCountryId = $("#Filter_CountryId").val();
            return {
                'filter.Search': $("#Filter_Search").val(),
                'filter.CountryId': selectedCountryId ? parseInt(selectedCountryId) : null,
                'filter.SortColumn': currentSortColumn,
                'filter.SortDirection': currentSortDirection
            };
        }

        function loadTable(page) {
            currentPage = page || 1;
            var data = Object.assign({ p: currentPage }, getFilterData());
            $.get('@Url.Action("Table","Province")', data)
                .done(function (html) {
                    $("#table-container").html(html);
                });
        }

        function loadTableWithSort(sortColumn, sortDirection) {
            currentSortColumn = sortColumn;
            currentSortDirection = sortDirection;
            loadTable(1);
        }

        function openProvinceModal(url) {
            $.get(url).done(function (html) {
                var $modal = $("#provinceModal");
                $modal.find('.modal-body').html(html);
                if ($.validator && $.validator.unobtrusive) {
                    $.validator.unobtrusive.parse($modal);
                }
                
                // Initialize Select2 inside modal with parent element
                $('select[class*="provincemodal"].select2').select2({
                    dropdownParent: $('#provinceModal')
                });
                
                var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('provinceModal'));
                modal.show();
            });
        }

        $(document).on('submit', '#formFilter', function (e) {
            e.preventDefault();
            loadTable(1);
        });

        $(document).on('click', '#table-container .page-link', function (e) {
            e.preventDefault();
            var hrefValue = $(this).attr("href") || '';
            var match = hrefValue.match(/p=(\d+)/);
            var p = match ? parseInt(match[1]) : 1;
            loadTable(p);
        });

        $(document).on('click', '.btn-add-province', function () {
            var url = '@Url.Action("CreateProvinceModal","Province")';
            var selectedCountryId = $("#Filter_CountryId").val();
            if (selectedCountryId && selectedCountryId > 0) {
                url += '?countryId=' + selectedCountryId;
            }
            openProvinceModal(url);
        });

        $(document).on('click', '#btnClearFilter', function () {
            $('#Filter_CountryId').val(null).trigger('change');
            $("#Filter_Search").val('');
            loadTable(1);
        });

        $(document).on('click', '.btn-edit-province', function () {
            var id = $(this).data('id');
            openProvinceModal('@Url.Action("CreateProvinceModal","Province")' + '?provinceId=' + id);
        });

        $(document).on('submit', '#provinceModal form', function (e) {
            e.preventDefault();
            var $form = $(this);
            var $btn = $form.find('button[type="submit"]');
            $btn.prop('disabled', true).html('<i class="icon-spinner fa-spin"></i> در حال ذخیره...');
            
            var action = $form.attr('action') || '@Url.Action("SaveProvince","Province")';
            $.ajax({
                url: action,
                type: 'POST',
                data: $form.serialize(),
                headers: {
                    'RequestVerificationToken': $form.find('input[name="__RequestVerificationToken"]').val()
                }
            }).done(function (resp, status, xhr) {
                if (typeof resp === 'object' && resp !== null && resp.success) {
                    var modalEl = document.getElementById('provinceModal');
                    var modal = bootstrap.Modal.getInstance(modalEl);
                    modal.hide();
                    loadTable(currentPage);
                    updateProvinceCount();
                    showAlert(resp.message, 0);
                } else {
                    var errorMsg = resp.message || 'خطا در ثبت اطلاعات';
                    showAlert(errorMsg, 1);
                    $("#provinceModal .modal-body").html(resp);
                    if ($.validator && $.validator.unobtrusive) {
                        $.validator.unobtrusive.parse('#provinceModal');
                    }
                    $('#btnSaveProvince').prop('disabled', false).html('<i class="icon-check"></i> ذخیره');
                }
            }).fail(function (xhr, status, error) {
                showAlert('خطا در ارسال درخواست: ' + error, 1);
                $('#btnSaveProvince').prop('disabled', false).html('<i class="icon-check"></i> ذخیره');
            });
        });

        $(document).on('click', '.btn-delete-province', function () {
            var id = $(this).data('id');
            var name = $(this).data('name');
            
            Swal.fire({
                title: 'آیا از حذف استان "' + name + '" مطمئن هستید؟',
                text: "این عملیات قابل بازگشت نیست!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'بله، حذف کن',
                cancelButtonText: 'انصراف'
            }).then((result) => {
                if (result.isConfirmed) {
                    deleteProvince(id);
                }
            });
        });

        function deleteProvince(id) {
            $.ajax({
                url: '@Url.Action("DeleteProvince", "Province")',
                type: 'POST',
                data: { provinceId: id },
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val()
                }
            }).done(function (resp) {
                if (resp.success) {
                    loadTable(currentPage);
                    updateProvinceCount();
                    showAlert(resp.message, 0);
                } else {
                    showAlert(resp.message, 1);
                }
            }).fail(function (xhr, status, error) {
                showAlert('خطا در حذف استان: ' + error, 1);
            });
        }

        function updateProvinceCount() {
            var url = '@Url.Action("GetProvinceCount", "Province")';
            var selectedCountryId = $("#Filter_CountryId").val();
            if (selectedCountryId && selectedCountryId > 0) {
                url += '?countryId=' + selectedCountryId;
            }
            $.get(url)
                .done(function (resp) {
                    if (resp.count !== undefined) {
                        var titleText = '<i class="icon-frane"></i> لیست استانها';
                        if (selectedCountryId && selectedCountryId > 0) {
                            var countryName = $("#Filter_CountryId option:selected").text();
                            titleText += ' - ' + countryName;
                        }
                        titleText += ' ( تعداد کل ' + resp.count.toLocaleString('fa-IR') + ' )';
                        $('.title').html(titleText);
                    }
                });
        }
    </script>
}
