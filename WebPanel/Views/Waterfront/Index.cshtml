@model WaterfrontPageDto
@{
    ViewData["Title"] = "اسکلـــه ها";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    int i = 1;
}



<div class="col-lg-12">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between">
                
                    <h3 class="title">
                        <i class="icon-frane"></i> اسکلـــه ها
                     
                    </h3>
              <div>
                    <a class="btn rounded btn-primary" onclick="createWaterfront();"><i class="fa-solid fa-plus me-2"></i>اسکله جدید</a>

                    <!-- /.portlet-title -->
                    <div class="buttons-box">

                        <i class="icon-size-fullscreen"></i>
                        <div class="paper-ripple">
                            <div class="paper-ripple__background"></div>
                            <div class="paper-ripple__waves"></div>
                        </div>
                    </div>
                    <!-- /.buttons-box -->
              </div>
            </div>
            <!-- /.portlet-heading -->
            
            <!-- /.portlet-body -->
        </div>
        <div class="card-body pt-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped" id="data-table">
                    <thead class="bg-primary">
                        <tr>
                            <th>#</th>
                            <th>اسکله</th>
                            <th>شماره اسکله</th>
                            <th>عمق</th>
                            <th>نوع</th>
                            <td>حداکثر تناژ</td>

                            <td>عملیات</td>
                        </tr>
                    </thead>
                    <tbody>


                        @foreach (var item in Model.Waterfronts)
                        {
                            <tr>
                                <td class="align-middle">@(i++)</td>
                                <td class="align-middle">@item.WaterfrontName</td>
                                <td class="align-middle">@item.WaterfrontNumber</td>
                                <td class="align-middle">@item.Depth</td>
                                <td class="align-middle">@item.WaterfrontKind.ToDisplay()</td>
                                <td class="align-middle">@item.MaximumInputTonnage</td>

                                <td>
                                    <a class="btn btn-warning btn-sm btn-icon curve px-2" onclick="editWaterfront('@item.Id');"><i class="icon-pencil fs-6 align-middle"></i></a>
                                </td>
                            </tr>

                        }



                    </tbody>
                </table>


            </div>
            <!-- /.table-responsive -->
        </div>
        <!-- /.portlet -->
    </div>
</div>

<div id="generalmodal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">ثبت اسکله</h4>
                <button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalbody">
                <partial name="_CreateWaterfront" model="Model.CreateDto" />
            </div>
        </div>
    </div>
</div>


@section script {
  
    <script>

        $(document).ready(function () {
             
        });


        function createWaterfront() {
            $("#WaterfrontName").val('');
            $("#WaterfrontNumber").val('0');
            $("#Id").val('');
            $("#LonX").val('');
            $("#LatY").val('');
            $("#MaximumInputTonnage").val('0');
               
            $("#generalmodal").modal('show');
        }

        function editWaterfront(id) {

            $.post("@Url.Action("GetCreateWaterfrontPageById", "Waterfront")", { waterfrontId: id })
                .done(function (res) {
                    $("#modalbody").html(res);
                    $("#generalmodal").modal('show');
                })
                .fail(function (xhr, status, error) {
                    location.reload();
                });
        }


        $(".page-link").click(function (event) {
            event.preventDefault(); // غیرفعال کردن عملکرد پیشفرض href

            var hrefValue = $(this).attr("href");
            $("#pageNumber").val(hrefValue.split("p=")[1]);
            $("#formFilter").submit();
        });
    </script>
}