<div class="col-lg-12">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between">
               
                    <h3 class="title">
                        <i class="icon-frane"></i> مدیریت ناحیه ها
                    </h3>
             
                <div>
                    <a class="alert-icon btn btn-primary round" onclick="createCategory();"> <i class="icon-plus align-middle"></i> دسته بندی جدید </a>
                    
                </div>
                <!-- /.buttons-box -->
            </div>
            <!-- /.portlet-heading -->
            <!-- /.portlet-body -->
        </div>
        <div class="card-body pt-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped" id="data-table">
                    <thead class="bg-primary">
                        <tr>
                            <th>ردیف</th>
                            <th>نام دسته بندی</th>
                            <th>تعداد ناحیه</th>
                            <th>توضیحات</th>
                            <th>وضعیت</th>
                            <th>مدیریت ناحیه ها</th>
                            <td>عملیات</td>
                        </tr>
                    </thead>
                    <tbody>


                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle" >@(i++)</td>
                                <td class="align-middle" >@item.Name</td>
                                <td class="align-middle" >@item.AreaCount</td>
                                <td class="align-middle" >@item.Description</td>
                                <td class="align-middle" >
                                    <span class="label px-2 py-1 rounded label-@(item.IsActive?"success":"danger")">@(item.IsActive ? "فعال" : "غیر فعال")</span>
                                </td>

                                <td class="text-center">
                                    <a asp-action="Areas" asp-route-categoryId="@item.Id" class="btn btn-success overview overview-btn">
                                        <ul class="d-flex mb-0">
                                            <li>ناحیه ها</li>

                                        </ul>
                                    </a>
                                </td>

                                <td class="align-middle px-1 text-center">
                                    <a class="btn btn-warning px-2 btn-sm btn-icon curve" onclick="editCategory('@item.Id');">
                                        <i class="icon-pencil fs-6 align-middle"></i>
                                    </a>

                                    <a id="ChangePass@(i)" onclick="ShowQAlert(event,'ChangePass@(i)');"
                                       class="btn btn-danger px-2 btn-sm btn-icon curve btn-questions"
                                       asp-action="RemoveAreaCategory" asp-route-categoryId="@item.Id">
                                        <i class="icon-trash fs-6 align-middle fa-flip-horizontal"></i>
                                    </a>
                                </td>
                            </tr>

                        }

                    </tbody>
                </table>


            </div>
            <!-- /.table-responsive -->
        </div>
        <!-- /.portlet -->
    </div>
</div>



<div id="generalmodal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">ثبت دسته بندی محوطه</h4>
                <button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalbody">
                <partial name="_CreateAreaCategory" model="@(new CreateAreaCategoryDto())" />
            </div>
        </div>
    </div>
</div>



@section script {
    <script>
        function createCategory() {
            $("#Name").val('');
            $("#Description").val('');
            $("#Id").val('');
            $("#IsActive").prop('checked', true);
            $("#generalmodal").modal('show');

        }
        function editCategory(id) {

            $.post("@Url.Action("GetAreaCategoryById","AreaPoint")", { categoryId: id })
                .done(function (res) {
                    $("#modalbody").html(res);
                    $("#generalmodal").modal('show');
                });
        }


         
    </script>
}
