@model List<AreaCategoryDto>
@{
    ViewData["Title"] = "دسته بندی ناحیه ها";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    int i = 1;
}


<!--<div class="col-md-12">
    <div class="breadcrumb-box border shadow">
