<script>
    const Toast = Swal.mixin({
        toast: true,
        position: "top-start",
        showConfirmButton: false,
        showCloseButton: true,
        timer: 3000,
        timerProgressBar: true,
        didOpen: (toast) => {
            toast.onmouseenter = Swal.stopTimer;
            toast.onmouseleave = Swal.resumeTimer;
        }
    });

    function showAlert(message, type) {
        var icon = type == 0 ? "success" : "error";

        Toast.fire({
            icon: icon,
            title: message
        });
    }


    function showAlert2(message, type) {
        var icon = type == 0 ? "success" : "error";
        Swal.fire({
            position: "center",
            icon: icon,
            title: message,
            showConfirmButton: false,
            timer: 2000
        });
    }
</script>


@if (TempData.Peek("msg") != null)
{
    ResponseMessage message = JsonConvert.DeserializeObject<ResponseMessage>(TempData["msg"].ToString());
    var icon = message.Type == ResponseMessageType.Success ? "success" : "error";

    <script>
        
        Toast.fire({
            icon: "@icon",
            title: "@message.Message"
        });
    </script>
}


