@model WarehouseSegmentPageDto
@{
	ViewData["Title"] = "قطعه بندی ها";
	Layout = "~/Views/Shared/AdminLayout.cshtml";
	int i = 1;

}



<div class="col-lg-12">
	<div class="card">
		<div class="card-header">
			<div class="d-flex justify-content-between">

				<h3 class="title">
					<a asp-action="Warehouses"><i class="fa-solid fa-right-to-bracket me-2"></i></a>
					<i class="icon-frane"></i> مدیریت قطعه های انبار (@Model.WarehouseInfo?.Name)
				</h3>

				<div>
					<a class="alert-icon btn btn-success round mx-2" onclick="createSegment();">قطعه جدید</a>
				</div>
			</div>
		</div>
		<div class="card-body pt-0">
			<div class="table-responsive">
				<table class="table table-bordered table-hover table-striped" id="data-table">
					<thead class="bg-primary">
						<tr>
							<th>ردیف</th>
							<th>نام قطعه</th>
							<th>وضعیت</th>
							<td>عملیات</td>
						</tr>
					</thead>
					<tbody>
					
						@foreach (var item in Model.WarehouseSegments)
						{
							<tr>
								<td class="align-middle">@(i++)</td>
								<td class="align-middle">@item.Name</td>
								<td class="align-middle text-center">
									<span class="label px-2 py-1 rounded label-@(item.IsActive?"success":"danger")">@(item.IsActive ? "فعال" : "غیر فعال")</span>
								</td>

								<td class="align-middle">
									<a class="btn btn-warning btn-sm px-2 btn-icon curve" onclick="editSegment('@item.Id');">
										<i class="icon-pencil fs-6 align-middle"></i>
									</a>

									<a id="RemoveSegment@(i)" onclick="ShowQAlert(event,'RemoveSegment@(i)');"
									   class="btn btn-danger px-2 btn-sm btn-icon curve btn-questions"
									   asp-action="DeleteWarehouseSegment" asp-route-warehouseSegmentId="@item.Id"
									   asp-route-warehouseId="@Model.WarehouseInfo.Id">
										<i class="icon-trash fs-6 align-middle fa-flip-horizontal"></i>
									</a>
								</td>
							</tr>

						}

					</tbody>
				</table>


			</div>
			<!-- /.table-responsive -->
		</div>
		<!-- /.portlet -->
	</div>
</div>



<div id="generalmodal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">

				<h4 class="modal-title">ثبت قطعه</h4>
				<button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body" id="modalbody">
				<partial name="_CreateSegment" model="@(new CreateWarehouseSegmentDto{ WarehouseId = Model.WarehouseInfo.Id })" />
			</div>
		</div>
	</div>
</div>



@section script {
	<script>
		function createSegment() {
			$("#Name").val('');
			$("#Id").val('');
			$("#IsActive").prop('checked', true);
			$("#generalmodal").modal('show');

		}
		function editSegment(id) {

			$.post("@Url.Action("GetWarehouseSegmentById", "Warehouse")", { warehouseSegmentId: id })
				.done(function (res) {
					$("#modalbody").html(res);
					$("#generalmodal").modal('show');
				});
		}

	</script>
}
