@model PageResult<CreateDriverDto>
@{
    ViewData["Title"] = "راننده ها";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    int i = ((Model.PageNumber - 1) * Model.PageSize) + 1;
    var companyId = (Guid)ViewBag.companyId;
}

<div class="col-lg-12">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between">

                <h3 class="title">
                    <a asp-controller="Company" asp-action="Details" asp-route-companyId="@ViewBag.companyId"><i class="fa-solid fa-right-to-bracket me-2"></i></a>
                    <i class="icon-frane"></i> لیست راننده های شرکت
                </h3>

                <div>
                    <a class="alert-icon btn btn-success round" asp-controller="Transportation" asp-action="CreateDriver" asp-route-companyId="@companyId">راننده جدید</a>
                    @* <a asp-controller="Company" asp-action="Details" asp-route-companyId="@ViewBag.companyId" class="btn btn-warning btn-round"> <i class="icon-close"> </i> برگشت</a> *@
                </div>
                
            </div>
        </div>
       
        <div class="card-body pt-0">
            <div class="table-responsive  vh-100">
                <table class="table table-bordered table-hover table-striped" id="data-table">
                    <thead class="bg-primary">
                        <tr>
                            <th>ردیف</th>
                            <th>نام و نام خانوادگی</th>
                            <th>کد ملی</th>
                            <td>تلفن</td>

                            <td>عملیات</td>
                        </tr>
                    </thead>
                    <tbody>


                        @foreach (var item in Model.Data)
                        {
                            <tr>
                                <td class="align-middle">@(i++)</td>
                                <td class="align-middle">@item.Name</td>
                                <td class="align-middle">@item.CodeMeli</td>
                                <td class="align-middle">@item.Phone</td>

                                <td class="d-flex justify-content-first">
                                    <div class="dropdown-basic">
                                        <div class="dropdown">
                                            <div class="btn-group mb-0">
                                                <button class="dropbtn btn-light rounded" type="button"><i data-feather="chevron-down" class="text-info"></i></button>
                                                <div class="dropdown-content">

                                                    <a asp-controller="Transportation" asp-action="CreateDriver" asp-route-companyId="@item.CompanyId" asp-route-driverId="@item.Id"><i class="icon-pencil"></i> ویرایش</a>

                                                    <a id="DeleteCompany@(i)" onclick="ShowQAlert(event,'DeleteCompany@(i)');" asp-controller="Company" asp-action="DeleteCompany" asp-route-companyId="@item.Id"><i class="icon-trash fa-flip-horizontal"> </i> حذف</a>

                                                </div><!-- /.btn-group -->
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>

                        }



                    </tbody>
                </table>
                <div class="mt-4">
                    <cs-pager cs-paging-pagesize="@Model.PageSize"
                              cs-paging-pagenumber="@Model.PageNumber"
                              cs-paging-totalitems="@Model.TotalItems"
                              cs-paging-maxpageritems="10"
                              cs-pagenumber-param="p"
                              asp-route-companyId="@ViewBag.companyId"
                              cs-show-first-last="true"
                              cs-suppress-empty-nextprev="true"
                              cs-suppress-inactive-firstlast="true"
                              cs-show-numbered="true"
                              cs-first-page-text="ابتدا"
                              cs-last-page-text="انتها"
                              cs-next-page-title="بعدی"
                              cs-previous-page-title="قبلی"
                              cs-first-page-title="ابتدا"
                              cs-last-page-title="انتها"
                              cs-next-page-text="بعدی"
                              cs-previous-page-text="قبلی"
                              cs-pager-li-current-class="page-item active"
                              cs-pager-li-other-class="page-item"
                              cs-pager-li-non-active-class="page-item disabled"
                              cs-pager-link-current-class="page-link"
                              cs-pager-link-other-class="page-link"
                              asp-controller="Transportation"
                              asp-action="Drivers">
                    </cs-pager>
                </div>
            </div>
        </div>
    </div>
</div>

