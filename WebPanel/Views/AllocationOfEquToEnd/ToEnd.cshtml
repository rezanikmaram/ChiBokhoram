    @* Damaged Equipment - خسارت وارد شده به تجهیزات *@
    <script>

        function damagedShowModal() {
            $('#CreateDamagedDto_Id').val('');
            $('#CreateDamagedDto_Description').val('');
            $('#CreateDamagedDto_Price').val('0');
            $('#CreateDamagedDto_PayByCompanyOwner').prop("checked", true);
            $('#CreateDamagedDto_DateFa').val('');
            $("#Damagedmodal").modal('show');
        }

        function addOrUpdateDamaged() {
            let allocationEquipmentId = $('#CreateDamagedDto_AllocationEquipmentId').val();
            let id = $('#CreateDamagedDto_Id').val();
            let seoEquipmentId = $("#CreateDamagedDto_SeoEquipmentId").val();
            let description = $('#CreateDamagedDto_Description').val();
            let price = $('#CreateDamagedDto_Price').val();
            let dateFa = $('#CreateDamagedDto_DateFa').val();


            $("#Damagedmodal").modal('hide');
            $.post("@Url.Action("AddOrUpdateDamaged", "AllocationOfEquToEnd")",
                {
                    allocationEquipmentId,
                    id,
                    seoEquipmentId,
                    description,
                    price,
                    dateFa,
                    payByCompanyOwner: document.getElementById("CreateDamagedDto_PayByCompanyOwner").checked
                })
                .done(function (res) {

                    $("#DamagedListId").html(res);
                })
                .fail(function (xhr, status, error) {
                    location.reload();
                });
        }

        function editDamaged(row) {
            let id = $('#damaged_id' + row).text();
            let seoEquipmentId = $("#damaged_SeoEquipmentId" + row).text();
            let description = $('#damaged_Description' + row).text();
            let price = $('#damaged_Price' + row).text();
            let payOwner = Number($('#damaged_PayOwner' + row).text());
            let dateFa = $('#damaged_DateFa' + row).text();


            $('#CreateDamagedDto_Id').val(id);
            $('#CreateDamagedDto_SeoEquipmentId').val(seoEquipmentId);
            $('#CreateDamagedDto_Description').val(description);
            $('#CreateDamagedDto_Price').val(Number(price));
            $('#CreateDamagedDto_DateFa').val(dateFa);

            if (payOwner == 1)
                $('#CreateDamagedDto_PayByCompanyOwner').prop("checked", true);
            else
                $('#CreateDamagedDto_PayByCompanyOwner').prop("checked", false);

            $("#CreateDamagedDto_SeoEquipmentId").select2({
                dropdownParent: $('#Damagedmodal')
            });
            $("#CreateDamagedDto_SeoEquipmentId").trigger('change');

            $("#Damagedmodal").modal('show');
        }

        async function DeleteDamage(event, damagedId) {
            event.preventDefault();
            let result = await ShowQAlert2(event);

            if (result === true) {
                $.post("@Url.Action("DeleteDamaged", "AllocationOfEquToEnd")",
                    {
                        damagedId
                    })
                    .done(function (res) {

                        $("#DamagedListId").html(res);
                    })
                    .fail(function (xhr, status, error) {
                        location.reload();
                    });
            }

        }
    </script>


