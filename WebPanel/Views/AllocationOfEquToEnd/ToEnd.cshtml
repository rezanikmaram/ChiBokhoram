@model AllocationOfEquToEndPageDto
@{
    ViewData["Title"] = "تکمیل اطلاعات عملیات";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}


@section style {

}


@* اطلاعات پایه *@

<div class="col-lg-12">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between">
                <h3 class="title">
                    <a asp-action="SeoAllocationPage" asp-route-seoid="@Model.SeoId" asp-controller="Seo"><i class="fa-solid align-middle fa-right-to-bracket me-2"></i></a>
                    @Model.PageTitle
                </h3>

                <div>
                    <a class="btn btn-success rounded-3 mx-1"
                       asp-action="GetAllocationEquOperationExcelFile"
                       asp-route-allocationEquId="@Model.AllocationEquId">
                        <i class="icon-printer"></i>
                        گزارش اکسل
                    </a>

                    @if (Model != null && Model?.State == AllocationEquipmentState.InOperation)
                    {
                        <a id="AcceptEndOperation"
                           class="btn btn-success rounded-3 mx-1"
                           onclick="ShowQAlert(event, 'AcceptEndOperation');"
                           asp-action="AcceptEndOperation" asp-route-allocationEquId="@Model.AllocationEquId">
                            <i class="icon-plus"></i>
                            ثبت اتمام عملیات
                        </a>
                    }
                </div>
            </div>

            <!-- /.portlet-title -->
            <div class="buttons-box">

                <i class="icon-size-fullscreen"></i>
                <div class="paper-ripple">
                    <div class="paper-ripple__background"></div>
                    <div class="paper-ripple__waves"></div>
                </div>
                <!-- /.buttons-box -->
            </div>
            <!-- /.portlet-heading -->
            <!-- /.portlet-body -->
        </div>
    </div>
</div>



@* مقدار تناژ *@
<partial name="_ValueTonnagePage" model="Model.ValueTonnagePage" />


@* اجاره ساعتی *@
<partial name="_RentalPage" model="Model.RentalPage" />


@* تعداد جابجایی تجهیز  *@
<partial name="_CountDisPage" model="Model.CountDisPage" />


@* تعداد جابجایی درب انبار  *@
<partial name="_MovingDoorPage" model="Model.MovingDoorPage" />


@* خسارت وارد شده به تجهیزات  *@
<partial name="_DamagedPage" model="Model.DamagedPage" />

@* توضیحات  *@
<partial name="_DescriptionPage" model="Model.DescriptionPage" />


@* افزودن تجهیز جدید *@
<partial name="_NewEqupment" />



@section script {
    <script src="~/assets/js/validation/jquery.validate.min.js"></script>
    <script src="~/assets/js/validation/jquery.validate.unobtrusive.min.js"></script>


    <script>
        $(document).ready(function () {

            $('.clockpicker').clockpicker({
                placement: 'bottom',
                align: 'left',
                donetext: 'تایید'
            });

            $("#CreateValueTonnageDto_SeoEquipmentId").select2({
                dropdownParent: $('#valueTonnagemodal')
            });

            $("#CreateRentalDto_SeoEquipmentId").select2({
                dropdownParent: $('#rentalmodal')
            });

            $("#CreateCountDisDto_SeoEquipmentId").select2({
                dropdownParent: $('#CountDismodal')
            });

            $("#CreateMovingDoorDto_SeoEquipmentId").select2({
                dropdownParent: $('#MovingDoormodal')
            });

            $("#CreateDamagedDto_SeoEquipmentId").select2({
                dropdownParent: $('#Damagedmodal')
            });

        });



        kamaDatepicker('CreateCountDisDto_DateFa', customOptions);
        kamaDatepicker('CreateDamagedDto_DateFa', customOptions);
        kamaDatepicker('CreateDescriptionDto_DateFa', customOptions);
        kamaDatepicker('CreateMovingDoorDto_DateFa', customOptions);
        kamaDatepicker('CreateRentalDto_DateFa', customOptions);
        kamaDatepicker('CreateValueTonnageDto_DateFa', customOptions);
    </script>



    @* value tonnage *@
    <script>

        function valueTonnageShowModal() {
            $('#CreateValueTonnageDto_Id').val('');
            $('#CreateValueTonnageDto_Tonnage').val('0');
            $('#CreateValueTonnageDto_DateFa').val('');
            $("#valueTonnagemodal").modal('show');
        }

        function addOrUpdateValueTonnage() {
            let allocationEquipmentId = $('#CreateValueTonnageDto_AllocationEquipmentId').val();
            let id = $('#CreateValueTonnageDto_Id').val();
            let tonnage = $('#CreateValueTonnageDto_Tonnage').val();
            let seoEquipmentId = $("#CreateValueTonnageDto_SeoEquipmentId").val();

            let dateFa = $('#CreateValueTonnageDto_DateFa').val();

            $("#valueTonnagemodal").modal('hide');
            $.post("@Url.Action("AddOrUpdateValueTonnage", "AllocationOfEquToEnd")",
                {
                    allocationEquipmentId,
                    id,
                    tonnage,
                    dateFa,
                    seoEquipmentId
                })
                .done(function (res) {

                    $("#ValueTonnageListId").html(res);
                })
                .fail(function (xhr, status, error) {
                    location.reload();
                });
        }

        function editValueTonnage(row) {
            // let allocationEquipmentId = $('#CreateValueTonnageDto_AllocationEquipmentId').val();
            let id = $('#vt_id' + row).text();
            let tonnage = $('#vt_Tonnage' + row).text();
            let seoEquId = $("#vt_SeoEquipmentId" + row).text();
            let dateFa = $('#vt_DateFa' + row).text();


            $('#CreateValueTonnageDto_Id').val(id);
            $('#CreateValueTonnageDto_Tonnage').val(tonnage);
            $('#CreateValueTonnageDto_SeoEquipmentId').val(seoEquId)
            $('#CreateValueTonnageDto_DateFa').val(dateFa);

            $("#CreateValueTonnageDto_SeoEquipmentId").select2({
                dropdownParent: $('#valueTonnagemodal')
            });
            $("#CreateValueTonnageDto_SeoEquipmentId").trigger('change');

            $("#valueTonnagemodal").modal('show');
        }


        async function DeleteValueTonnage(event, valueTonnageId) {
            event.preventDefault();
            let result = await ShowQAlert2(event);

            if (result === true) {
                $.post("@Url.Action("DeleteValueTonnage", "AllocationOfEquToEnd")",
                    {
                        valueTonnageId
                    })
                    .done(function (res) {

                        $("#ValueTonnageListId").html(res);
                    })
                    .fail(function (xhr, status, error) {
                        location.reload();
                    });
            }

        }

    </script>



    @* rental  اجاره ساعتی / تناژی *@
    <script>
        function rentalShowModal() {
            $('#CreateRentalDto_Id').val('');
            $('#CreateRentalDto_Location').val('');
            $('#CreateRentalDto_Rental').val('0');
            $('#CreateRentalDto_TonnageTanzif').val('0');
            $('#CreateRentalDto_TonnageDepo').val('0');
            $('#CreateRentalDto_Tonnage').val('0');
            $('#CreateRentalDto_DateFa').val('');
            $("#rentalmodal").modal('show');
        }

        function addOrUpdateRental() {
            let allocationEquipmentId = $('#CreateRentalDto_AllocationEquipmentId').val();
            let id = $('#CreateRentalDto_Id').val();
            let seoEquipmentId = $("#CreateRentalDto_SeoEquipmentId").val();
            let location = $('#CreateRentalDto_Location').val();

            let rental = $('#CreateRentalDto_Rental').val();
            let tonnageTanzif = $('#CreateRentalDto_TonnageTanzif').val();
            let tonnageDepo = $('#CreateRentalDto_TonnageDepo').val();

            let tonnage = $('#CreateRentalDto_Tonnage').val();
            let dateFa = $('#CreateRentalDto_DateFa').val();



            $("#rentalmodal").modal('hide');
            $.post("@Url.Action("AddOrUpdateRental", "AllocationOfEquToEnd")",
                {
                    allocationEquipmentId,
                    id,
                    seoEquipmentId,

                    location,
                    rental,
                    tonnageTanzif,
                    tonnageDepo,
                    tonnage,

                    dateFa
                })
                .done(function (res) {

                    $("#RentalListId").html(res);
                })
                .fail(function (xhr, status, error) {
                    location.reload();
                });
        }

        function editRental(row) {

            let id = $('#rental_id' + row).text();
            let seoEquipmentId = $("#rental_SeoEquipmentId" + row).text();
            let location = $('#rental_Location' + row).text();

            let rental = $('#rental_Rental' + row).text();
            let tonnageTanzif = $('#rental_TonnageTanzif' + row).text();
            let tonnageDepo = $('#rental_TonnageDepo' + row).text();

            let tonnage = $('#rental_Tonnage' + row).text();

            let dateFa = $('#rental_DateFa' + row).text();


            $('#CreateRentalDto_Id').val(id);
            $('#CreateRentalDto_SeoEquipmentId').val(seoEquipmentId);
            $('#CreateRentalDto_Location').val(location);

            $('#CreateRentalDto_Rental').val(Number(rental));
            $('#CreateRentalDto_TonnageTanzif').val(Number(tonnageTanzif));
            $('#CreateRentalDto_TonnageDepo').val(Number(tonnageDepo));

            $('#CreateRentalDto_Tonnage').val(Number(tonnage));
            $('#CreateRentalDto_DateFa').val(dateFa);


            $("#CreateRentalDto_SeoEquipmentId").select2({
                dropdownParent: $('#rentalmodal')
            });
            $("#CreateRentalDto_SeoEquipmentId").trigger('change');

            $("#rentalmodal").modal('show');
        }

        async function DeleteRental(event, rentalId) {
            event.preventDefault();
            let result = await ShowQAlert2(event);

            if (result === true) {
                $.post("@Url.Action("DeleteRental", "AllocationOfEquToEnd")",
                    {
                        rentalId
                    })
                    .done(function (res) {

                        $("#RentalListId").html(res);
                    })
                    .fail(function (xhr, status, error) {
                        location.reload();
                    });
            }

        }
    </script>


