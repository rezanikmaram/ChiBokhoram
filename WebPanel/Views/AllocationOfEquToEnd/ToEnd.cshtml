    @* افزودن تجهیز جدید *@
    <script>
        function newEquipment() {
            let allocationEquEndReportType = $('#AllocationEquEndReportTypeId').val();
            let EquipmentName = $('#EquipmentNameId').val();


            $.post("@Url.Action("NewEquipment", "AllocationOfEquToEnd")",
                {
                    allocationEquEndReportType,
                    EquipmentName
                })
                .done(function (res) {
                    location.reload();
                })
                .fail(function (xhr, status, error) {
                    location.reload();
                });

        }


        function showNewEquipmentModal(type, parentModalId) {
            $('#AllocationEquEndReportTypeId').val(type);

            $("#" + parentModalId).modal('hide');
            $("#NewEquModal").modal('show');
        }

    </script>
}
