@model AllocationEquDescriptionPageDto



<div class="col-lg-12">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between">
                
                    <h3 class="title">
                        <i class="icon-frane"></i>    توضیحات
                    </h3>

                   <div>
                        <a class="btn btn-primary rounded"
                           onclick="descriptionShowModal();">
                            <i class="icon-plus align-middle"></i>
                            مقدار جدید
                        </a>

                        <!-- /.portlet-title -->
                        <div class="buttons-box">

                            <i class="icon-size-fullscreen"></i>
                            <div class="paper-ripple">
                                <div class="paper-ripple__background"></div>
                                <div class="paper-ripple__waves"></div>
                            </div>
                        </div>
                   </div>
                <!-- /.buttons-box -->
            </div>
            <!-- /.portlet-heading -->
            <!-- /.portlet-body -->
        </div>
        <div class="card-body pt-0">
            <div id="DescriptionListId">
                <partial name="_DescriptionList" model="Model.List" />
            </div>

        </div>
        <!-- /.portlet -->
    </div>
</div>



<div id="Descriptionmodal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">   ثبت توضیح  </h4>
                <button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalbody">

                <div class="card-body pt-0">

                    <div class="form-body">


                        <input asp-for="CreateDescriptionDto.Id" hidden />
                        <input asp-for="CreateDescriptionDto.AllocationEquipmentId" hidden />
                        <div class="row gy-3">



                            <div class="col-sm-12">
                                <div class="form-group  ">
                                    <label>توضیح</label>
                                    <div class="input-group">
                                        <textarea rows="5" asp-for="CreateDescriptionDto.Description" class="form-control" required>
                                            </textarea>
                                    </div>
                                    <span asp-validation-for="CreateDescriptionDto.Description" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="form-group  ">
                                    <label>تاریخ</label>
                                    <div class="input-group">
                                        <input type="text" asp-for="CreateDescriptionDto.DateFa" required autocomplete="off" class="form-control">
                                    </div>
                                    <span asp-validation-for="CreateDescriptionDto.DateFa" class="text-danger"></span>
                                </div>
                            </div>

                        </div>


                        <div class="modal-footer px-0 border-0">
                            <a onclick="addOrUpdateDescription()" class="btn btn-success btn-round">  ثبت</a>
                            <button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>
                        </div>

                    </div>

                </div>

            </div>
        </div>
    </div>
</div>









