@model List<AllocationEquMovingDoorDto>

@{
    int rowMovingDoor = 1;
}

<div class="table-responsive">
    <table class="table table-sm table-bordered table-hover table-striped" id="data-table">
        <thead>
            <tr>
                <th style="width: 5%">ردیف</th>

                <th> نوع  </th>
                <th>تعداد جابجایی  </th>
                <td>تاریخ</td>

                <td>عملیات</td>
            </tr>
        </thead>
        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td class="align-middle" >@(rowMovingDoor)</td>
                    <td class="align-middle"  style="display:none" id="md_id@(rowMovingDoor)">@item.Id </td>
                    <td class="align-middle" style="display:none" id="md_SeoEquipmentId@(rowMovingDoor)">@item.SeoEquipmentId</td>
                    <td class="align-middle" >@item.Title </td>
                    <td class="align-middle"  id="md_CountMoving@(rowMovingDoor)">@item.CountMoving</td>
                    <td class="align-middle"  id="md_DateFa@(rowMovingDoor)">@item.DateFa</td>


                    <td class="align-middle">
                        <a class="btn btn-warning px-2 btn-sm btn-icon curve" onclick="editMovingDoor('@rowMovingDoor');"><i class="icon-pencil fs-6 align-middle"></i></a>

                        <a onclick="DeleteMovingDoor(event, '@item.Id');" class="btn btn-danger btn-sm px-2 btn-icon curve btn-questions">
                            <i class="icon-trash fs-6 align-moiddle fa-flip-horizontal"></i>
                        </a>
                    </td>
                    @{
                        rowMovingDoor++;
                    }
                </tr>
            }

            @if (Model?.Any() == true)
            {
                <tr style=" background-color: #3fbb7630;">
                    <td>--</td>

                    <th>جمع کل </th>
                    <th> @(Model?.Sum(x => x.CountMoving).ToPrice(ToPriceExtention.PriceType.NoType) ?? "0")</th>

                    <th>---</th>
                    <th>--</th>

                </tr>
            }
        </tbody>
    </table>

</div>











