@model AllocationEquRentalPageDto



<div class="col-lg-12">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between">
               
                    <h3 class="title">
                        <i class="icon-frane"></i>    اجاره ساعتی / تناژی تجهیزات
                    </h3>

                    <div>

                    <a class="btn btn-primary rounded"
                       onclick="rentalShowModal();">
                        <i class="icon-plus align-middle"></i>
                        مقدار جدید
                    </a>
                    <!-- /.portlet-title -->
                    <div class="buttons-box">

                        <i class="icon-size-fullscreen"></i>
                        <div class="paper-ripple">
                            <div class="paper-ripple__background"></div>
                            <div class="paper-ripple__waves"></div>
                        </div>
                    </div>
                    </div>
                    
                <!-- /.buttons-box -->
            </div>
            <!-- /.portlet-heading -->
            <!-- /.portlet-body -->
        </div>
        <div class="card-body pt-0">
            <div id="RentalListId">
                <partial name="_RentalList" model="Model.List" />
            </div>

        </div>
        <!-- /.portlet -->
    </div>
</div>



<div id="rentalmodal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">  اجاره ساعتی/تناژ تجهیز</h4>
                <button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalbody">

                <div class="card-body pt-0">

                    <div class="form-body">


                        <input asp-for="CreateRentalDto.Id" hidden />
                        <input asp-for="CreateRentalDto.AllocationEquipmentId" hidden />
                        <div class="row gy-4">

                            <div class="col-sm-12">
                                <div class="form-group">
                                    <label>نوع تجهیز</label>
                                    <div class="input-group col-sm-6" >
                                        <select class="form-control select2 " asp-for="CreateRentalDto.SeoEquipmentId"
                                                asp-items="Model.EquipmentsTitle" style="width:100%!important;">
                                        </select>

                                      @*   <span class="input-group-btn">
                                            <a class="btn px-2 btn-success"
                                               onclick="showNewEquipmentModal('0', 'rentalmodal')">
                                                <i class="icon-plus align-middle"></i>

                                            </a>
                                        </span> *@
                                       
                                    </div>
                                    <span asp-validation-for="CreateRentalDto.SeoEquipmentId"
                                          class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="form-group  ">
                                    <label>محل عملیات</label>
                                    <div class="input-group">
                                        <input type="text" asp-for="CreateRentalDto.Location" class="form-control">
                                    </div>
                                    <span asp-validation-for="CreateRentalDto.Location" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="form-group  ">
                                    <label>اجاره ساعتی / مرحله ای</label>
                                    <div class="input-group">
                                        <input type="number" asp-for="CreateRentalDto.Rental" min="0" class="form-control">
                                    </div>
                                    <span asp-validation-for="CreateRentalDto.Rental" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="form-group  ">
                                    <label>تناژ تنظیف</label>
                                    <div class="input-group">
                                        <input type="number" asp-for="CreateRentalDto.TonnageTanzif" min="0" class="form-control">
                                    </div>
                                    <span asp-validation-for="CreateRentalDto.TonnageTanzif" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="form-group  ">
                                    <label>تناژ دپو</label>
                                    <div class="input-group">
                                        <input type="number" asp-for="CreateRentalDto.TonnageDepo" min="0" class="form-control">
                                    </div>
                                    <span asp-validation-for="CreateRentalDto.TonnageDepo" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="form-group  ">
                                    <label>تناژ عملیات</label>
                                    <div class="input-group">
                                        <input type="number" asp-for="CreateRentalDto.Tonnage" min="0" class="form-control">
                                    </div>
                                    <span asp-validation-for="CreateRentalDto.Tonnage" class="text-danger"></span>
                                </div>
                            </div>

                             

                            <div class="col-sm-6">
                                <div class="form-group  ">
                                    <label>تاریخ</label>
                                    <div class="input-group">
                                        <input type="text" asp-for="CreateRentalDto.DateFa" required autocomplete="off" class="form-control">
                                    </div>
                                    <span asp-validation-for="CreateRentalDto.DateFa" class="text-danger"></span>
                                </div>
                            </div>

                        </div>


                        <div class="modal-footer border-0 px-0">
                            <a onclick="addOrUpdateRental()" class="btn btn-success btn-round">  ثبت</a>
                            <button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>
                        </div>

                    </div>

                </div>

            </div>
        </div>
    </div>
</div>









