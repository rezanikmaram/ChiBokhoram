@model List<AllocationEquValueTonnageDto>

@{
    int rowValue = 1;
    string totalTonnage = Model?.Sum(x => x.Tonnage).ToPrice(ToPriceExtention.PriceType.NoType) ?? "0";
}

<div class="table-responsive">
    <table class="table table-sm table-bordered table-hover table-striped" id="data-table">
        <thead>
            <tr>
                <th style="width: 5%">ردیف</th>

                <th> نوع تجهیز </th>
                <th>مقدار تخلیه/بارگیری</th>
                <td>تاریخ</td>

                <td>عملیات</td>
            </tr>
        </thead>
        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td class="align-middle">@(rowValue)</td>
                    <td class="align-middle" style="display:none" id="vt_id@(rowValue)">@item.Id </td>
                    <td class="align-middle" style="display:none" id="vt_SeoEquipmentId@(rowValue)">@item.SeoEquipmentId</td>
                    <td class="align-middle" id="vt_Title@(rowValue)">@item.Title </td>
                    <td class="align-middle" >@item.TonnageTitle</td>
                    <td style="display:none" id="vt_Tonnage@(rowValue)">@item.Tonnage</td>
                    <td class="align-middle" id="vt_DateFa@(rowValue)">@item.DateFa</td>


                    <td class="align-middle">
                        <a class="btn px-2 btn-warning btn-sm btn-icon curve" onclick="editValueTonnage('@rowValue');"><i class="icon-pencil fs-6 align-middle"></i></a>

                        <a onclick="DeleteValueTonnage(event, '@item.Id');" class="btn px-2 btn-danger btn-sm btn-icon curve btn-questions">
                            <i class="icon-trash fs-6 align-middle fa-flip-horizontal"></i>
                        </a>
                    </td>
                    @{
                        rowValue++;
                    }
                </tr>
            }


            @if (Model?.Any() == true)
            {
                <tr style=" background-color: #3fbb7630;">
                    <td>--</td>

                    <th>جمع کل </th>
                    <th>@totalTonnage</th>
                    <th>--</th>
                    <th>--</th>

                </tr>
            }

        </tbody>
    </table>

   
    

</div>











