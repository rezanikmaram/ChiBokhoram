@model VesselAllocationNoticeListDto
@{
    ViewData["Title"] = "جزئیات اعلام تخصیص شناور";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="card">
    <div class="card-header pb-0 px-3">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="title">
                <i class="fa fa-ship"></i>
                <a asp-action="Index"><i class="fa-solid fa-right-to-bracket me-2"></i></a>
                جزئیات اعلام تخصیص شناور
            </h3>
        </div>
    </div>
    <div class="card-body pt-0">
        <div class="bg-primary rounded-3 mt-4 p-3">
            <div class="row gy-3 align-items-center">
                <div class="col-4">
                    <p class="fs-6 fw-bold"><i class="fa fa-ship me-1"></i> @Model.ShipName</p>
                    <p class="fs-6 fw-bold"><i class="fa fa-map-marker me-1"></i> سفر: @Model.VoyageNumber</p>
                </div>
                <div class="col-4">
                    <p class="fs-6 fw-bold"><i class="fa fa-building me-1"></i> @Model.CompanyName</p>
                    <p class="fs-6 fw-bold"><i class="fa fa-tasks me-1"></i> @Model.TransportTypeTitle</p>
                </div>
                <div class="col-4">
                    <p class="fs-6 fw-bold"><i class="fa fa-cube me-1"></i> @Model.ProductName</p>
                    <p class="fs-6 fw-bold"><i class="fa fa-user me-1"></i> @Model.PersonelName</p>
                </div>
                <div class="col-4">
                    <p class="fs-6 fw-bold"><i class="fa fa-anchor me-1"></i> @Model.PortName</p>
                    <p class="fs-6 fw-bold"><i class="fa fa-calendar me-1"></i> @Model.CreatedDateFa</p>
                </div>
            </div>
        </div>
    </div>
</div>
