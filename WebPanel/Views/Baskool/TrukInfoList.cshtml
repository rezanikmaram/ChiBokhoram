@using Entities.Entities.Hirman
@model PageResult<FpnDeviceLog>
@{
	ViewData["Title"] = "ورود خروج کامیون ها";
	Layout = "~/Views/Shared/AdminLayout.cshtml";
	int i = ((Model.PageNumber - 1) * Model.PageSize) + 1;
}

<div class="col-lg-12">
	<div class="card">
		<div class="card-header">
			<div class="d-flex">
				<div class="d-flex justify-content-between">
					<h3 class="title">
						<i class="icon-frane"></i> ورود خروج کامیون ها
					</h3>

					@* <div>
						<a class="alert-icon btn btn-success round" asp-action="DetectNoTruck">بروزرسانی</a>
					</div> *@
				</div>
				@* <a class="alert-icon btn btn-success round" asp-controller="Company" asp-action="CreateCompany">شرکت جدید</a>*@


				<!-- /.portlet-title -->
				<div class="buttons-box">

					<i class="icon-size-fullscreen"></i>
					<div class="paper-ripple">
						<div class="paper-ripple__background"></div>
						<div class="paper-ripple__waves"></div>
					</div>
				</div>
				<!-- /.buttons-box -->
			</div>
			<!-- /.portlet-heading -->

		</div>

		<div class="card-body pt-0">
			<div class="table-responsive">

				<div id="data-table_filter" class="dataTables_filter">
				</div>

				<table class="table table-bordered table-hover table-striped" id="data-table">
					<thead class="bg-primary">
						<tr>
							<td>#</td>
							<td>تاریخ</td>
							<td>نام دستگاه</td>
							<td>پلاک</td>

							<td>نوع کامیون</td>
							<td>مالک کامیون</td>
							<td>کد ملی</td>

						</tr>
					</thead>
					<tbody>
						@if (Model?.Data?.Any() == true)
						{
							foreach (var item in Model.Data)
							{
								<tr>
									<td>@(i++)</td>
									<td style="direction:ltr">@item.Date.ToShortPersianDateTimeString()</td>
									<td>@item?.Device?.Name (@item.DeviceRadio?.Name)</td>
									<td>@item.TruckInfoSokht?.Plaque</td>

									<td>@item.TruckInfoSokht?.CarType</td>
									<td>@item.TruckInfoSokht?.Name @item.TruckInfoSokht?.LastName</td>
									<td>@item.TruckInfoSokht?.NationalCode</td>
								</tr>
							}
						}

					</tbody>
				</table>
				<div>
					<cs-pager cs-paging-pagesize="@Model.PageSize"
							  cs-paging-pagenumber="@Model.PageNumber"
							  cs-paging-totalitems="@Model.TotalItems"
							  cs-paging-maxpageritems="20"
							  cs-pagenumber-param="p"
							  cs-show-first-last="true"
							  cs-suppress-empty-nextprev="true"
							  cs-suppress-inactive-firstlast="true"
							  cs-show-numbered="true"
							  cs-first-page-text="ابتدا"
							  cs-last-page-text="انتها"
							  cs-next-page-title="بعدی"
							  cs-previous-page-title="قبلی"
							  cs-first-page-title="ابتدا"
							  cs-last-page-title="انتها"
							  cs-next-page-text="بعدی"
							  cs-previous-page-text="قبلی"
							  cs-pager-li-current-class="page-item active"
							  cs-pager-li-other-class="page-item"
							  cs-pager-li-non-active-class="page-item disabled"
							  cs-pager-link-current-class="page-link"
							  cs-pager-link-other-class="page-link"
							  asp-controller="Baskool"
							  asp-action="TrukInfoList">
					</cs-pager>
				</div>

			</div>
			<!-- /.table-responsive -->
		</div>
		<!-- /.portlet-body -->
		<!-- /.portlet -->
	</div>
</div>



@section script {


	<script>
		$(document).ready(function () {
			$('.clockpicker').clockpicker({
				placement: 'bottom',
				align: 'left',
				donetext: 'تایید'
			});


			kamaDatepicker('FilterDto_FromDate', customOptions);
			kamaDatepicker('FilterDto_ToDate', customOptions);


			$(".page-link").click(function (event) {
				event.preventDefault(); // غیرفعال کردن عملکرد پیشفرض href

				var hrefValue = $(this).attr("href");
				$("#pageNumber").val(hrefValue.split("p=")[1]);
				$("#formFilter").submit();
			});

		});


	</script>
}