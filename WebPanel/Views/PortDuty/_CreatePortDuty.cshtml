@model CreatePortDutyDto

<form asp-action="Create" method="post">
    <input asp-for="Id" type="hidden" />
    <div class="card-body pt-0">
        <div class="row">
            <div class="col-md-12">
                <div class="form-body">
                    <div id="portDutyTypeStep">
                        <div class="row gy-4">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label>نوع ثبت</label>
                                    <div class="input-group">
                                        <select class="form-control select2 generalmodal" asp-for="PortDutyType"
                                                asp-items="Html.GetEnumSelectList<PortDutyType>()">
                                            <option value="">انتخاب کنید</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="PortDutyType" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer border-0 px-0 mt-4">
                            <button type="button" id="portDutyNextBtn" class="btn btn-primary btn-round">بعدی</button>
                            <button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>
                        </div>
                    </div>

                    <div id="portDutyDetailsStep" class="d-none">
                        <div class="row gy-4">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label>نوع عوارض</label>
                                    <div class="input-group">
                                        <select class="form-control select2 generalmodal" asp-for="PortDutyDescriptionType"
                                                asp-items="Html.GetEnumSelectList<PortDutyDescriptionType>()">
                                            <option value="">انتخاب کنید</option>
                                        </select>
                                        <span asp-validation-for="PortDutyDescriptionType" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <div class="form-group">
                                    <label>هدف عوارض</label>
                                    <div class="input-group">
                                        <select class="form-control select2 generalmodal" asp-for="PortDutyTargetType"
                                                asp-items="Html.GetEnumSelectList<PortDutyTargetType>()">
                                            <option value="">انتخاب کنید</option>
                                        </select>
                                        <span asp-validation-for="PortDutyTargetType" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="modal-footer border-0 px-0 mt-4">
                            <button type="submit" class="btn btn-success btn-round">ذخیره</button>
                            <button type="button" id="portDutyPrevBtn" class="btn btn-secondary btn-round">قبلی</button>
                            <button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
