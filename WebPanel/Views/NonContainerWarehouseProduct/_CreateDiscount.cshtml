@using Entities.DTOs.Web
@model CreateNonContainerWarehouseProductDiscountPageDto

<div id="createDiscountModal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" role="dialog">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h4 class="modal-title">ثبت تخفیف</h4>
				<button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body" id="modalBody">
				<form id="CreateDiscountForm" asp-action="CreateDiscount" method="post">
					<input asp-for="CreateDiscount.Id" type="hidden" />
					<div class="card-body pt-0">
						<div class="row">
							<div class="col-md-12">
								<div class="form-body">
									<div class="row gy-4">

										<div class="col-md-12">
											<div class="form-group">
												<label>شرح تخفیف</label>
												<div class="input-group">
													<input type="text" class="form-control rounded" asp-for="CreateDiscount.Title">
													<span asp-validation-for="CreateDiscount.Title" class="text-danger"></span>
												</div>
											</div>
										</div>

										<div class="col-md-12">
											<div class="form-group">
												<label>دوره تخفیف</label>
												<div class="input-group">
													<select class="form-control select2 createDiscountModal" asp-for="CreateDiscount.TariffPeriodId"
															asp-items="@Model.TariffPeriods">
														<option value="">انتخاب کنید</option>
													</select>
													<span asp-validation-for="CreateDiscount.TariffPeriodId" class="text-danger"></span>
												</div>
											</div>
										</div>

										<div class="col-md-6">
											<div class="form-group">
												<label>رویه گمرکی</label>
												<div class="input-group">
													<select class="form-control select2 createDiscountModal" asp-for="CreateDiscount.CustomsProcedure"
															asp-items="Html.GetEnumSelectList<CustomsProcedure>()">
														<option value="">بدون رویه گمرکی</option>
													</select>
													<span asp-validation-for="CreateDiscount.CustomsProcedure" class="text-danger"></span>
												</div>
											</div>
										</div>

										

										<div class="col-sm-3">
											<div class="form-group">
												<label>درصد تخفیف</label>
												<div class="input-group">
													<input type="number" step="0.01" class="form-control" min="0.0" max="100.0"
														   asp-for="CreateDiscount.DiscountPercentage">
													<span asp-validation-for="CreateDiscount.DiscountPercentage"></span>
												</div>
											</div>
										</div>

										<div class="col-sm-3">
											<div class="form-group">
												<label>روز معافیت  </label>
												<div class="input-group">
													<input type="number" class="form-control" min="0" max="1000"
														   asp-for="CreateDiscount.WarehouseExemptionDays">
													<span asp-validation-for="CreateDiscount.WarehouseExemptionDays"></span>
												</div>
											</div>
										</div>

										<div class="col-md-12">
											<div class="form-group">
												<label>موارد استثنا</label>
												<div class="input-group">
													<select class="form-control select2 createDiscountModal" asp-for="CreateDiscount.ExceptionsInt" multiple="multiple"
															asp-items="Html.GetEnumSelectList<GeneralCargoProductType>()">
														<option value="">انتخاب کنید</option>
													</select>
													<span asp-validation-for="CreateDiscount.ExceptionsInt" class="text-danger"></span>
												</div>
											</div>
										</div>

									</div>

									<div class="modal-footer border-0 px-0 mt-4">
										<a onclick="SaveCreateDiscount(event)" class="btn btn-success btn-round">ذخیره</a>
										<button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>
									</div>
								</div>
							</div>
						</div>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>



<script src="~/assets/js/validation/jquery.validate.min.js"></script>
<script src="~/assets/js/validation/jquery.validate.unobtrusive.min.js"></script>

<script>

	$('select[class*="createDiscountModal"].select2').select2({
		dropdownParent: $('#createDiscountModal')
	 });

	 function SaveCreateDiscount(e)
	 {
		 e.preventDefault();

		 let $form = $("#CreateDiscountForm");
		 let formData = $form.serialize();

		 $.post("@Url.Action("CreateDiscount", "NonContainerWarehouseProduct")",
					formData)
					.done(function (res) {
						$("#createDiscountModal").modal('hide');
						$("#DiscountPageModal").modal('hide');
						showDiscountPage();
					})
					.fail(function (xhr, status, error) {
						location.reload();
					});
	 }

</script>