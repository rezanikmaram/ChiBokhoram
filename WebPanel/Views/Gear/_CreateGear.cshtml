@model CreateGearDto

<form id="gearForm" asp-action="SaveGearAjax" method="post" onsubmit="return submitGearForm(event);">
    <input asp-for="Id" type="hidden" id="GearId" />
    <div class="card-body pt-0">
        <div class="row">
            <div class="col-md-12">
                <div class="form-body">
                    <div class="justify-content-between row gy-4">

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>نام تجهیز</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="Name">
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>نام شرکت</label>
                                <div class="input-group">
                                    <select class="form-control rounded select2 generalmodal" asp-for="CompanyId" asp-items="ViewBag.Companies">
                                        <option value="">نامشخص</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>قرارداد</label>
                                <div class="input-group">
                                    <select class="form-control rounded select2 generalmodal" asp-for="ContractId" asp-items="ViewBag.Contracts">
                                        <option value="">بدون قرارداد</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>نوع تجهیز</label>
                                <div class="input-group">
                                    <select class="form-control rounded select2 generalmodal" asp-for="GearTypeId" asp-items="ViewBag.GearTypes"></select>
                                    <span asp-validation-for="GearTypeId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>مدل تجهیز</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="GearModel" placeholder="مدل تجهیز را وارد کنید">
                                    <span asp-validation-for="GearModel" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>وضعیت تجهیز</label>
                                <div class="input-group">
                                    <select class="form-control rounded select2 generalmodal" asp-for="GearStateId" asp-items="ViewBag.GearStates">
                                        <option value="">نامشخص</option>
                                    </select>
                                    <span asp-validation-for="GearStateId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>نوع اجاره تجهیز</label>
                                <div class="input-group">
                                    <select class="form-control rounded select2 generalmodal" asp-for="EquipmentType" asp-items="@Html.GetEnumSelectList<EquipmentType>()"></select>
                                    <span asp-validation-for="EquipmentType" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>نوع مالکیت</label>
                                <div class="input-group">
                                    <select class="form-control rounded select2 generalmodal" asp-for="OwnershipType" asp-items="@Html.GetEnumSelectList<Common.enumeration.Hirman.OwnershipType>()"></select>
                                    <span asp-validation-for="OwnershipType" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>نوع تجهیز</label>
                                <div class="input-group">
                                    <select class="form-control rounded select2 generalmodal" asp-for="GearCategory" asp-items="@Html.GetEnumSelectList<Common.enumeration.GearCategory>()"></select>
                                    <span asp-validation-for="GearCategory" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>سال ساخت تجهیز</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="ProduceYear">
                                    <span asp-validation-for="ProduceYear" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>شماره اموال</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="PropertyNumber">
                                    <span asp-validation-for="PropertyNumber" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>تناژ</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="Tonnage">
                                    <span asp-validation-for="Tonnage" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>کشور سازنده</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="ManufacturerCountry">
                                    <span asp-validation-for="ManufacturerCountry" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>شرکت سازنده</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="ManufacturerCompany">
                                    <span asp-validation-for="ManufacturerCompany" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>طول شاخک</label>
                                <div class="input-group">
                                    <input type="number" step="0.01" class="form-control rounded" asp-for="ForkLength">
                                    <span asp-validation-for="ForkLength" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>ارتفاع باربرداری</label>
                                <div class="input-group">
                                    <input type="number" step="0.01" class="form-control rounded" asp-for="LiftHeight">
                                    <span asp-validation-for="LiftHeight" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>شماره شاسی</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="ChassisNumber">
                                    <span asp-validation-for="ChassisNumber" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>نام گیربکس</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="GearboxName">
                                    <span asp-validation-for="GearboxName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>مدل گیربکس</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="GearboxModel">
                                    <span asp-validation-for="GearboxModel" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>نام موتور</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="EngineName">
                                    <span asp-validation-for="EngineName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>مدل موتور</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="EngineModel">
                                    <span asp-validation-for="EngineModel" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>سریال موتور</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="EngineSerial">
                                    <span asp-validation-for="EngineSerial" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>تعداد لاستیک</label>
                                <div class="input-group">
                                    <input type="number" class="form-control rounded" asp-for="TireCount">
                                    <span asp-validation-for="TireCount" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group">
                                <label>سایز لاستیک</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="TireSize">
                                    <span asp-validation-for="TireSize" class="text-danger"></span>
                                </div>
                            </div>
                        </div>


                        <div class="col-md-3">
                            <div class="form-group">
                                <label>پلاک</label>
                                <div class="input-group">
                                    <input type="text" class="form-control rounded" asp-for="Plaque">
                                    <span asp-validation-for="Plaque" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-3"></div>


                    </div>

                    <div class="modal-footer border-0 px-0">
                        <button type="submit" class="btn btn-success btn-round">ذخیره</button>
                        <button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<script src="~/assets/js/validation/jquery.validate.min.js"></script>
<script src="~/assets/js/validation/jquery.validate.unobtrusive.min.js"></script>
<script>
    $(document).ready(function () {
        $('select[class*="generalmodal"].select2').select2({
            dropdownParent: $('#generalmodal')
        });
    });

    function submitGearForm(event) {
        event.preventDefault();
        
        var form = $("#gearForm");
        
        if (!form.valid()) {
            return false;
        }
        
        var formData = form.serialize();
        
        $.ajax({
            url: "@Url.Action("SaveGearAjax", "Gear")",
            type: "POST",
            data: formData,
            success: function(response) {
                if (response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'موفقیت',
                        text: response.message,
                        confirmButtonText: 'باشه',
                        timer: 2000,
                        timerProgressBar: true
                    }).then(function() {
                        $("#generalmodal").modal('hide');
                        if (typeof refreshGearTable === 'function') {
                            refreshGearTable();
                        }
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'خطا',
                        text: response.message,
                        confirmButtonText: 'باشه'
                    });
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'خطا',
                    text: 'خطایی رخ داد. لطفاً دوباره تلاش کنید',
                    confirmButtonText: 'باشه'
                });
            }
        });
        
        return false;
    }
</script>
