@model ChangePasswordDto
@{
    ViewData["Title"] = "تغییر رمز کاربری";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}


<div class="col-lg-12">
    <div class="card">
        <div class="card-header pb-0">
            <div class="d-flex justify-content-between">
                <h3 class="title">
                   <i class="icon-note"></i> تغییر رمز کاربری
                </h3>
            </div>
        </div>
        <form asp-action="ChangePassword" method="post">
            <div class="card-body pt-0">

                <div class="form-body">
                    <ul class="d-flex col-md-12">
                        <li class="">
                            <div class="form-group m-l-60 ">
                                <label >رمز قدیمی</label>
                                <div class="input-group" style="width: 400px;">
                                    <input style="border-radius: 10px;" type="password" class="form-control" asp-for="OldPass" required>
                                    <span asp-validation-for="OldPass" class="text-danger"></span>
                                </div>
                            </div>
                        </li>
                        
                    </ul>
                    <ul class="d-flex col-md-12">
                        <li class="">
                            <div class="form-group">
                                <label >رمز جدید</label>
                                <div class="input-group" style="width: 400px;">
                                    <input style="border-radius: 10px;" type="password" class="form-control" asp-for="NewPass">
                                    <span asp-validation-for="NewPass" class="text-danger"></span>
                                </div>
                            </div>
                        </li>
                        
                    </ul>
                    <ul class="d-flex col-md-12">
                    <li class="">
                            <div class="form-group m-l-60 ">
                                <label >تکرار رمز جدید</label>
                                <div class="input-group" style="width: 400px;">
                                    <input style="border-radius: 10px;" type="password" class="form-control" asp-for="NewPassRe" required>
                                    <span asp-validation-for="NewPassRe"  class="text-danger"></span>
                                </div>
                            </div>
                        </li>
                     </ul>
                </div>
            </div>
            <div class="form-actions" style="float: left;">
                <button type="submit" class="btn btn-info btn-round">
                    <i class="icon-check"></i>
                    ذخیره
                    <div class="paper-ripple"><div class="paper-ripple__background"></div><div class="paper-ripple__waves"></div></div>
                </button>
            </div>
            <section class="fix"></section>
        </form>


    </div>
</div>