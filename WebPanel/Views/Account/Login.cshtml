@using Microsoft.Extensions.Options;
@inject IOptionsSnapshot<SiteSettings> settings;


@model UserLoginDto
@{
    Layout = null;
    var returnUrl = @Context.Request.Query["returnurl"];
    var appType = settings.Value.OrganizationInfo.Type;

    var styleVersion = 3;
}


<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/login-v2/css/bootstrap.rtl.css">
    <link rel="stylesheet" href="~/login-v2/css/style.css?v=@styleVersion">
    <link rel="stylesheet" href="~/login-v2/font/all.min.css">

    @if (appType == EnumOrganizationInfo.HedayatPGP)
    {
        <title>شرکت خدمات دریایی هدایت کشتی</title>
    }
    else
    {
        <title>ورود به سامانه تخلیه و بارگیری</title>
    }
</head>
<body>

    <div class="container d-flex justify-content-center align-items-center position-relative">
            <div class="bg-white rounded-5 px-5 py-4 text-center main-bg-white z-3 shadow-lg">
                <div class="mb-4 d-flex justify-content-center flex-row-reverse align-items-center">
                    <img src="~/login-v2/assets/FPN.png" alt="" class="img-fluid w-20">
                    <p class="mt-3 text-dark me-3">سامانه تخلیه و بارگیری</p>
                </div>
                <div class="d-flex flex-column justify-content-around align-items-center">
                    <form asp-action="Login" asp-controller="Account" method="post" asp-route-returnurl="@returnUrl">
                        <input type="text" placeholder="  نام کاربری " class="my-2 border p-3" asp-for="UserName">
                        <input type="password" placeholder=" رمز عبور " class="my-2 border p-3" asp-for="Password">
                       
                        <div asp-validation-summary="All" class="text-danger" style="text-align:right;direction:rtl;">
                        </div>
                        <button type="submit" class="main-cta mt-3 "> ورود به سامانه</button>
                    </form>
                </div>
                <div class="mt-5">
                    <a href="#"  type="button" data-bs-toggle="modal" data-bs-target="#exampleModal" class="text-decoration-none "> <i class="fa-regular fa-circle-question mx-2 align-middle"></i>راهنمای ورود</a>
                </div>
            </div>
            <div class="position-absolute top-shelf px-4 pt-1 text-center shadow">
                <div class="h-100 pt-3">
                     <span class="text-white fw-bold mx-2 ">Future Per Networks</span>
                    <!--  <img src="fpnLogo.png" alt="" class="img-fluid w-12 mx-2"> -->
                </div>
            </div>
            <div class="position-absolute bottom-shelf px-4 pt-1 text-center shadow">
                <div>
                    <p class="text-white fw-bold mx-2 mt-4 fs-6"> پروژه آینده ای به ازای شبکه ها   </p>
                </div>
            </div>
        </div>

    <!--modal start-->
        <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title fs-5" id="exampleModalLabel">راهنمای ورود</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="lh-lg">
                            - هرگونه نرم افزار پروکسی یا فی.لترش.کن را خاموش و غیرفعال کنید. <br />

                            - از مرورگر به روز مانند گوگل کروم یا فایرفاکس استفاده نمایید.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    <!--modal end-->

    <script src="~/login-v2/font/all.min.js"></script>
    <script src="~/login-v2/js/bootstrap.bundle.min.js"></script>

    
</body>
</html>
