@model ImasVesselPageDto
@{
    ViewData["Title"] = "لیست شناور ها";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    int i = ((Model.Vessels.PageNumber - 1) * Model.Vessels.PageSize) + 1;
}


<div class="col-lg-12">
    <div class="card">
        <div class="card-header pb-1">
            <div class="d-flex justify-content-between">
                <h3 class="title">
                    <i class="icon-frane"></i> لیست شناور ها
                </h3>
                <div>
                    <a class="alert-icon btn btn-success round" asp-action="UpdateVessel">بروزرسانی</a>
                    <a class="btn px-2 btn-primary rounded"
                       onclick="ShowModalReportList(event)">
                        <i class="fa-solid fa-download align-middle mx-1"></i> دانلود گزارش
                    </a>
                </div>
            </div>
        </div>
        <div class="card-body pt-0">
            <form id="formFilter" asp-action="VesselList" asp-route-p="" method="post">
                <input name="p" id="pageNumber" hidden />
                <div class="form-body">
                    <div class="row gy-4">
                        <div class="form-group col-md-3">
                            <label>بندر</label>
                            <div class="input-group">
                                <select class="form-control select2"
                                        asp-for="Filter.MooringPortId"
                                        asp-items="Model.Ports">
                                    <option value="">همه بنادر </option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group col-md-3">
                            <label>جستجو</label>
                            <div class="input-group">
                                <input type="text" asp-for="Filter.Search" class="form-control" />
                            </div>
                        </div>

                        <div class="form-group col-sm-2">
                            <label>از تاریخ:</label>
                            <div class="input-group">
                                <input asp-for="Filter.DateFrom" type="text" class=" form-control" autocomplete="off">
                                <span asp-validation-for="Filter.DateFrom" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group col-sm-2 ms-2">
                            <label>تا تاریخ:</label>
                            <div class="input-group">
                                <input asp-for="Filter.DateTo" type="text" class=" form-control" autocomplete="off">
                                <span asp-validation-for="Filter.DateTo" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="col-sm-1 d-flex justify-content-center align-content-center flex-wrap">
                            <div class="">
                                <button style="margin-top:30px; border-radius:5px" class="alert-icon btn btn-success " type="submit"><p class="px-3">فیلتر</p></button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>

            <div class="table-responsive mt-4">
                <table class="table table-bordered table-hover table-striped" id="data-table">
                    <thead class="bg-primary">
                        <tr>
                            <th>ردیف</th>
                            <th>شماره دریایی</th>
                            <th>نام شناور</th>
                            <td>آخرین وضعیت</td>
                            <td>تاریخ ورود</td>
                            <td>بندر</td>
                            <td> نوع شناور</td>

                            <th> ظرفیت ناخالص  </th>
                            <th> ظرفیت خالص  </th>
                            <td>آخرین موقعیت</td>
                            <th> پرچم شناور  </th>
                        </tr>
                    </thead>
                    <tbody>


                        @foreach (var item in Model.Vessels.Data)
                        {
                            <tr>
                                <td class="align-middle">@(i++)</td>
                                <td class="align-middle">@item.PmoNumber</td>
                                <td class="align-middle">@item.VesselPersianName</td>
                                <td class="align-middle">@item.VoyageStatePersianName  </td>
                                <td class="align-middle">@item.JalaliEntranceAnchorageDateTimeTitle</td>
                                <td class="align-middle">@item.MooringPortPersianName</td>
                                <td class="align-middle">@item.VesselType</td>

                                <td class="align-middle">@item.GT_title</td>
                                <td class="align-middle">@item.NT_title</td>

                                <td class="align-middle">@item.LastLocationPersianNameTitle</td>
                                <td class="align-middle">@item.VesselFlagCountryPersianName</td>

                            </tr>

                        }



                    </tbody>
                </table>
                <div>
                    <cs-pager cs-paging-pagesize="@Model.Vessels.PageSize"
                              cs-paging-pagenumber="@Model.Vessels.PageNumber"
                              cs-paging-totalitems="@Model.Vessels.TotalItems"
                              cs-paging-maxpageritems="10"
                              cs-pagenumber-param="p"
                              cs-show-first-last="true"
                              cs-suppress-empty-nextprev="true"
                              cs-suppress-inactive-firstlast="true"
                              cs-show-numbered="true"
                              cs-first-page-text="ابتدا"
                              cs-last-page-text="انتها"
                              cs-next-page-title="بعدی"
                              cs-previous-page-title="قبلی"
                              cs-first-page-title="ابتدا"
                              cs-last-page-title="انتها"
                              cs-next-page-text="بعدی"
                              cs-previous-page-text="قبلی"
                              cs-pager-li-current-class="page-item active"
                              cs-pager-li-other-class="page-item"
                              cs-pager-li-non-active-class="page-item disabled"
                              cs-pager-link-current-class="page-link"
                              cs-pager-link-other-class="page-link"
                              asp-controller="Imas"
                              asp-action="VesselList">
                    </cs-pager>
                </div>

            </div>
            <!-- /.table-responsive -->
        </div>
        <!-- /.portlet -->
    </div>
</div>


<div id="ReportListModal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">

                <h4 class="modal-title">گزارش لیست شناور ها</h4>
                <button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalbody">

                <div class="card-body pt-0">

                    <div class="form-body">

                        <div class="row">
                            <div class="col-sm-12">
                                <div class="form-group">
                                    <label>نوع گزارش</label>
                                    <div class="input-group">
                                        <select class="form-control"
                                                id="listVesselReportType"
                                                name="reportType"
                                                asp-items="Html.GetEnumSelectList<ReportType>()">
                                        </select>
                                    </div>
                                </div>
                            </div>



                        </div>


                        <div class="modal-footer px-0 pb-0 border-0">
                            <button type="button" class="btn btn-success btn-round" onclick="GetReportList(event)"> دریافت گزارش </button>
                            <button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>

                            <button id="excel1" type="submit" form="formFilter" formaction="/Imas/GetReportList?reportType=1"
                                    class="btn w-100 mx-0 d-none my-2 px-2 btn-outline-primary-2x rounded-0">
                                گزارش  اکسل
                            </button>
                            <button id="pdf1" type="submit" form="formFilter" formaction="/Imas/GetReportList?reportType=0"
                                    class="btn d-none w-100 mx-0 my-2 px-2 btn-outline-primary-2x rounded-0">
                                گزارش  Pdf
                            </button>
                        </div>

                    </div>
                </div>


            </div>
        </div>
    </div>
</div>



@section script {
    <script>
         $(document).ready(function () {
              $(".select2").select2();
          });

          function GetReportList(event) {
            $("#ReportListModal").modal('hide');
            let selectValue = document.getElementById("listVesselReportType").value;

            if(selectValue == 0)
                $("#pdf1").click();
            else if(selectValue == 1)
                $("#excel1").click();
        }

         function ShowModalReportList(event) {
            event.preventDefault();

            $("#ReportListModal").modal('show');
        }


        kamaDatepicker('Filter_DateFrom', customOptions);
        kamaDatepicker('Filter_DateTo', customOptions);

        $(".page-link").click(function (event) {
               event.preventDefault(); // غیرفعال کردن عملکرد پیشفرض href

               var hrefValue = $(this).attr("href");
               $("#pageNumber").val(hrefValue.split("=")[1]);
               $("#formFilter").submit();
           });
    </script>
}