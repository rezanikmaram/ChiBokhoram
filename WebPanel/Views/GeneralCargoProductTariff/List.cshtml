@model GeneralCargoProductTariffPageDto

@{
    ViewData["Title"] = "تعرفه کالای غیر کانتینری";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    int i = 1;
}

<div class="col-lg-12">
    <div class="card">
        <div class="card-header pb-0">
            <div class="d-flex justify-content-between mb-3">
                <h3 class="title">
                    <a href="/GeneralCargoProduct/List"> <i class="fa-solid fa-right-to-bracket me-2"></i> </a> تعرفه کالای غیر کانتینری
                </h3>

                <a class="btn btn-success d-md-block d-none" style="border-radius:5px; margin:0px 10px" onclick="showCreateTariffModal()">
                    <i class="icon-plus"></i>
                    ثبت تعرفه جدید
                </a>
            </div>
            <div>
                <h4>اطلاعات کالا:</h4>
                <ul class="list-unstyled d-flex my-3">
                    <li class="bg-primary mx-1 p-2 rounded-3"><strong>عنوان:</strong> @Model.GeneralCargoProduct.Title</li>
                    <li class="bg-primary mx-1 p-2 rounded-3"><strong>نوع کالا:</strong> @Model.GeneralCargoProduct.GeneralCargoProductType.ToDisplay()</li>
                </ul>
            </div>
        </div>

        <div class="card-body pt-0">
            <div class="table-responsive vh-100">
                <table class="table table-bordered table-hover table-striped">
                    <thead class="bg-primary text-white">
                    <tr>
                        <th>ردیف</th>
                        <th>مبلغ</th>
                        <th>ارز</th>
                        <th>روش محاسبه</th>
                        <th>دوره تعرفه</th>
                        <th>از تاریخ</th>
                        <th>تا تاریخ</th>
                        <th>عملیات</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td>@(i++)</td>
                            <td>@item.Price.ToPrice()</td>
                            <td>@item.CurrencyTypeTitle</td>
                            <td>@item.TariffCalculationTypeTitle</td>
                            <td>@(string.IsNullOrWhiteSpace(item.ContractPeriodTitle) ? "-" : item.ContractPeriodTitle)</td>
                            <td>@item.StartDateFa</td>
                            <td>@item.EndDateFa</td>
                            <td>
                                <a class="btn btn-warning px-2 btn-sm btn-icon curve" onclick="editTariff('@item.Id');"><i class="icon-pencil align-middle fs-7"></i></a>

                                <a id="DeleteTariff@(i)" onclick="ShowQAlert(event,'DeleteTariff@(i)');"
                                   asp-action="DeleteTariff" asp-route-generalCargoProductTariffId="@item.Id"
                                   class="btn btn-danger btn-sm btn-icon px-2 ms-1">
                                    <i class="icon-trash fs-6 align-middle fa-flip-horizontal"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


<!-- Modal -->
<div id="tariffModal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered ">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">تعرفه جدید</h4>
                <button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody">
                <partial name="_CreateGeneralCargoProductTariff" model="@Model.Create" />
            </div>
        </div>
    </div>
</div>

@section script {
    <script>
        $(document).ready(function () {
            $(".page-link").click(function (event) {
                event.preventDefault();
                var hrefValue = $(this).attr("href");
                $("#pageNumber").val(hrefValue.split("p=")[1]);
                $("#formFilter").submit();
            });
        });

        function showCreateTariffModal() {
             $("#Id").val('');
            $("#tariffModal").modal('show');
        }

         function editTariff(id) {
            $.post("@Url.Action("GetTariffById", "GeneralCargoProductTariff")", { tariffId: id })
                .done(function (res) {
                    $("#modalBody").html(res);
                    $("#tariffModal").modal('show');
                });
        }
    </script>
}
