@model Entities.DTOs.Web.Hirman.SimcardPageDto
@{
    int i = ((Model.Simcards.PageNumber - 1) * Model.Simcards.PageSize) + 1;
    var currentSortColumn = Model.Filter?.SortColumn ?? "phonenumber";
    var currentSortDirection = Model.Filter?.SortDirection ?? "asc";
}

<div class="table-responsive mt-4">
    <table class="table table-sm table-bordered table-hover table-striped" id="data-table">
        <thead class="bg-primary">
            <tr>
                <th class="sortable-header" data-column="row">ردیف</th>
                <th class="sortable-header" data-column="phonenumber" style="cursor: pointer;">
                    شماره
                    @if (currentSortColumn == "phonenumber")
                    {
                        <i class="icon-arrow-@(currentSortDirection == "asc" ? "up" : "down") text-white"></i>
                    }
                    else
                    {
                        <i class="icon-sort text-white-50"></i>
                    }
                </th>
                <th class="sortable-header" data-column="ip" style="cursor: pointer;">
                    IP
                    @if (currentSortColumn == "ip")
                    {
                        <i class="icon-arrow-@(currentSortDirection == "asc" ? "up" : "down") text-white"></i>
                    }
                    else
                    {
                        <i class="icon-sort text-white-50"></i>
                    }
                </th>
                <th class="sortable-header" data-column="price" style="cursor: pointer;">
                    موجودی
                    @if (currentSortColumn == "price")
                    {
                        <i class="icon-arrow-@(currentSortDirection == "asc" ? "up" : "down") text-white"></i>
                    }
                    else
                    {
                        <i class="icon-sort text-white-50"></i>
                    }
                </th>
                <th class="sortable-header" data-column="serial" style="cursor: pointer;">
                    سریال
                    @if (currentSortColumn == "serial")
                    {
                        <i class="icon-arrow-@(currentSortDirection == "asc" ? "up" : "down") text-white"></i>
                    }
                    else
                    {
                        <i class="icon-sort text-white-50"></i>
                    }
                </th>
                <th class="sortable-header" data-column="description" style="cursor: pointer;">
                    توضیحات
                    @if (currentSortColumn == "description")
                    {
                        <i class="icon-arrow-@(currentSortDirection == "asc" ? "up" : "down") text-white"></i>
                    }
                    else
                    {
                        <i class="icon-sort text-white-50"></i>
                    }
                </th>
                <th>دستگاه</th>
                <th class="sortable-header" data-column="isactive" style="cursor: pointer;">
                    وضعیت
                    @if (currentSortColumn == "isactive")
                    {
                        <i class="icon-arrow-@(currentSortDirection == "asc" ? "up" : "down") text-white"></i>
                    }
                    else
                    {
                        <i class="icon-sort text-white-50"></i>
                    }
                </th>
                <th>عملیات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Simcards.Data)
            {
                <tr>
                    <td class="align-middle">@(i++)</td>
                    <td class="align-middle">@item.PhoneNumber</td>
                    <td class="align-middle">@item.Ip</td>
                    <td class="align-middle">@item.Price</td>
                    <td class="align-middle">@item.Serial</td>
                    <td class="align-middle">@item.Description</td>
                    <td class="align-middle">@item.DeviceName</td>
                    <td class="align-middle">
                        <a class="btn-activation-simcard" data-id="@item.Id" style="cursor:pointer">
                            <span class="label px-2 py-1 rounded label-@(item.IsActive ? "success" : "danger")">
                                @(item.IsActive ? "فعال" : "غیر فعال")
                            </span>
                        </a>
                    </td>
                    <td class="align-middle px-2 text-center">
                        <a class="btn btn-warning px-2 btn-sm btn-icon curve" onclick="editSimcard('@item.Id');"><i class="icon-pencil align-middle fs-6"></i></a>
                        <button type="button" class="btn btn-danger px-2 btn-sm btn-icon curve btn-delete-simcard" data-id="@item.Id" data-number="@item.PhoneNumber">
                            <i class="icon-trash fs-6 align-middle fa-flip-horizontal"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="mt-3">
        <cs-pager cs-paging-pagesize="@Model.Simcards.PageSize"
                  cs-paging-pagenumber="@Model.Simcards.PageNumber"
                  cs-paging-totalitems="@Model.Simcards.TotalItems"
                  cs-paging-maxpageritems="10"
                  cs-pagenumber-param="p"
                  cs-show-first-last="true"
                  cs-suppress-empty-nextprev="true"
                  cs-suppress-inactive-firstlast="true"
                  cs-show-numbered="true"
                  cs-first-page-text="ابتدا"
                  cs-last-page-text="انتها"
                  cs-next-page-title="بعدی"
                  cs-previous-page-title="قبلی"
                  cs-first-page-title="ابتدا"
                  cs-last-page-title="انتها"
                  cs-next-page-text="بعدی"
                  cs-previous-page-text="قبلی"
                  cs-pager-li-current-class="page-item active"
                  cs-pager-li-other-class="page-item"
                  cs-pager-li-non-active-class="page-item disabled"
                  cs-pager-link-current-class="page-link"
                  cs-pager-link-other-class="page-link"
                  asp-controller="Simcard"
                  asp-action="Table">
        </cs-pager>
    </div>
</div>

<script>
    $(document).off('click', '.sortable-header').on('click', '.sortable-header', function(e) {
        var column = $(this).data('column');
        if (!column || column === 'row') return;
        
        var currentSortColumn = '@currentSortColumn';
        var currentSortDirection = '@currentSortDirection';
        
        var newDirection = 'asc';
        if (column === currentSortColumn) {
            newDirection = currentSortDirection === 'asc' ? 'desc' : 'asc';
        }
        
        if (typeof loadTableWithSort === 'function') {
            loadTableWithSort(column, newDirection);
        }
    });
</script>
