@model ContractPageDto
@{
    ViewData["Title"] = "لیست قراردادها";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    var i = ((Model.Contracts.PageNumber - 1) * Model.Contracts.PageSize) + 1;
}

<div class="col-lg-12">
    <div class="card">
        <div class="card-header pb-2">
            <div class="d-flex justify-content-between">
                <h3 class="title">
                    <i class="fa-solid fa-receipt align-middle"></i> لیست قراردادها
                </h3>
                <div>
                    <a class="alert-icon btn btn-primary round" asp-action="CreateContract"><i class="fa-solid fa-plus me-2"></i>قرارداد جدید  </a>
                    <div class="buttons-box">
                        <i class="icon-size-fullscreen"></i>
                        <div class="paper-ripple">
                            <div class="paper-ripple__background"></div>
                            <div class="paper-ripple__waves"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body pt-0">

            <form id="formFilter" asp-action="Index" asp-route-p="" method="post">
                <input name="p" id="pageNumber" hidden />
                <div class="form-body ">
                    <div class="row col-md-12">
                        <div class="form-group col-md-4">
                            <label>جستجو</label>
                            <div class="input-group">
                                <input type="text" asp-for="Filter.Search" class="form-control" />
                            </div>
                        </div>
                        <div class="form-group col-md-4">
                            <label>شرکت</label>
                            <div class="input-group">
                                <select class="form-control select2" asp-for="Filter.CompanyId" asp-items="ViewBag.Company">
                                    <option value="">همه شرکت ها</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-group col-md-2 d-flex justify-content-center flex-wrap align-content-center">
                            <button style="border-radius:5px; margin-top:30px" class="alert-icon btn btn-success" type="submit">
                                <p class="px-3"> فیلتر</p>
                            </button>
                        </div>
                    </div>
                </div>
            </form>

            <div class="table-responsive mb-4 pb-5 mt-4">
                <table class="table table-bordered table-hover table-striped" id="data-table">
                    <thead class="bg-primary">
                        <tr>
                            <th>ردیف</th>
                            <th>شماره قرارداد</th>
                            <th>شرکت</th>
                            <th>تاریخ شروع</th>
                            <th>تاریخ پایان</th>
                            <th>حجم نهایی</th>
                            <th>وزن نهایی</th>
                            <th>تعداد سفر نهایی</th>
                            <th>تعداد کانتینر نهایی</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Contracts.Data)
                        {
                            <tr>
                                <td class="align-middle">@(i++)</td>
                                <td class="align-middle">@item.ContractNumber</td>
                                <td class="align-middle">@item.CompanyName</td>
                                <td class="align-middle">@(item.ContractStartDate.HasValue ? item.ContractStartDate.Value.ToPersianDate2() : "")</td>
                                <td class="align-middle">@(item.ContractEndDate.HasValue ? item.ContractEndDate.Value.ToPersianDate2() : "")</td>
                                <td class="align-middle">@string.Format("{0:#,0}", item.FinallVolume)</td>
                                <td class="align-middle">@string.Format("{0:#,0}", item.FinallWeight)</td>
                                <td class="align-middle">@item.FinallVoyage</td>
                                <td class="align-middle">@item.FinallContainer</td>
                                <td class="d-flex justify-content-first px-1">
                                    <div class="d-flex flex-wrap gap-1">
                                        <a class="btn btn-secondary btn-sm mx-1 px-2" asp-action="GetAssignedGears" asp-route-contractId="@item.Id" title="تخصیص تجهیزات"> <i class="fa-solid fa-screwdriver-wrench fs-6 align-middle"></i> </a>
                                        <a class="btn btn-info text-white btn-sm mx-1 px-2" asp-action="GetAssignedPersons" asp-route-contractId="@item.Id" title="تخصیص کاربران"> <i class="fa-solid fa-user-plus fs-6 align-middle"></i> </a>
                                        <a class="btn btn-success btn-sm mx-1 px-2" asp-action="GetPortalUsers" asp-route-contractId="@item.Id" title="کاربران پورتال"> <i class="fa fa-user fs-6 align-middle"></i> </a>
                                        <a class="btn btn-primary btn-sm mx-1 px-2" asp-action="Options" asp-route-contractId="@item.Id" title="تنظیمات قرارداد"> <i class="fa-solid fa-gear fs-6 align-middle"></i> </a>
                                        <a class="btn btn-warning btn-sm btn-icon curve mx-1 px-2" asp-action="CreateContract" asp-route-contractId="@item.Id" title="ویرایش"><i class="icon-pencil align-middle fs-6 align-middle"></i></a>
                                        <a class="btn btn-danger btn-sm btn-icon curve btn-questions mx-1 px-2" id="DeleteContract@(i)" onclick="ShowQAlert(event,'DeleteContract@(i)');" asp-action="DeleteContract" asp-route-contractId="@item.Id" title="حذف"><i class="icon-trash fa-flip-horizontal fs-6 align-middle"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="mt-3">
                    <cs-pager cs-paging-pagesize="@Model.Contracts.PageSize"
                              cs-paging-pagenumber="@Model.Contracts.PageNumber"
                              cs-paging-totalitems="@Model.Contracts.TotalItems"
                              cs-paging-maxpageritems="10"
                              cs-pagenumber-param="p"
                              cs-show-first-last="true"
                              cs-suppress-empty-nextprev="true"
                              cs-suppress-inactive-firstlast="true"
                              cs-show-numbered="true"
                              cs-first-page-text="ابتدا"
                              cs-last-page-text="انتها"
                              cs-next-page-title="بعدی"
                              cs-previous-page-title="قبلی"
                              cs-first-page-title="ابتدا"
                              cs-last-page-title="انتها"
                              cs-next-page-text="بعدی"
                              cs-previous-page-text="قبلی"
                              cs-pager-li-current-class="page-item active"
                              cs-pager-li-other-class="page-item"
                              cs-pager-li-non-active-class="page-item disabled"
                              cs-pager-link-current-class="page-link"
                              cs-pager-link-other-class="page-link"
                              asp-controller="Contract"
                              asp-action="Index">
                    </cs-pager>
                </div>
            </div>
        </div>
    </div>
</div>

@section script {
    <script>
        $(document).ready(function () {
            $(".select2").select2();
        });
        $(".page-link").click(function (event) {
            event.preventDefault();
            var hrefValue = $(this).attr("href");
            var pageParam = new URL(hrefValue, window.location.origin).searchParams.get('p') || "1";
            $("#pageNumber").val(pageParam);
            $("#formFilter").submit();
        });
    </script>
}
