@model GetAssignedContractPersonsDto
@{
    ViewData["Title"] = $"کاربران قرارداد ({Model.ContractNumber})";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="card-header bg-white border-0 p-3">
    <div class="d-flex justify-content-between">
        <h3 class="title m-0">
            <a asp-action="Index">
                <i class="fa-solid fa-right-to-bracket align-middle me-2"></i>
            </a>
            کاربران قرارداد (@Model.ContractNumber)
        </h3>
        <div class="buttons-box">
            <i class="icon-size-fullscreen"></i>
            <div class="paper-ripple">
                <div class="paper-ripple__background"></div>
                <div class="paper-ripple__waves"></div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-6">
        <div class="card rounded-3 min-height-600">
            <div class="card-header">
                <div class="d-flex justify-content-between">
                    <h3 class="title m-0">
                        <i class="icon-user"></i>
                        انتخاب کاربران برای قرارداد
                    </h3>
                    <form asp-action="AssignPersonsToContract" method="post" id="assignPersonsForm">
                        <a class="btn mb-2 float-end btn-success rounded text-white label" onclick="assignPersons();">+ اضافه کردن انتخاب شده ها</a>
                        <input id="assignIds" name="Ids" type="hidden" />
                        <input name="ContractId" type="hidden" value="@Model.ContractId" />
                    </form>
                </div>
            </div>
            <div class="card-body pt-0">
                <form asp-action="GetAssignedPersons" method="post" id="filterFormLeft">
                    <input type="hidden" asp-for="ContractId" />
                    <div class="form-body mb-4">
                        <div class="row">
                            <div class="form-group col-lg-6">
                                <label>جستجو</label>
                                <div class="input-group">
                                    <input asp-for="Filter.Search" type="text" class="form-control" placeholder="نام/نام‌خانوادگی/تلفن/شرکت">
                                </div>
                            </div>
                            <div class="col-lg-3 d-flex align-items-end">
                                <button class="btn btn-success rounded label w-100" type="submit"><p class="m-0">فیلتر</p></button>
                            </div>
                        </div>
                    </div>
                </form>

                <div class="table-responsive w-100">
                    <table class="table table-bordered">
                        <thead class="bg-primary">
                            <tr>
                                <th style="width:30px"></th>
                                <th>نام و نام خانوادگی</th>
                                <th>تلفن</th>
                                <th>شرکت</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.UnAssignedPersons)
                        {
                            <tr>
                                <td><input type="checkbox" value="@item.Id" name="unassignedPersonId" /></td>
                                <td>@item.FullName</td>
                                <td>@item.Phone</td>
                                <td>@item.CompanyName</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card rounded-3">
            <div class="card-header d-flex justify-content-between">
                <h3 class="title m-0">
                    <i class="icon-speech"></i>
                    کاربران متصل به قرارداد
                </h3>
                <form asp-action="RemovePersonsFromContract" method="post" id="removePersonsForm">
                    <a class="btn btn-danger text-white label rounded" onclick="removePersons();">- حذف انتخاب شده ها</a>
                    <input id="removeIds" name="Ids" type="hidden" />
                    <input name="ContractId" type="hidden" value="@Model.ContractId" />
                </form>
            </div>
            <div class="card-body pt-0">
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead class="bg-primary">
                            <tr>
                                <th style="width:30px"></th>
                                <th>نام و نام خانوادگی</th>
                                <th>تلفن</th>
                                <th>شرکت</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.AssignedPersons)
                        {
                            <tr>
                                <td><input type="checkbox" value="@item.Id" name="assignedPersonId" /></td>
                                <td>@item.FullName</td>
                                <td>@item.Phone</td>
                                <td>@item.CompanyName</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section script {
<script>
    function assignPersons() {
        var ids = "";
        $("#assignIds").val('');
        $("input:checkbox[name=unassignedPersonId]:checked").each(function () {
            ids = ids ? (ids + ',' + $(this).val()) : $(this).val();
        });
        if (ids) {
            $("#assignIds").val(ids);
            $("#assignPersonsForm").submit();
        } else {
            showAlert2('کاربری انتخاب نشده است', 1);
        }
    }
    function removePersons() {
        var ids = "";
        $("#removeIds").val('');
        $("input:checkbox[name=assignedPersonId]:checked").each(function () {
            ids = ids ? (ids + ',' + $(this).val()) : $(this).val();
        });
        if (ids) {
            $("#removeIds").val(ids);
            $("#removePersonsForm").submit();
        } else {
            showAlert2('کاربری انتخاب نشده است', 1);
        }
    }
</script>
}
