<script>
    
    $(document).on("click", ".btnAddProduct", function () {

        const targetSelect = $(this).data("target-select");

        $.post("/Product/GetAddProductPage", function (res) {

            $("#addProductModalContainer").html(res);

            let modal = $("#addProductModal");

            // ⭐ ذخیره selector داخل مودال
            modal.data("target-select", targetSelect);

            modal.modal("show");

            modal.find('.select2').select2({
                dropdownParent: modal
            });
        });
    });

    function addProductToMainSelect(productId) {

        const modal = $("#addProductModal");
        const targetSelect = modal.data("target-select");

        if (!targetSelect) return;

        $.get('/Product/GetProductAndCategoryNameById', { productId: productId }, function (product) {

            const select = $(targetSelect);

            // ساخت option جدید + انتخاب آن
            const newOption = new Option(
                product.text,
                product.id,
                true,   // defaultSelected
                true    // selected
            );

            select.append(newOption).val(product.id).trigger('change');
        });
    }
     
</script>
