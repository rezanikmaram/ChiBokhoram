@model ProductHSCodePageDto
@{
	ViewData["Title"] = "HS Codes";
	Layout = "~/Views/Shared/AdminLayout.cshtml";
	int i = ((Model.List.PageNumber - 1) * Model.List.PageSize) + 1;
}


<div class="col-lg-12">
	<div class="card">
		<div class="card-header pb-2">
			<div class="d-flex justify-content-between">
				<h3 class="title">
					<i class="icon-frane"></i> کالاها HS Code
				</h3>
				<div>
					<a class="btn btn-primary rounded" onclick="createHsCode();"><i class="fa-solid fa-plus me-2"></i>HS code جدید</a>
				</div>
				<!-- /.buttons-box -->
			</div>
			<!-- /.portlet-heading -->


		</div>
		<div class="card-body pt-0">

			<form id="formFilter" asp-action="HSCode" asp-route-p="" method="post">
				<input name="p" id="pageNumber" hidden />
				<div class="form-body ">

					<div class="row gy-4">

						<div class="col-md-3 col-sm-12">
							<div class="form-group">
								<label>  جستجو:</label>
								<div class="input-group">
									<input asp-for="Filter.Search" type="text" class="rounded form-control">
									<span asp-validation-for="Filter.Search" class="text-danger"></span>
								</div>
							</div>
						</div>

						<div class="form-group col-md-2 ">
							<button style="border-radius:5px; margin-top:30px" class="alert-icon px-3 btn btn-success "
									type="submit">
								فیلتر
							</button>
						</div>

					</div>



				</div>
			</form>

			<div class="table-responsive mt-4">
				<table class="table table-sm table-bordered table-hover table-striped" id="data-table">
					<thead class="bg-primary">
						<tr>
							<th>ردیف</th>
							<th>HS Code</th>
							<th>نام   </th>
							<th>Name</th>
							<th>خلاصه</th>


							<th>عملیات</th>
						</tr>
					</thead>
					<tbody>


						@foreach (var item in Model.List.Data)
						{
							<tr>
								<td class="align-middle">@(i++)</td>
								<td class="align-middle"> @item.Number </td>
								<td class="align-middle">@item.NameFa</td>
								<td class="align-middle">@item.NameEn  </td>
								<td class="align-middle">@item.Title  </td>

								<td class="align-middle px-2 text-center">
									<a class="btn btn-warning px-2 btn-sm btn-icon curve" onclick="editHscode('@item.Id');"><i class="icon-pencil align-middle fs-6"></i></a>
									<a id="DeleteHscode@(i)" onclick="ShowQAlert(event,'DeleteHscode@(i)');" class="btn btn-danger px-2 btn-sm btn-icon curve btn-questions"
									   asp-action="DeleteHscode" asp-route-HscodeId="@item.Id">
										<i class="icon-trash fs-6 align-middle fa-flip-horizontal"></i>
									</a>
								</td>
							</tr>
						}

					</tbody>
				</table>

				<div>
					<cs-pager cs-paging-pagesize="@Model.List.PageSize"
							  cs-paging-pagenumber="@Model.List.PageNumber"
							  cs-paging-totalitems="@Model.List.TotalItems"
							  cs-paging-maxpageritems="10"
							  cs-pagenumber-param="p"
							  cs-show-first-last="true"
							  cs-suppress-empty-nextprev="true"
							  cs-suppress-inactive-firstlast="true"
							  cs-show-numbered="true"
							  cs-first-page-text="ابتدا"
							  cs-last-page-text="انتها"
							  cs-next-page-title="بعدی"
							  cs-previous-page-title="قبلی"
							  cs-first-page-title="ابتدا"
							  cs-last-page-title="انتها"
							  cs-next-page-text="بعدی"
							  cs-previous-page-text="قبلی"
							  cs-pager-li-current-class="page-item active"
							  cs-pager-li-other-class="page-item"
							  cs-pager-li-non-active-class="page-item disabled"
							  cs-pager-link-current-class="page-link"
							  cs-pager-link-other-class="page-link"
							  asp-controller="Product"
							  asp-action="HSCode">
					</cs-pager>
				</div>

			</div>

		</div>

	</div>
</div>


<div id="generalmodal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
	<div class="modal-dialog modal-lg modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h4 class="modal-title">ثبت کالا</h4>
				<button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body" id="modalbody">


				<form asp-action="CreateHSCode" method="post">
					<input asp-for="CreateDto.Id" type="hidden" />

					<div class="card-body pt-0">
						<div class="col-md-12">
							<div class="form-body">

								<div class="row gy-4">

									<div class="col-md-2">
										<div class="form-group  ">
											<label> HS Code  </label>
											<div class="input-group">
												<input type="text" asp-for="CreateDto.Number" class="form-control" required>
											</div>
											<span asp-validation-for="CreateDto.Number" class="text-danger"></span>
										</div>
									</div>

									<div class="col-md-10">
										<div class="form-group  ">
											<label> خلاصه نام کالا  </label>
											<div class="input-group">
												<input type="text" asp-for="CreateDto.Title" class="form-control" >
											</div>
											<span asp-validation-for="CreateDto.Title" class="text-danger"></span>
										</div>
									</div>

									<div class="col-md-6">
										<div class="form-group  ">
											<label> نام کالا فارسی  </label>
											<div class="input-group">
												<input type="text" asp-for="CreateDto.NameFa" class="form-control">
											</div>
											<span asp-validation-for="CreateDto.NameFa" class="text-danger"></span>
										</div>
									</div>
									<div class="col-md-6">
										<div class="form-group  ">
											<label> نام کالا انگلیسی  </label>
											<div class="input-group">
												<input type="text" asp-for="CreateDto.NameEn" class="form-control" >
											</div>
											<span asp-validation-for="CreateDto.NameEn" class="text-danger"></span>
										</div>
									</div>

								</div>


								<div class="modal-footer px-2 border-0 px-0">
									<button type="submit" class="btn btn-success btn-round">ذخیره</button>
									<button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>
								</div>
							</div>



						</div>
					</div>

				</form>


			</div>
		</div>
	</div>
</div>


@section script {
	 
	<script>
		$(document).ready(function () {
			//$('.select2').select2();
			  
		});
		 
		function createHsCode() {
			$("#CreateDto_Id").val('');
			$("#CreateDto_Number").val('');
			$("#CreateDto_Title").val('');
			$("#CreateDto_NameFa").val('');
			$("#CreateDto_NameEn").val('');
		  
			$("#generalmodal").modal('show');

		}

		function editHscode(id) {

			$.post("@Url.Action("GetHSCodeById", "Product")", { hsCodeId: id })
				.done(function (res) {
					//$("#modalbody").html(res);
					$("#CreateDto_Id").val(res.id);
					$('#CreateDto_Number').val(res.number);
				  
					$("#CreateDto_Title").val(res.title);
					$("#CreateDto_NameFa").val(res.nameFa);
					$("#CreateDto_NameEn").val(res.nameEn);

					$("#generalmodal").modal('show');
				})
				.fail(function (xhr, status, error) {
					location.reload();
				});
		}


		$(".page-link").click(function (event) {
			event.preventDefault(); // غیرفعال کردن عملکرد پیشفرض href

			var hrefValue = $(this).attr("href");
			$("#pageNumber").val(hrefValue.split("p=")[1]);
			$("#formFilter").submit();
		});

	</script>
}

