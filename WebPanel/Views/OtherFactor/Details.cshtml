@model OtherFactorDetailsPageDto
@{
	ViewData["Title"] = "جزئیات درآمد";
	Layout = "~/Views/Shared/AdminLayout.cshtml";
}
<div class="row">
	<div class="card">
		<div class="card-header pb-0 px-3">
			<div class="d-flex justify-content-between align-items-center">
				<h3 class="title">
					<i class="icon-frane"></i>
					<a asp-action="list" ><i class="fa-solid fa-right-to-bracket me-2"></i></a>
					جزئیات درآمد
				</h3>
				<div class="d-flex align-items-center">
					<a onclick="ShowModalSetInfo()" class=" btn btn-info me-2 ">تکمیل مشخصات</a>
					<a id="DeleteFactor" onclick="ShowQAlert(event,'DeleteFactor', 'حذف فاکتور' , 'آیا از حذف این فاکتور مطمئن هستید');"
					   asp-controller="OtherFactor" asp-action="DeleteFactor"
					   asp-route-factorId="@Model.SeoFactor.Id"  
					   class=" btn btn-danger">
						<i class="icon-trash fa-flip-horizontal"></i> حذف
					</a>

				</div>
			</div>
			<div class="row">
			</div>
		</div>
		<div class="card-body pt-0 px-2">
			<div class="bg-primary rounded-3 mt-4 p-3">
				<div class="row gy-3 align-items-center">
					<div class="col-1">
						<img src="~/assets/images/rial.png" alt="" class="img-fluid">
					</div>
					 
					<div class="col-3">
						<p class="fs-6 fw-bold">شماره فاکتور : @(Model.SeoFactor.NumberFactor ?? "---") </p>
						<p class="fs-6 fw-bold">تاریخ : @Model.SeoFactor.DateFa</p>
					</div>
					<div class="col-3">
						<p class="fs-6 fw-bold">طرف حساب: @Model.SeoFactor.InvoiceRecipientCompanyName</p>
						<p class="fs-6 fw-bold">وضعیت: @Model.SeoFactor.State.ToDisplay()</p>
					</div>
					 
					 
					@* white devider start *@
					<div class="col-12 border-top border-white"></div>
					@* white divider end *@


					@* @if (User.IsInRole("admin") || User.IsInRole("adminOnePort")) *@

					<div class="col-3">

						<a class="btn btn-light w-100 py-3 fs-5" asp-action="DocFiles"
						   asp-route-factorId="@Model.SeoFactor.Id">
							<p><i class="fa-solid fa-anchor fs-3  mb-2"></i></p>
							مدیریت اسناد مرتبط
						</a>

					</div>

					<div class="col-3">
						<a class="btn btn-light w-100 py-3 fs-5" asp-action="Factor"
						   asp-route-factorId="@Model.SeoFactor.Id">
							<p><i class="fa-solid fa-anchor fs-3  mb-2"></i></p>
							صورتحساب
						</a>
					</div>

				</div>
			</div>
		</div>
	</div>
</div>

<div id="modalSetInfo">
</div>

@section script {


	<script>

		$(document).ready(function () {

		});

				function ShowModalSetInfo()
		{
			let seoFactorId = '@Model.SeoFactor.Id';

			$.post("@Url.Action("GetSeoFactorInfo", "SeoFactor")",
				{
					factorId :seoFactorId
				})
				.done(function (res) {
					$("#modalSetInfo").html(res);
					$("#generalmodal").modal('show');
				})
				.fail(function (xhr, status, error) {
					location.reload();
				});
		}

		function SaveInfo(e) {
			e.preventDefault();

			let $form = $("#formSetInfo");
			let formData = $form.serialize();

			$.post("@Url.Action("SetInfoSeoFactor", "SeoFactor")", formData)
				.done(function (res) {
					$("#generalmodal").modal('hide');
					showAlert("با موفقیت ذخیره شد", 0);
				})
				.fail(function () {
					location.reload();
				});
		}
	</script>
}

