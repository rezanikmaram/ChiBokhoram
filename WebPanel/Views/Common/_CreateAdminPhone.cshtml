@model CreateSeoReciveInfoDto

<form asp-action="AdminPhone" method="post">
    <input asp-for="Id" type="hidden" />



    <div class="card-body pt-0">
        <div class="col-md-12">
            <div class="form-body">

                <div class="row mt-3">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>نام و نام خانوادگی</label>
                            <div class="input-group">
                                <input type="text" class="form-control rounded" asp-for="FullName" required>
                                <span asp-validation-for="FullName"></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>شماره تلفن</label>
                            <div class="input-group">
                                <input type="tel" class="form-control rounded" asp-for="Phone">
                                <span asp-validation-for="Phone"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-12 d-flex">
                    <div class="mt-4">
                        <div class="input-group activeor">
                            <label>
                                <input type="checkbox" asp-for="IsActive" class="normal">
                                فعال/غیرفعال
                            </label>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 px-0">
                    <button type="submit" class="btn btn-success btn-round">ذخیره</button>
                    <button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>
                </div>

            </div>
        </div>
    </div>


</form>

  <script src="~/assets/js/validation/jquery.validate.min.js"></script>
 <script src="~/assets/js/validation/jquery.validate.unobtrusive.min.js"></script>