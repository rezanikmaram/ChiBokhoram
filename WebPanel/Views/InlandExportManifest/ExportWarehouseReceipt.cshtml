         var productSwitchConfig = {
            $switch: null,
            $productSelect: null,
            cache: {
                seoProducts: @Html.Raw(Json.Serialize(Model.SeoProducts)),
                allProducts: null,
                loading: false
            },
            urls: {
                seoProducts: '@Url.Action("GetSeoProducts", "Seo")',
                allProducts: '@Url.Action("GetAllProducts", "Seo")'
            },
            selectors: {
                switch: '#ProductSwitch',
                productSelect: '#AddWarehouseReceiptProduct_SeoProductId',
                modal: '#generalmodal'
            }
        };

        // ==================== INITIALIZATION ====================
        $(document).ready(function () {
             initializeProductSwitch();
        });

        // ==================== INITIALIZATION FUNCTION ====================
        async function initializeProductSwitch() {
            // 1. پیدا کردن المنت‌ها
            productSwitchConfig.$switch = $(productSwitchConfig.selectors.switch);
            productSwitchConfig.$productSelect = $(productSwitchConfig.selectors.productSelect);

            // 2. بررسی وجود المنت‌ها
            if (!productSwitchConfig.$switch.length) {
                console.error('سوئیچ با ID ProductSwitch پیدا نشد!');
                return;
            }

            if (!productSwitchConfig.$productSelect.length) {
                console.error('سلکت با ID AddWarehouseReceiptProduct_SeoProductId پیدا نشد!');
                return;
            }

            // 3. تنظیم event listener برای سوئیچ
            productSwitchConfig.$switch.on('change', async function() {
                var isSeoProductsOnly = $(this).is(':checked');
                //console.log('سوئیچ تغییر کرد به:', isSeoProductsOnly);
                await handleProductSwitchChange(isSeoProductsOnly);
            });

            // 4. مقداردهی اولیه
            var initialState = productSwitchConfig.$switch.is(':checked');
            //console.log('وضعیت اولیه سوئیچ:', initialState);

            // 5. بارگذاری اولیه بر اساس وضعیت فعلی
            if (initialState && productSwitchConfig.cache.seoProducts) {
                updateProductSelect(productSwitchConfig.cache.seoProducts);
            }

            // 6. تست دستی - حذف این بعد از تست
            // console.log('سوئیچ مقداردهی شد:', productSwitchConfig.$switch.val());
            // console.log('محصولات کش شده:', productSwitchConfig.cache.seoProducts);
        }

         // ==================== HANDLE SWITCH CHANGE ====================
          async function handleProductSwitchChange(isSeoProductsOnly) {
            showLoading(true);

            try {
                if (isSeoProductsOnly) {
                    await loadSeoProducts();
                } else {
                    await loadAllProducts();
                }
            } catch (error) {
                console.error('خطا در تغییر لیست کالاها:', error);
            } finally {
                showLoading(false);
            }
        }

        // ==================== LOAD SEO PRODUCTS ====================
        async function loadSeoProducts() {
            // اگر قبلا کش شده
            if (productSwitchConfig.cache.seoProducts &&
                productSwitchConfig.cache.seoProducts.length > 0) {
                //console.log('استفاده از کالاهای کش شده بارنامه');
                updateProductSelect(productSwitchConfig.cache.seoProducts);
                showLoading(false);
                return;
            }

            // اگر کش نشده، از سرور بگیر
            await fetchProducts(true);
        }

        // ==================== LOAD ALL PRODUCTS ====================
        async function loadAllProducts() {
            // اگر قبلا کش شده
            if (productSwitchConfig.cache.allProducts &&
                productSwitchConfig.cache.allProducts.length > 0) {
                //console.log('استفاده از همه کالاهای کش شده');
                updateProductSelect(productSwitchConfig.cache.allProducts);
                showLoading(false);
                return;
            }

            // اگر کش نشده، از سرور بگیر
            await fetchProducts(false);
        }

        // ==================== FETCH PRODUCTS FROM SERVER ====================
        async function fetchProducts(isSeoProductsOnly) {
            // جلوگیری از درخواست‌های تکراری
            if (productSwitchConfig.cache.loading) {
                //console.log('درخواست در حال انجام است...');
                return;
            }

            productSwitchConfig.cache.loading = true;

            var url = isSeoProductsOnly
                ? productSwitchConfig.urls.seoProducts
                : productSwitchConfig.urls.allProducts;

            var params = isSeoProductsOnly
                ? { seoId: '@Model.Info.Id' }
                : {};

            //console.log('دریافت کالاها از سرور:', url, params);


            try {
                const response = await $.ajax({
                    url: url,
                    type: 'GET',
                    data: params,
                    dataType: 'json'
                });

                //console.log('داده‌های دریافتی:', response);

                // ذخیره در کش
                if (isSeoProductsOnly) {
                    productSwitchConfig.cache.seoProducts = response;
                } else {
                    productSwitchConfig.cache.allProducts = response;
                }

                // بروزرسانی select
                updateProductSelect(response);

                // ریست وضعیت
                productSwitchConfig.cache.loading = false;
                showLoading(false);

                // نمایش پیام موفقیت
                showSuccessMessage('لیست کالاها با موفقیت بارگذاری شد');

            } catch ( error) {
                    console.error('خطا در دریافت کالاها:', error);

                // ریست وضعیت
                productSwitchConfig.cache.loading = false;
                showLoading(false);

                // نمایش پیام خطا
                showErrorMessage('خطا در دریافت لیست کالاها');

                // fallback به لیست پیش‌فرض
                if (!isSeoProductsOnly) {
                    // برگرداندن چک‌باکس به حالت روشن (کالاهای بارنامه)
                    $('#ProductSwitch').prop('checked', true);

                    // نمایش لیست قبلی (کالاهای بارنامه)
                    if (productSwitchConfig.cache.seoProducts) {
                        updateProductSelect(productSwitchConfig.cache.seoProducts);
                    }
                }

                throw error;
            } finally {
                productSwitchConfig.cache.loading = false;
            }

        }

        // ==================== UPDATE PRODUCT SELECT ====================
        function updateProductSelect(products) {
            if (!products || !Array.isArray(products)) {
                let message = 'داده‌های محصول نامعتبر است:';
                console.error(message, products);

                Toast.fire({
                    icon: 'error',
                    title: message
                });
                return;
            }

            // حفظ مقدار انتخاب شده فعلی
            var currentValue = productSwitchConfig.$productSelect.val();
            //console.log('مقدار فعلی سلکت:', currentValue);

            // پاک کردن options فعلی
            productSwitchConfig.$productSelect.empty();

            // اضافه کردن محصولات
            var item = '';
            $.each(products, function(index, product) {
                if (product == null) {
                        productSwitchConfig.$productSelect.empty();
                }
                else {
                        item += "<option value='" + product.id + "'>" + product.title + "</option>";
                }
            });
            productSwitchConfig.$productSelect.html(item);

            // ریفرش select2 با تنظیمات درست
            refreshSelect2();

            // تعداد آیتم‌های اضافه شده
            var optionCount = productSwitchConfig.$productSelect.find('option').length - 1;
            //console.log('تعداد کالاهای اضافه شده:', optionCount);

            // اعتبارسنجی
            if (productSwitchConfig.$productSelect.valid) {
                productSwitchConfig.$productSelect.valid();
            }
        }

        // ==================== REFRESH SELECT2 ====================
        function refreshSelect2() {
            // از بین بردن select2 فعلی
            if (productSwitchConfig.$productSelect.hasClass('select2-hidden-accessible')) {
                productSwitchConfig.$productSelect.select2('destroy');
            }

            // ایجاد مجدد select2 با والد درست
            productSwitchConfig.$productSelect.select2({
                dropdownParent: $(productSwitchConfig.selectors.modal),
                placeholder: "کالا را انتخاب کنید",
                allowClear: false,
                width: '100%',
                dir: 'rtl'
            }).trigger('change');
        }

        // ==================== SHOW/HIDE LOADING ====================
        function showLoading(show) {
            if (show) {
                // اضافه کردن کلاس loading
                productSwitchConfig.$productSelect.addClass('loading');
                productSwitchConfig.$productSelect.prop('disabled', true);

                // اگر spinner وجود ندارد، اضافه کن
                if (!productSwitchConfig.$productSelect.parent().find('.select2-loading').length) {
                    productSwitchConfig.$productSelect.parent().append(
                        '<div class="select2-loading"><i class="fas fa-spinner fa-spin me-2"></i>در حال بارگذاری...</div>'
                    );
                }
            } else {
                // حذف کلاس loading
                productSwitchConfig.$productSelect.removeClass('loading');
                productSwitchConfig.$productSelect.prop('disabled', false);

                // حذف spinner
                productSwitchConfig.$productSelect.parent().find('.select2-loading').remove();
            }
        }

        // ==================== MESSAGE FUNCTIONS ====================
        function showSuccessMessage(message) {
            //console.log('Success:', message);

        }

        function showErrorMessage(message) {
            console.error('Error:', message);

            Toast.fire({
                icon: 'error',
                title: message
            });
        }



        // ==================== STYLES ====================
        function addCustomStyles() {
            if (!$('#product-switch-styles').length) {
                $('head').append(`
                    <style id="product-switch-styles">
                        .select2-loading {
                            position: absolute;
                            left: 10px;
                            top: 50%;
                            transform: translateY(-50%);
                            background: rgba(255,255,255,0.9);
                            padding: 5px 10px;
                            border-radius: 4px;
                            font-size: 12px;
                            z-index: 9999;
                            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
                        }
                        select.loading {
                            opacity: 0.6;
                            background-color: #f8f9fa;
                        }
                    </style>
                `);
            }
        }

        // اضافه کردن استایل‌ها
        addCustomStyles();


    </script>
}
