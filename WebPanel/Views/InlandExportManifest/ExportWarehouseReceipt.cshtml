@model ExportWarehouseReceiptPageDto

@{
    ViewData["Title"] = "قبض انبار صادرات";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    int i = 1;
    int row = 1;
    int swrRow = 1;
    bool isContainer = Model.Info.Seo?.TrafficType == TrafficType.Container;
    string colSize = isContainer ? "col-md-3" : "col-md-6";
}



<div class="col-md-12">
    <div class="p-3 rounded-3 bg-white shadow-sm">
        <div class="d-flex justify-content-between">
            <div>
                <span class="fs-6">
                    <i class="icon-frane"></i>
                    <a asp-controller="InlandExportManifest" asp-action="Details" asp-route-Id="@Model.Info.Id"><i class="fa-solid fa-right-to-bracket me-2"></i></a>
                    قبض انبار صادارات
                </span>
                <span class="label p-2 mx-2 rounded label-primary">@($"{Model.Info.ManifestNumber} {Model.Info.Seo?.OwnerName}")</span>
                <span class="label p-2 mx-2 rounded label-info">@Model.Info.Seo?.ProductName (@Model.Info.Seo?.Count.ToPrice() @Model.Info.Seo?.ProductPackingName)</span>
            </div>

            <div class="d-flex align-items-center">
                @DateTimeOffset.Now.ToLongPersianDateString()
                <i class="icon-calendar"></i>
            </div>
        </div>
    </div>
</div>


<div class="mt-3 cu-table">
    <div class="row">
        <div class="col-md-12">
            <div class="card rounded-3 min-height-600">
                <div class="card-header">
                    <div class="d-flex justify-content-between">
                        <h3 class="title m-0">
                            <i class="fa-solid fa-boxes-packing text-primary align-middle me-2"></i>
                            تالی های بارنامه - تعداد @(Model.SeoProductAndTaliInfos?.Count.ToPrice() ?? "0") (@(ServiceUnLoadType.UnloadToWarehouse.ToDisplay()))
                        </h3>
                        <div>
                            @if (Model.SeoProductAndTaliInfos?.Any() == true)
                            {
                                <a onclick="addSelectedToWarehouseReceipt()"
                                   style="border-radius:5px; margin:0px 10px" class="btn btn-primary btn-sm">
                                    افزودن انتخاب شده ها به قبض انبار
                                </a>
                            }
                        </div>
                        @* <div>
                            @if (Model.SeoMinInfo.VoyageId != null)
                            {
                                <a asp-controller="Voyage" asp-action="CompactTali" asp-route-voyageId="@Model.SeoMinInfo.VoyageId"
                                   asp-route-seoId="@Model.SeoMinInfo.Id" asp-route-returnPage="100"
                                   style="border-radius:5px; margin:0px 10px" class="btn btn-success">
                                    خلاصه تالی
                                </a>

                                <a asp-controller="Voyage" asp-action="DetailTali"
                                   asp-route-seoId="@Model.SeoMinInfo.Id" asp-route-returnPage="100"
                                   asp-route-voyageId="@Model.SeoMinInfo.VoyageId"
                                   style="border-radius:5px; margin:0px 10px" class="btn btn-success">
                                    ریزجزئیات تالی
                                </a>
                            }
                        </div> *@
                    </div>
                </div>
                <div class="card-body pt-0">

                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-hover table-striped cu-table" id="tali-table">
                            <thead class="bg-primary">
                                <tr>
                                    <th><input type="checkbox" id="selectAllTali" /></th>
                                    <th>ردیف</th>
                                    <th>کالا</th>

                                    <th>تاریخ اولین تخلیه</th>


                                    <th>شمارش صفاف</th>

                                    <th>وزن میانگین  </th>
                                    <th>وزن باسکول  </th>

                                    <th>انبار</th>

                                    <th>عملیات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.SeoProductAndTaliInfos != null)
                                {
                                    foreach (var item in Model.SeoProductAndTaliInfos)
                                    {
                                        <tr>
                                            <td class="align-middle bg-light" style="width:30px;"><input type="checkbox" value="@item.IdJsonData" class="tali-checkbox" /></td>
                                            <td class="align-middle bg-light">@(i)</td>
                                            <td class="align-middle bg-light"> @item.FullProductName </td>

                                            <td class="align-middle bg-light"> @item.FirstUnloadDate </td>


                                            <td class="align-middle bg-light">@item.TaliCount1.ToPrice()  </td>

                                            <td class="align-middle bg-light">@item.WeightAverage.ToPrice()  </td>
                                            <td class="align-middle bg-light">@item.WeightBaskol.ToPrice()  </td>

                                            <td class="align-middle bg-light">@item.WarehouseTitle</td>
                                            <td class="d-none">
                                                <div class="d-none">
                                                    <input hidden id="@($"{i}-taliData")" value="@JsonConvert.SerializeObject(item)" />
                                                </div>

                                            </td>

                                            <td class="align-middle bg-light px-2 text-center">
                                                <a class="btn btn-sm btn-info px-2" onclick="showModalAddProduct('@($"{i}-taliData")')">  <i class="fa-solid fa-warehouse text-white align-middle me-2"></i> + </a>
                                            </td>
                                        </tr>

                                        i++;
                                    }
                                }


                            </tbody>
                        </table>

                    </div>

                </div><!-- /.portlet-body -->
            </div>
        </div>

    </div>
</div>


<div class="mt-1">
    <div class="row">
        <div class="col-md-12">
            <div class="card rounded-3 min-height-600">
                <div class="card-header">
                    <div class="d-flex justify-content-between">
                        <h3 class="title m-0">
                            <i class="fa-solid fa-warehouse text-primary align-middle me-2"></i>
                            صدور قبض انبار
                        </h3>
                        <div>
                            <a style="border-radius:5px; margin:0px 10px" class="btn btn-primary " onclick="showModalAddProduct('');">
                                <i class="icon-plus"></i>
                                افزودن کالا
                            </a>

                            @if (Model.PreviewProducts?.Any() == true)
                            {
                                <a onclick="ShowModalDescription(event)"
                                   id="descriptionButton"
                                   style="border-radius:5px; margin:0px 10px"
                                   class="btn btn-info mx-2"> مشخصات</a>

                                <a onclick="PreviewWarehouseReciept(event)"
                                   id="previewButton"
                                   style="border-radius:5px; margin:0px 10px"
                                   class="btn btn-warning mx-2">پیش نمایش</a>

                                <a onclick="FinalWarehouserReciept(event,'@Model.Info.Seo.SeoId')"
                                   id="finalizeButton"
                                   style="border-radius:5px; margin:0px 10px"
                                   class="btn btn-success mx-2">نهایی کردن قبض انبار</a>
                            }
                            else
                            {
                                <a onclick="ShowModalDescription(event)"
                                   id="descriptionButton"
                                   style="border-radius:5px; margin:0px 10px; display: none"
                                   class="btn btn-info mx-2"> مشخصات</a>

                                <a onclick="PreviewWarehouseReciept(event)"
                                   id="previewButton"
                                   style="border-radius:5px; margin:0px 10px; display: none"
                                   class="btn btn-warning mx-2">پیش نمایش</a>

                                <a onclick="FinalWarehouserReciept(event,'@Model.Info.Seo.SeoId')"
                                   id="finalizeButton"
                                   style="border-radius:5px; margin:0px 10px; display: none"
                                   class="btn btn-success mx-2">نهایی کردن قبض انبار</a>

                            }

                        </div>
                    </div>
                </div>
                <div class="card-body pt-0">
                    <div id="PreviewProductsId">
                        <partial name="_ExportWarehouseReceiptListProduct" model="Model.PreviewProducts" />
                    </div>


                </div><!-- /.portlet-body -->
            </div>
        </div>

    </div>
</div>


<div class="mt-1">
    <div class="row">
        <div class="col-md-12">
            <div class="card rounded-3 min-height-600">
                <div class="card-header py-3 px-3">
                    <div class="d-flex justify-content-between">
                        <h3 class="title m-0">
                            <i class="fa-solid fa-receipt text-primary align-middle me-2"></i>
                            قبض انبار ها  (تعداد @(Model.SeoWarehouseReceipts?.Count.ToPrice() ?? "0"))
                        </h3>
                    </div>
                </div>
            @if (Model.SeoWarehouseReceipts != null)
            {
                <div class="accordion pt-2 px-3" id="accordionExample">
                @foreach (var item in Model.SeoWarehouseReceipts)
                {
                    <div class="accordion-item mb-1">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed @(row % 2 == 0 ? "bg-white" : "bg-light")" type="button" data-bs-toggle="collapse" data-bs-target="#collapse@(row)" aria-expanded="false" aria-controls="collapse@(row)">
                                <div class="align-middle bg-info p-1 px-2 rounded-circle text-info text-white">
                                    <span>
                                        @(swrRow++) 
                                    </span>
                                </div>
                                <div class="responsive-accordion-btn">
                                    <div class="d-flex justify-content-between gap-4 align-items-center px-3">
                                        <div class="text-dark">
                                            <span class="text-secondary"> شماره قبض: </span> @item.Number
                                        </div>
                                        <div class="text-dark">
                                            <span class="text-secondary"> شماره بارنامه/مجوز: </span>
                                            @if (item.EntryRouteType == EntryRouteType.EntryFromSea)
                                            {
                                                <a target="_blank" asp-action="seoAccessPage" asp-controller="Seo" class="text-dark px-2 "
                                                   asp-route-seoId="@item.SeoId">
                                                    @item.BillOfLadingNumber
                                                </a>
                                            }
                                            else
                                            {
                                                <a target="_blank" asp-action="Details" asp-controller="InlandExportManifest" class="text-dark px-2 "
                                                   asp-route-Id="@item.InlandExportManifestId">
                                                    @item.BillOfLadingNumber
                                                </a>
                                            }
                                        </div>
                                        <div class="text-dark">
                                            <span class="text-secondary"> کشتی: </span> @item.SeoShipShipName
                                        </div>
                                        <div class="text-dark">
                                            <span class="text-secondary"> تعداد کالا: </span> @(item.Products?.Count ?? 0)
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-between gap-4 align-items-center px-3 responsive-mt3 mt-3">
                                        <div class="text-dark">
                                            <span class="text-secondary"> نوع ورود: </span> @item.EntryRouteTypeTitle
                                        </div>
                                        <div class="text-dark">
                                            <span class="text-secondary"> صاحب کالا: </span> @item.CompanyOwnerCompanyName
                                        </div>
                                        <div class="text-dark">
                                            <span class="text-secondary"> تاریخ صدور: </span> @item.CreatedDateFa
                                        </div>
                                    </div>
                                </div>
                            </button>
                        </h2>
                        <div id="collapse@(row++)" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
                            <div class="accordion-body p-1">
                                <div class="table-responsive" style="max-height: 35rem; min-height: 25rem">
                                    <table class="table table-sm table-bordered table-hover cu-table" id="data-table">
                                        <thead class="bg-primary">
                                        <tr>
                                            <th class="align-middle">کالا</th>
                                            <th class="px-0"><div class="px-3">تعداد</div> <hr class="my-1" /> <div class="px-3">باقیمانده</div></th>
                                            <th class="px-0"><div class="px-3"> وزن ناخالص </div> <hr class="my-1" /> <div class="px-3">باقیمانده</div></th>
                                            <th class="px-0"><div class="px-3"> وزن خالص </div> <hr class="my-1" /> <div class="px-3">باقیمانده</div></th>
                                            <th class="px-0"><div class="px-3"> حجم </div> <hr class="my-1" /> <div class="px-3">باقیمانده</div></th>
                                            <th class="align-middle">انبار</th>

                                            <th class="align-middle">تعداد روز در انبار</th>
                                            <th class="align-middle">عملیات</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                          
                                        <tr>
                                            <!-- سلول‌های بدون rowspan -->
                                            <td class="align-middle"><a class="btn btn-outline-info px-2" onclick="ShowModalSwrProductFullInfo('@item.Products[0].Id')"> @item.Products[0].ProductFullTitle</a></td>
                                            <td class="align-middle px-0 py-4">
                                                <div class="mb-1 px-3">@item.Products[0].Count.ToPrice()</div>
                                                <hr class="my-1" />
                                                <div class="px-3">@item.Products[0].RemainingCount.ToPrice()</div>
                                            </td>
                                            <td class="align-middle px-0 py-4">
                                                <div class="mb-1 px-3">@item.Products[0].WeightGross.ToPrice()</div>
                                                <hr class="my-1" />
                                                <div class="px-3">@item.Products[0].RemainingWeightGross.ToPrice()</div>
                                            </td>
                                            <td class="align-middle px-0 py-4">
                                                <div class="mb-1 px-3">@item.Products[0].WeightNet.ToPrice()</div>
                                                <hr class="my-1" />
                                                <div class="px-3">@item.Products[0].RemainingWeightNet.ToPrice()</div>
                                            </td>
                                            <td class="align-middle px-0 py-4">
                                                <div class="mb-1 px-3">@item.Products[0].Volume.ToPrice()</div>
                                                <hr class="my-1" />
                                                <div class="px-3">@item.Products[0].RemainingVolume.ToPrice()</div>
                                            </td>
                                            <td class="align-middle">

                                                <div class="px-3">
                                                    <span class="text-dark">@item.Products[0].Warehouse?.Name</span> - <span class="text-dark">@item.Products[0].WarehouseSegment?.Name</span>
                                                </div>

                                            </td>
                                            <td class="align-text-top" rowspan="@item.Products.Count">
                                                <div class="px-3">
                                                    <span class="text-dark">@item.StockDayInWarehouse</span>
                                                </div>

                                            </td>
                                        
                                            <td rowspan="@item.Products.Count" class="align-text-top ">

                                                <div class="dropdown w-100">
                                                    <button class="dropbtn w-100 btn btn-info rounded" type="submit">
                                                        <div class="d-flex align-items-center">
                                                            <span> منو </span><i class="icofont icofont-arrow-down align-middle"></i>
                                                        </div>
                                                    </button>
                                                    <div class="dropdown-content">
                                                        <ul>
                                                            <li>
                                                                <a class="dropdown-item" onclick="showWarehouseReceiptOutbounds('@item.Id')"> <i class="fa-solid fa-receipt"></i>  نمایش پروانه ها </a>
                                                            </li>
                                                            <li>
                                                                <a target="_blank" class="dropdown-item"
                                                                   asp-action="GetFileWarehouseReceiptById" asp-controller="Seo"
                                                                   asp-route-seoWarehouseReceiptId="@item.Id">
                                                                    <i class="fa-solid fa-download"></i> دانلود
                                                                </a>
                                                            </li>

                                                            @if (item.Products.Any(x => x.RemainingCount > 1))
                                                            {
                                                                <li>
                                                                    <a asp-controller="WarehouseReceipt" asp-action="Split" class="dropdown-item"
                                                                       asp-route-seoWarehouseReceiptId="@item.Id" asp-route-seoId="@Model.Info.Id">
                                                                        <i class="fa-solid fa-adjust"></i> تفکیک
                                                                    </a>
                                                                </li>
                                                            }

                                                            @if (item.Products.Any(x => x.RemainingCount > 0))
                                                            {
                                                                <li>
                                                                    <a asp-controller="WarehouseReceipt" asp-action="Merge" class="dropdown-item"
                                                                       asp-route-seoWarehouseReceiptId="@item.Id" asp-route-ExportId="@Model.Info.Id">
                                                                        <i class="fa-solid fa-bag-seedling"></i> تجمیع
                                                                    </a>
                                                                </li>
                                                            }

                                                            @if (item.Products.Any(x => x.RemainingCount > 0))
                                                            {
                                                                <li>
                                                                    <a asp-controller="WarehouseReceipt" asp-action="ChangeOwnership" class="dropdown-item"
                                                                       asp-route-seoWarehouseReceiptId="@item.Id" asp-route-ExportId="@Model.Info.Id">
                                                                        <i class="fa-solid fa-bag-seedling"></i> تغییر مالکیت
                                                                    </a>
                                                                </li>
                                                            }

                                                            @if (item.HasFullContainerForStrip)
                                                            {
                                                                <li>
                                                                    <a asp-controller="WarehouseReceipt" asp-action="StripContainerList" class="dropdown-item"
                                                                       asp-route-swrId="@item.Id">
                                                                        <i class="fa-solid fa-bag-seedling"></i> استریپ کانتینر
                                                                    </a>
                                                                </li>
                                                            }
                                                        </ul>
                                                    </div>
                                                </div>

                                            </td>
                                        </tr>

                                        <!-- سطرهای بعدی برای آیتم‌های باقی‌مانده -->
                                        @for (int p = 1; p < item.Products.Count; p++)
                                        {
                                            <tr>
                                                <td class="align-middle"><a class="btn btn-outline-info px-2" onclick="ShowModalSwrProductFullInfo('@item.Products[p].Id')"> @item.Products[p].ProductFullTitle </a></td>
                                                <td class="align-middle px-0 py-4">
                                                    <div class="px-3">@item.Products[p].Count.ToPrice()</div>
                                                    <hr class="my-1" />
                                                    <div class="px-3">@item.Products[p].RemainingCount.ToPrice()</div>
                                                </td>
                                                <td class="align-middle px-0 py-4">
                                                    <div class="px-3">@item.Products[p].WeightGross.ToPrice()</div>
                                                    <hr class="my-1" />
                                                    <div class="px-3">@item.Products[p].RemainingWeightGross.ToPrice()</div>
                                                </td>
                                                <td class="align-middle px-0 py-4">
                                                    <div class="px-3">@item.Products[p].WeightNet.ToPrice()</div>
                                                    <hr class="my-1" />
                                                    <div class="px-3">@item.Products[p].RemainingWeightNet.ToPrice()</div>
                                                </td>
                                                <td class="align-middle px-0 py-4">
                                                    <div class="px-3">@item.Products[p].Volume.ToPrice()</div>
                                                    <hr class="my-1" />
                                                    <div class="px-3">@item.Products[p].RemainingVolume.ToPrice()</div>
                                                </td>
                                                <td class="align-middle px-0 py-4">
                                                    <div class="px-3">@item.Products[p].Warehouse?.Name - @item.Products[p].WarehouseSegment?.Name</div>
                                                </td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                </div>
                                
                            </div>
                        </div>
                    </div>
                    }
                </div>
                }
            </div>
        </div>

    </div>
</div>


<div id="addAllModal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">افزودن تالی‌های انتخاب شده به قبض انبار</h4>
                <button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addAllToWarehouseReceiptForm">
                    <div class="row gy-4">
                         <div class="col-md-12">
                            <div class="form-group">
                                <label>انبار پیش فرض - درصورت مشخص نبودن انبار در تالی از این انبار استفاده میشود</label>
                                <select class="form-control select2" id="addAllWarehouse"
                                        asp-items="@Model.Warehouses">
                                        <option value="">نامشخص</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success btn-round" onclick="submitAddAllToWarehouseReceipt()">ذخیره</button>
                <button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>
            </div>
        </div>
    </div>
</div>

<div id="generalmodal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">مشخصات کالا در قبض انبار</h4>
                <button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalbody">

                <input asp-for="DateFirstTaliFa" type="hidden" />
                <form asp-action="AddOrUpdateProductToWarehouseReceipt" id="AddProductInWarehouseRecieptId" method="post">
                    <input asp-for="AddWarehouseReceiptProduct.Id" type="hidden" />
                    <input asp-for="AddWarehouseReceiptProduct.SeoWarehouseReceiptId" type="hidden" />
                    <input asp-for="AddWarehouseReceiptProduct.ExportId" value="@Model.Info.Id" type="hidden" />
                    <input asp-for="AddWarehouseReceiptProduct.SeoId" value="@Model.Info.Seo.SeoId" type="hidden" />

                    <div class="card-body py-0">

                        <div class="form-body">
                            <div class="row gy-4">

                                <div class="col-md-6">
                                    <div class=" form-group">
                                        <span class="d-flex justify-content-start">
                                            <label> کالا</label>
                                            @*  <div class="form-check form-switch ms-3">
                                                <input type="checkbox" class="form-check-input" id="ProductSwitch" role="switch" checked />
                                                <label class="form-check-label text-success ms-2">  فقط کالا های بارنامه </label>
                                            </div> *@
                                        </span>
                                        <div class="input-group">
                                            @* <partial name="_SeoWRProduct" model="@Model.SeoProducts" /> *@
                                            <select class="form-control  select2 generalmodal"
                                                    asp-for="AddWarehouseReceiptProduct.SeoProductId">
                                                @if (Model.SeoProducts?.Any() == true)
                                                {
                                                    foreach (var item in Model.SeoProducts)
                                                    {
                                                        <option value="@item.Id">@item.Title</option>
                                                    }
                                                }
                                            </select>
                                            <span asp-validation-for="AddWarehouseReceiptProduct.SeoProductId" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>


                                <div class="col-md-6">
                                    <div class=" form-group">
                                        <label>HS Code</label>
                                        <div class="input-group">
                                            <input asp-for="AddWarehouseReceiptProduct.HSCode" type="text" class=" form-control rounded">
                                            <span asp-validation-for="AddWarehouseReceiptProduct.HSCode" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>

                                @if (isContainer)
                                {
                                    <div class="@(colSize)">
                                        <div class="form-group">
                                            <label>پر/خالی بودن</label>
                                            <div class="input-group">
                                                <select class="form-control select2 generalmodal" asp-for="AddWarehouseReceiptProduct.IsFreeContainer">
                                                    <option value="true">کانتینر خالی</option>
                                                    <option value="false">کانتینر پر</option>
                                                </select>
                                                <span asp-validation-for="AddWarehouseReceiptProduct.IsFreeContainer" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                }

                                <div class="@(colSize)">
                                    <div class=" form-group">
                                        <label> انبار</label>
                                        <div class="input-group">
