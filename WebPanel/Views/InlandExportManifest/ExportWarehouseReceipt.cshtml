@section script {
    <script>
        $(document).ready(function () {
            $('.select2').select2();

            $('select[class*="generalmodal"].select2').select2({
                dropdownParent: $('#generalmodal')
            });

            kamaDatepicker('AddWarehouseReceiptProduct_FirstUnloadDateFa', customOptions);
            resetModalToDefaults();

            $('#selectAllTali').click(function (e) {
                var isChecked = this.checked;
                $('#tali-table tbody tr:visible').find('td input:checkbox.tali-checkbox').prop('checked', isChecked);
            });

        });

        $(document).ready(function () {
            $('select[id^="addAll"]').select2({
                dropdownParent: $('#addAllModal')
            });
        });

        function addSelectedToWarehouseReceipt() {
            var selectedIds = [];
            $("input:checkbox.tali-checkbox:checked").each(function () {
                selectedIds.push($(this).val());
            });

            if (!selectedIds || selectedIds.length === 0) {
                showAlert("هیچ تالی انتخاب نشده است");
                return;
            }

            $('#addAllModal').modal('show');
        }

        function submitAddAllToWarehouseReceipt() {
            var selectedIds = [];
            $("input:checkbox.tali-checkbox:checked").each(function () {
                selectedIds.push($(this).val());
            });

            if (!selectedIds || selectedIds.length === 0) {
                showAlert("هیچ تالی انتخاب نشده است");
                return;
            }

            var exportId = "@Model.Info.Id";
            var warehouse = $('#addAllWarehouse').val();

            $.post("@Url.Action("AddSelectedTaliToWarehouseReceipt", "InlandExportManifest")",
                {
                    exportId: exportId,
                    selectedTaliIds: selectedIds,
                    warehouseId: warehouse
                })
                .done(function (res) {
                    $("#addAllModal").modal('hide');
                    $("#PreviewProductsId").html(res);
                    CheckBtnFinalShow();
                    showAlert("تالی‌های انتخاب شده با موفقیت به قبض انبار اضافه شدند", 0);
                })
                .fail(function (xhr, status, error) {
                    showAlert("خطا در افزودن تالی‌ها به قبض انبار");
                });
        }

        function ShowGeneralCargoProductTitle(id)
        {
            if (!id) {
                showAlert("تعرفه باربری ثبت نشده است");
                return;
            }
            $.post("@Url.Action("GetGeneralCargoProductTitle", "GeneralCargoProduct")",
                {
                    generalCargoProductTariffId: id
                })
                .done(function (res) {
                    showAlert(res, 0);
                })
                .fail(function (xhr, status, error) {
                    showAlert("خطا  ");
                });
        }

        function ShowNonContainerWarehouseProductTitle(id)
        {
            if (!id) {
                showAlert("تعرفه انبارداری ثبت نشده است");
                return;
            }
            $.post("@Url.Action("GetNonContainerWarehouseProductTitle", "NonContainerWarehouseProduct")",
                {
                    nonContainerWarehouseProductTariffId: id
                })
                .done(function (res) {
                    showAlert(res, 0);
                })
                .fail(function (xhr, status, error) {
                    showAlert("خطا  ");
                });
        }

        $(document).ready(function () {
            $('#AddProductInWarehouseRecieptId').submit(function (e) {
                e.preventDefault();

                if (!$(this).valid()) {
                    return;
                }

                var count = parseInt($('#AddWarehouseReceiptProduct_Count').val()) || 0;

                if (count < 1) {
                    showAlert("تعداد را درست وارد کنید");
                    return;
                }

                $.ajax({
                    url: $(this).attr('action'),
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (response) {
                        $("#generalmodal").modal('hide');
                        $('#PreviewProductsId').html(response);
                        CheckBtnFinalShow();
                    },
                    error: function (xhr) {
                        location.reload();
                    }
                });
            });
        });

        async function editProduct(row) {
            let seoProductId = $('#seoProductId' + row).val();
            let productId = $('#productId' + row).val();
            if (!seoProductId)
            {
                seoProductId = productId;
                $('#ProductSwitch').prop('checked', false) ;
                await loadAllProducts();
            }
            else{
                $('#ProductSwitch').prop('checked', true).trigger('change') ;
            }


            // console.log('seoProductId: ' + seoProductId);
            // console.log('productId: ' + productId);

            let seoRecieptProductId = $('#seoRecieptProductId' + row).text();
            let seoWarehouseReceiptId = $('#seoWarehouseReceiptId' + row).text();
            let count = $('#count' + row).text();
            let weightGross = $('#weightGross' + row).text();
            let weightNet = $('#weightNet' + row).text();
            let volume = $('#volume' + row).text();
            let seoWarehouseAndSegmentDtoJson = $('#seoWarehouseAndSegmentDtoJson' + row).text();
            let firstUnloadDateFa = $('#firstUnloadDateFa' + row).text();

            let isDangerous = $('#isDangerousId' + row).val() === '1';
            let isBigVolume = $('#isBigVolumeId' + row).val() === '1';
            let isUnusual = $('#isUnusualId' + row).val() === '1';
            let isRawMaterials = $('#isRawMaterialsId' + row).val() === '1';
            let isSelfTransported = $('#isSelfTransported' + row).val() === '1';

            let generalCargoProductTariffId = $('#generalCargoProductTariffId' + row).val();
            let nonContainerWarehouseProductTariffId = $('#nonContainerWarehouseProductTariffId' + row).val();
            let productPackingId = $('#productPackingId' + row).val();
            let hsCode = $('#hsCode' + row).val();

            let isFreeContainer = $('#isFreeContainerId' + row).val();
            let containerFreightProductTariffId = $('#containerFreightProductTariffId' + row).val();
            let containerWarehouseProductTariffId = $('#containerWarehouseProductTariffId' + row).val();
            let containerStripProductTariffId = $('#containerStripProductTariffId' + row).val();

            $('#AddWarehouseReceiptProduct_Id').val(seoRecieptProductId);
            $('#AddWarehouseReceiptProduct_SeoWarehouseReceiptId').val(seoWarehouseReceiptId);
            // $('#AddWarehouseReceiptProduct_SeoProductId').val(seoProductId.trim());

            // کمی تاخیر برای اطمینان از لود کامل
            setTimeout(() => {
                if (seoProductId) {
                    $('#AddWarehouseReceiptProduct_SeoProductId')
                        .val(seoProductId.trim())
                        .trigger('change');
                }
            }, 100);

            SetNumber(Number(count), 'AddWarehouseReceiptProduct_Count');
            SetNumber(Number(weightGross), 'AddWarehouseReceiptProduct_WeightGross');
            SetNumber(Number(weightNet), 'AddWarehouseReceiptProduct_WeightNet');
            SetNumber(Number(volume), 'AddWarehouseReceiptProduct_Volume');

            $('#AddWarehouseReceiptProduct_SeoWarehouseAndSegmentDtoJson').val(seoWarehouseAndSegmentDtoJson);
            $('#AddWarehouseReceiptProduct_FirstUnloadDateFa').val(firstUnloadDateFa);

            $('#AddWarehouseReceiptProduct_IsDangerous').prop('checked', isDangerous);
            $('#AddWarehouseReceiptProduct_IsBigVolume').prop('checked', isBigVolume);
            $('#AddWarehouseReceiptProduct_IsUnusual').prop('checked', isUnusual);
            $('#AddWarehouseReceiptProduct_IsRawMaterials').prop('checked', isRawMaterials);
            $('#AddWarehouseReceiptProduct_IsSelfTransported').prop('checked', isSelfTransported);

            $('#AddWarehouseReceiptProduct_SeoWarehouseAndSegmentDtoJson').trigger('change');

            $("#AddWarehouseReceiptProduct_GeneralCargoProductTariffId").val(generalCargoProductTariffId);
            $("#AddWarehouseReceiptProduct_GeneralCargoProductTariffId").trigger('change');

            $("#AddWarehouseReceiptProduct_NonContainerWarehouseProductTariffId").val(nonContainerWarehouseProductTariffId);
            $("#AddWarehouseReceiptProduct_NonContainerWarehouseProductTariffId").trigger('change');

            $("#AddWarehouseReceiptProduct_ProductPackingId").val(productPackingId);
            $("#AddWarehouseReceiptProduct_ProductPackingId").trigger('change');
            // $("#AddWarehouseReceiptProduct_ProductHSCodeId").val(productHSCodeId);
            // $("#AddWarehouseReceiptProduct_ProductHSCodeId").trigger('change');
            $("#AddWarehouseReceiptProduct_HSCode").val(hsCode);

            $("#AddWarehouseReceiptProduct_ContainerFreightProductTariffId").val(containerFreightProductTariffId);
            $("#AddWarehouseReceiptProduct_ContainerFreightProductTariffId").trigger('change');

            $("#AddWarehouseReceiptProduct_ContainerWarehouseProductTariffId").val(containerWarehouseProductTariffId);
            $("#AddWarehouseReceiptProduct_ContainerWarehouseProductTariffId").trigger('change');

            $("#AddWarehouseReceiptProduct_ContainerStripProductTariffId").val(containerStripProductTariffId);
            $("#AddWarehouseReceiptProduct_ContainerStripProductTariffId").trigger('change');

            if(isFreeContainer){
                $("#AddWarehouseReceiptProduct_IsFreeContainer").val(isFreeContainer.toString());
                $("#AddWarehouseReceiptProduct_IsFreeContainer").trigger('change');
            }
            else{
                $("#AddWarehouseReceiptProduct_IsFreeContainer").val('');
                $("#AddWarehouseReceiptProduct_IsFreeContainer").trigger('change');
            }

            $('select[class*="generalmodal"].select2').select2({
                dropdownParent: $('#generalmodal')
            });

            $("#generalmodal").modal('show');
        }

        function showModalAddProduct(taliDataId) {

            if (taliDataId) {
                var jsonData = $('#' + taliDataId).val();

                if (jsonData) {
                    try {
                        var taliData = JSON.parse(jsonData);
                        fillModalWithTaliData(taliData);
                    } catch (e) {
                        console.error('Error parsing JSON data:', e);

                        resetModalToDefaults();
                    }
                }
            } else {

                resetModalToDefaults();
            }


            $("#generalmodal").modal('show');
        }


        function fillModalWithTaliData(taliData) {
            resetModalToDefaults();
            if (taliData.SeoProductId) {
                $('#AddWarehouseReceiptProduct_SeoProductId').val(taliData.SeoProductId).trigger('change');
            }

            if (taliData.FirstUnloadDate) {
                $('#AddWarehouseReceiptProduct_FirstUnloadDateFa').val(taliData.FirstUnloadDate);
            }

            if (taliData.WarehouseJsonId) {
                $('#AddWarehouseReceiptProduct_SeoWarehouseAndSegmentDtoJson').val(taliData.WarehouseJsonId).trigger('change');
            }
            else{
                $('#AddWarehouseReceiptProduct_SeoWarehouseAndSegmentDtoJson').val('').trigger('change');
            }

            var count = taliData.TaliCount1;
            SetNumber(count, 'AddWarehouseReceiptProduct_Count');

            if(taliData.WeightBaskol > 0 )
            {
                var weightBaskol = taliData.WeightBaskol;
                SetNumber(weightBaskol, 'AddWarehouseReceiptProduct_WeightGross');
                SetNumber(weightBaskol, 'AddWarehouseReceiptProduct_WeightNet');
            }
            else
            {
                var weightAverage = taliData.WeightAverage;
                SetNumber(weightAverage, 'AddWarehouseReceiptProduct_WeightGross');
                SetNumber(weightAverage, 'AddWarehouseReceiptProduct_WeightNet');
            }

            $('#AddWarehouseReceiptProduct_IsDangerous').prop('checked', taliData.IsDangerous);
            $('#AddWarehouseReceiptProduct_IsBigVolume').prop('checked', taliData.IsBigVolume);
            $('#AddWarehouseReceiptProduct_IsUnusual').prop('checked', taliData.IsUnusual);
            $('#AddWarehouseReceiptProduct_IsRawMaterials').prop('checked', taliData.IsRawMaterials);

            $('#AddWarehouseReceiptProduct_Id').val('');

            var volume = taliData.Volume;
            SetNumber(volume, 'AddWarehouseReceiptProduct_Volume');
        }


        function resetModalToDefaults() {
            $('#AddWarehouseReceiptProduct_Id').val('');
            $('#AddWarehouseReceiptProduct_SeoWarehouseReceiptId').val('');
            SetNumber(1, 'AddWarehouseReceiptProduct_Count');
            
            SetNumber(0, 'AddWarehouseReceiptProduct_WeightGross');
            SetNumber(0, 'AddWarehouseReceiptProduct_WeightNet');
            SetNumber(0, 'AddWarehouseReceiptProduct_Volume');

            var dateFirstTaliFa = $('#DateFirstTaliFa').val();
            $('#AddWarehouseReceiptProduct_FirstUnloadDateFa').val(dateFirstTaliFa);

            $("#AddWarehouseReceiptProduct_IsDangerous").prop('checked', false);
            $("#AddWarehouseReceiptProduct_IsBigVolume").prop('checked', false);
            $("#AddWarehouseReceiptProduct_IsUnusual").prop('checked', false);
            $("#AddWarehouseReceiptProduct_IsRawMaterials").prop('checked', false);

            resetSelectsToDefault();

             if (productSwitchConfig.$switch) {
                productSwitchConfig.$switch.prop('checked', true).trigger('change');
            }
        }


        function resetSelectsToDefault() {
            $("#AddWarehouseReceiptProduct_GeneralCargoProductTariffId").val('').trigger('change');
            $("#AddWarehouseReceiptProduct_NonContainerWarehouseProductTariffId").val('').trigger('change');
            $("#AddWarehouseReceiptProduct_ContainerFreightProductTariffId").val('').trigger('change');
            $("#AddWarehouseReceiptProduct_ContainerWarehouseProductTariffId").val('').trigger('change');
            $("#AddWarehouseReceiptProduct_ContainerStripProductTariffId").val('').trigger('change');
            $("#AddWarehouseReceiptProduct_ProductPackingId").val('').trigger('change');
            $("#AddWarehouseReceiptProduct_ProductHSCodeId").val('').trigger('change');
            $("#AddWarehouseReceiptProduct_IsFreeContainer").val('').trigger('change');
            $("#AddWarehouseReceiptProduct_SeoProductId").val('').trigger('change');
            $("#AddWarehouseReceiptProduct_SeoWarehouseAndSegmentDtoJson").val('').trigger('change');
        }


        async function DeleteProduct(event, seoWarehouseReceiptProductId) {
            event.preventDefault();
            let result = await ShowQAlert2(event);

            if (result === true) {
                $.post("@Url.Action("DeleteWarehouseReceiptProduct", "InlandExportManifest")",
                    {
                        seoWarehouseReceiptProductId
                    })
                    .done(function (res) {

                        $("#PreviewProductsId").html(res);
                        CheckBtnFinalShow();
                    })
                    .fail(function (xhr, status, error) {
                        location.reload();
                    });
            }

        }



        function CheckBtnFinalShow() {
            var hasProducts = $("td[id^='seoRecieptProductId']").length > 0;

            const finalizeButton = document.getElementById('finalizeButton');
            const descriptionButton = document.getElementById('descriptionButton');
            const previewButton = document.getElementById('previewButton');

            if (finalizeButton) {
                finalizeButton.style.display = (hasProducts ) ? 'inline-block' : 'none';
            }

            if (descriptionButton) {
                descriptionButton.style.display = (hasProducts ) ? 'inline-block' : 'none';
            }

            if (previewButton) {
                previewButton.style.display = (hasProducts ) ? 'inline-block' : 'none';
            }
        }

        async function FinalWarehouserReciept(event, seoId) {
            event.preventDefault();
            let result = await ShowQAlert2(event, 'بعد از تایید نهایی امکان ویرایش وجود ندارد', 'تایید نهایی');

            if (result === true) {
                document.getElementById("finalizeButton").classList.add("disabled");

                $.post("@Url.Action("GenerateWarehouseReceipt", "Seo")", {
                    seoId
                }).done(function (res) {
                    location.reload();
                }).fail(function (xhr, status, error) {
                    location.reload();
                });
            }
        }

        function PreviewWarehouseReciept(event) {
            event.preventDefault();
            var swrId = document.getElementById('seoWarehouseReceiptId1')?.textContent?.trim();
            if (swrId) {
                window.open("@Url.Action("GetPreviewWarehouseReceipt", "Seo")" + "?seoWarehouseReceiptId=" + swrId, '_blank');
            }
        }

        async function ShowModalDescription(event) {
            event.preventDefault();

             let seoWarehouseReceiptId = $('#seoWarehouseReceiptId' + 1).text();
                $.post("@Url.Action("GetSwrDescription", "WarehouseReceipt")",
                {
                    seoWarehouseReceiptId
