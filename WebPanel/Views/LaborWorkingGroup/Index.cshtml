@model LaborWorkingGroupPageDto
@{
    ViewData["Title"] = "گروه‌های کاری";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    int i = 1;
}
 

<div class="col-lg-12">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between">
                <h3 class="title">
                    <i class="icon-frane"></i> گروه‌های کاری
                </h3>
                <div>
                    <a class="btn btn-primary rounded" onclick="createLaborWorkingGroup();"><i class="fa-solid fa-plus me-2"></i>گروه کاری جدید</a>
                    <!-- /.portlet-title -->
                    <div class="buttons-box">
                        <i class="icon-size-fullscreen"></i>
                        <div class="paper-ripple">
                            <div class="paper-ripple__background"></div>
                            <div class="paper-ripple__waves"></div>
                        </div>
                    </div>
                </div>
                <!-- /.buttons-box -->
            </div>
            <!-- /.portlet-heading -->
        </div>
        <div class="card-body pt-0">
            <div class="table-responsive">
                <table class="table table-sm table-bordered table-hover table-striped" id="data-table">
                    <thead class="bg-primary">
                        <tr>
                            <th>ردیف</th>
                            <th>نام</th>
                            <th>قیمت</th>
                            <th>توضیحات</th>
                            <th>وضعیت</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.LaborWorkingGroups)
                        {
                            <tr>
                                <td class="align-middle">@(i++)</td>
                                <td class="align-middle">@item.Name</td>
                                <td class="align-middle">@item.Price.ToPrice()</td>
                                <td class="align-middle">@item.Description</td>
                                <td class="align-middle">
                                    <a id="ActivateLaborWorkingGroup@(i)" onclick="ShowQAlert(event,'ActivateLaborWorkingGroup@(i)');"
                                       asp-action="ActivateLaborWorkingGroup"
                                       asp-route-laborWorkingGroupId="@item.Id">
                                        <span class="label px-2 py-1 rounded label-@(item.IsActive ? "success" : "danger")">
                                            @(item.IsActive ? "فعال" : "غیر فعال")
                                        </span>
                                    </a>
                                </td>
                                <td class="align-middle px-2 text-center">
                                    <a class="btn btn-warning px-2 btn-sm btn-icon curve" onclick="editLaborWorkingGroup(@item.Id);"><i class="icon-pencil align-middle fs-6"></i></a>
                                    <a id="DeleteLaborWorkingGroup@(i)" onclick="ShowQAlert(event,'DeleteLaborWorkingGroup@(i)');" class="btn btn-danger px-2 btn-sm btn-icon curve btn-questions"
                                       asp-action="DeleteLaborWorkingGroup" asp-route-laborWorkingGroupId="@item.Id">
                                        <i class="icon-trash fs-6 align-middle fa-flip-horizontal"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


<div id="generalmodal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">ثبت کروه کاری</h4>
                <button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalbody">
                <form asp-action="CreateLaborWorkingGroup" method="post">
                    <input asp-for="CreateLaborWorkingGroupDto.Id" type="hidden" />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="font-weight-semibold">نام</label>
                            <input type="text" asp-for="CreateLaborWorkingGroupDto.Name" class="form-control rounded-lg shadow-sm" required>
                            <span asp-validation-for="CreateLaborWorkingGroupDto.Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="font-weight-semibold">قیمت (ریال)</label>
                            <price-input asp-for="CreateLaborWorkingGroupDto.Price" placeholder="به ریال" required></price-input>
                            <span asp-validation-for="CreateLaborWorkingGroupDto.Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="font-weight-semibold">توضیحات</label>
                            <textarea asp-for="CreateLaborWorkingGroupDto.Description" class="form-control rounded-lg shadow-sm" rows="3"></textarea>
                            <span asp-validation-for="CreateLaborWorkingGroupDto.Description" class="text-danger small"></span>
                        </div>
                        <div class="col-md-12">
                            <div class="input-group">
                                <label>
                                    <input asp-for="CreateLaborWorkingGroupDto.IsActive" class="normal">
                                    فعال/غیرفعال
                                </label>
                            </div>
                            
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-4">
                        <button type="button" class="btn btn-danger rounded px-4" data-bs-dismiss="modal">بازگشت</button>
                        <button type="submit" class="btn btn-success rounded px-4">ذخیره</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section script {
    

    <script>
        $(document).ready(function () {
            //$("#CreateLaborWorkingGroupDto_DeviceId").select2({
            //    dropdownParent: $('#generalmodal')
            //});
        });

        function createLaborWorkingGroup() {
            $("#CreateLaborWorkingGroupDto_Name").val('');

            SetNumber(0, 'CreateLaborWorkingGroupDto_Price');
            $("#CreateLaborWorkingGroupDto_Id").val('');
            $("#CreateLaborWorkingGroupDto_Description").val('');
            $("#CreateLaborWorkingGroupDto_IsActive").prop('checked', true);
            $("#generalmodal").modal('show');
        }

        function editLaborWorkingGroup(id) {
            $.post("@Url.Action("GetLaborWorkingGroupById", "LaborWorkingGroup")", { laborWorkingGroupId: id })
                .done(function (res) {
                    $('#CreateLaborWorkingGroupDto_Name').val(res.name);
                   
                    SetNumber(res.price, 'CreateLaborWorkingGroupDto_Price');
                    $("#CreateLaborWorkingGroupDto_Id").val(res.id);
                    $("#CreateLaborWorkingGroupDto_Description").val(res.description);
                    $("#CreateLaborWorkingGroupDto_IsActive").prop('checked', res.isActive);
                    $("#generalmodal").modal('show');
                });
        }
    </script>
}