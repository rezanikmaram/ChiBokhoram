@model CounterExportOneProductPageDto

@{
	int taliSafafRow = ((Model.PageNumber - 1) * Model.PageSize) + 1;
}

<div id="taliListModal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
	<div class="modal-dialog modal-fullscreen">
		<div class="modal-content">
			<div class="modal-header">
				<h4 class="modal-title"> جزئیات شمارش اسکله   </h4>
				<button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body" id="modalbody">
				<input type="hidden" id="taliWroProductId" value="@Model.WroProductId" />
				<input type="hidden" id="taliStep" value="@(Model.Step ? "true" : "false")" />
				<div class="table-responsive">
					<table class="table table-sm table-bordered table-hover table-striped" id="data-table">
						<thead class="bg-primary">
							<tr>
								<th class="px-1 text-center">#</th>
								<th class="px-1 text-center">تاریخ</th>
                                <th class="px-1 text-center">@(Model.IsSelfTransported ? "شماره شاسی" : "کامیون")</th>
                                <th class="px-1 text-center">گروه کارگری</th>
                                <th class="px-1 text-center">نام تجهیز</th>
                                <th class="px-1 text-center">کاربر</th>
                                <th class="px-1 text-center">تعداد</th>
                                <th class="px-1 text-center">تعداد مشکل دار</th>
                                <th class="px-1 text-center">دبل کرن</th>
                                <th class="px-1 text-center">شناور (شماره سفر)</th>
								<th class="px-1 text-center">توضیحات</th>
								<th class="px-1 text-center">وضعیت</th>
								<th class="px-1 text-center">فایل ها</th>
								<th class="px-1 text-center">عملیات</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var item in Model.List)
							{
								<tr>
									<td class="align-middle px-2 text-center">@(taliSafafRow++)</td>
									<td class="align-middle px-2 text-center" dir="ltr">@item.DateFa</td>
                                    <td class="align-middle px-2 text-center">@(Model.IsSelfTransported ? Model.VehicleIdentificationNumber : item.CarPlates)</td>
                                    <td class="align-middle px-2 text-center">@item.LaborWorkingGroupName</td>
                                    <td class="align-middle px-2 text-center">@item.GearName</td>
                                    <td class="align-middle px-2 text-center">@item.UserFullName</td>
                                    <td class="align-middle px-2 text-center">@item.Count.ToPrice()</td>
                                    <td class="align-middle px-2 text-center">@(item.CountProblem > 0 ? item.CountProblem.ToPrice() : "---")</td>
                                    <td class="align-middle px-2 text-center">@(item.IsUsingDualCrane ? "بله" : "خیر")</td>
                                    <td class="align-middle px-2 text-center">@item.VoyageName</td>
									<td class="align-middle px-2 text-center">@item.Description</td>
									<td class="align-middle px-2 text-center">
										<span class="label px-2 py-1 rounded label-@(!item.IsProblem ? "success" : "danger")">
											@(!item.IsProblem ? "سالم" : "مشکل دار")
										</span>
									</td>
									<td class="align-middle px-2 text-center">
										@if (item.Files?.Any() == true)
										{
											for (int fileIndex = 0; fileIndex < item.Files.Count; fileIndex++)
											{
												<a asp-action="TaliFile"
												   asp-route-TaliProductId="@item.InlandExportManifestCounterProductId"
												   asp-route-FileName="@item.Files[fileIndex].FileName"
												   class="btn btn-primary p-2 py-0 mb-1" target="_blank">فایل @(fileIndex + 1)</a>
											}
										}
									</td>
									<td class="align-middle px-2 text-center">
										@if (item.HasCheckList)
										{
											<button class="btn btn-sm btn-info px-2" onclick="showCheckListModal(this, '@item.InlandExportManifestCounterProductId')" title="چک لیست">
												<i class="fa-solid fa-list-check"></i>
											</button>
										}
										@if (item.HasEditHistory)
										{
											<button class="btn btn-sm btn-warning px-2" onclick="showEditHistoryModal(this, '@item.InlandExportManifestCounterId')" title="تاریخچه ویرایش">
												<i class="fa-solid fa-clock-rotate-left"></i>
											</button>
										}
									</td>
								</tr>
							}
							@if (!Model.List.Any())
							{
								<tr>
                                    <td colspan="14" class="text-center">موردی یافت نشد</td>
								</tr>
							}
						</tbody>
					</table>
				</div>

				@if (Model.TotalItems > Model.PageSize)
				{
					var totalPages = (int)Math.Ceiling(Model.TotalItems / (double)Model.PageSize);
					<nav class="mt-3">
						<ul class="pagination justify-content-center mb-0">
							<li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
								<a class="page-link" href="#" data-page="1">ابتدا</a>
							</li>
							<li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
								<a class="page-link" href="#" data-page="@(Model.PageNumber - 1)">قبلی</a>
							</li>
							@for (int p = 1; p <= totalPages; p++)
							{
								<li class="page-item @(p == Model.PageNumber ? "active" : "")">
									<a class="page-link" href="#" data-page="@p">@p</a>
								</li>
							}
							<li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
								<a class="page-link" href="#" data-page="@(Model.PageNumber + 1)">بعدی</a>
							</li>
							<li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
								<a class="page-link" href="#" data-page="@totalPages">انتها</a>
							</li>
						</ul>
					</nav>
				}
			</div>
		</div>
	</div>
</div>

<script>
	$('#taliListModal').on('click', '.page-link', function (e) {
		e.preventDefault();
		var page = $(this).data('page');
		var wroProductId = $('#taliWroProductId').val();
		var step = $('#taliStep').val();
		var $oldModal = $('#taliListModal');
		$.post('@Url.Action("GetListCounterOneProduct", "WarehouseReceiptOutbound")', {
			swrProductId: wroProductId,
			step: step,
			page: page,
			pageSize: 50
		}).done(function (html) {
			$oldModal.modal('hide');
			$oldModal.one('hidden.bs.modal', function () {
				$('#generalModalContent').html(html);
				$('#taliListModal').modal('show');
			});
		}).fail(function () {
			showAlert2('خطا در بارگذاری صفحه', 1);
		});
	});

	function showInfoModal(title, content) {
		$('#modalTitle').text(title);
		$('#modalBody').html(content);
		$('#modalFooter').html('<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">بستن</button>');
		$('#generalModal').modal('show');
	}

	function showCheckListModal(btn, counterProductId) {
		var $btn = $(btn);
		var originalHtml = $btn.html();
		$btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');
		$('#taliListModal').modal('hide');
		$('#generalModal').one('hidden.bs.modal', function () {
			$('#taliListModal').modal('show');
		});
		$.post('@Url.Action("GetCheckListFactorsPartial", "WarehouseReceiptOutbound")', { counterProductId: counterProductId })
			.done(function (html) {
				showInfoModal('چک لیست', html);
				$btn.prop('disabled', false).html(originalHtml);
			})
			.fail(function () {
				showAlert2('خطا در بارگذاری چک لیست', 1);
				$btn.prop('disabled', false).html(originalHtml);
				$('#taliListModal').modal('show');
			});
	}

	function showEditHistoryModal(btn, counterId) {
		var $btn = $(btn);
		var originalHtml = $btn.html();
		$btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');
		$('#taliListModal').modal('hide');
		$('#generalModal').one('hidden.bs.modal', function () {
			$('#taliListModal').modal('show');
		});
		$.post('@Url.Action("GetEditHistoryPartial", "WarehouseReceiptOutbound")', { counterId: counterId })
			.done(function (html) {
				showInfoModal('تاریخچه ویرایش', html);
				$btn.prop('disabled', false).html(originalHtml);
			})
			.fail(function () {
				showAlert2('خطا در بارگذاری تاریخچه ویرایش', 1);
				$btn.prop('disabled', false).html(originalHtml);
				$('#taliListModal').modal('show');
			});
	}
</script>
