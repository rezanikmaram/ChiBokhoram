@model WarehouseReceiptOutboundInfoDto
 
<div class="card">

	<div class="card-body pt-0 ">
		<div class="bg-primary rounded-3 mt-4 p-3">
			<div class="row gy-3 align-items-center">
				<div class="col-1">
					<img src="~/assets/images/GoodsClearance.png" alt="" class="img-fluid">
				</div>
				<div class="col-3">
					<p class="fs-6 fw-bold">شماره پروانه : @(Model.CaseNumber) </p>
					<p class="fs-6 fw-bold">تاریخ : @Model.IssueDateFa</p>
				</div>
				<div class="col-3">
					<p class="fs-6 fw-bold">شرکت: @Model.CompanyAndSwrNumber</p>
					<p class="fs-6 fw-bold">نماینده قانونی: @Model.Agent</p>
				</div>
				<div class="col-3">
					<p class="fs-6 fw-bold">مبدا: @Model.Origin</p>
					<p class="fs-6 fw-bold"> مقصد: @Model.Destination</p>
				</div>
			</div>
		</div>
	</div>

</div>