@model List<CounterProductCheckListFactorDto>

<div class="table-responsive">
    <table class="table table-sm table-bordered table-hover table-striped mb-0">
        <thead class="bg-primary">
            <tr>
                <th>#</th>
                <th>عنوان</th>
                <th>وجود دارد</th>
                <th>توضیحات</th>
            </tr>
        </thead>
        <tbody>
            @if (Model?.Any() == true)
            {
                int i = 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center">@(i++)</td>
                        <td>@item.Title</td>
                        <td class="text-center">
                            <span class="label px-2 py-1 rounded label-@(item.IsExists ? "success" : "danger")">
                                @(item.IsExists ? "بله" : "خیر")
                            </span>
                        </td>
                        <td>@item.Description</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">چک لیستی ثبت نشده است</td>
                </tr>
            }
        </tbody>
    </table>
</div>
