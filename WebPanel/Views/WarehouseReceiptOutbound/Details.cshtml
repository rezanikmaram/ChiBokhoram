		// ==================== COUNTER VALIDATION STATUS FUNCTIONS ====================

		// Handle confirm button click for validation status change
		$('#counterConfirmStatusChange').on('click', function() {
			var counterId = $(this).data('counterId');
			var newStatus = $(this).data('newStatus');
			var description = $('#counterValidationStatusDescription').val();

			$('#counterValidationStatusModal').modal('hide');

			$.post("@Url.Action("ChangeCounterValidationStatus", "WarehouseReceiptOutbound")", {
				counterId: counterId,
				validationStatus: newStatus,
				description: description
			})
			.done(function (res) {
				if (res.success) {
					refreshCurrentSection();
				} else {
					alert('خطا در به‌روزرسانی وضعیت: ' + (res.message || 'خطای نامشخص'));
				}
			})
			.fail(function (xhr, status, error) {
				alert('خطا در ارتباط با سرور: ' + error);
			});
		});

		function changeCounterValidationStatus(counterId, newStatus) {
			if (counterId == null) return;
			$('#counterConfirmStatusChange').data('counterId', counterId);
			$('#counterConfirmStatusChange').data('newStatus', newStatus);
			$('#counterValidationStatusDescription').val('');
			$('#counterValidationStatusModal').modal('show');
		}

		function showCounterValidationHistory(counterId) {
			var historyData = window.__counterValidationHistoryData || [];

			// Filter history for this specific counter
			var counterHistory = historyData.filter(function(h) {
				return (h && h.counterId && h.counterId.toLowerCase() === counterId.toLowerCase()) ||
					   (h && h.CounterId && h.CounterId.toLowerCase() === counterId.toLowerCase());
			});

			// Build the history table HTML
			var html = '';
			if (!counterHistory || counterHistory.length === 0) {
				html = '<div class="alert alert-info text-center">تاریخچه‌ای برای این بارگیری یافت نشد.</div>';
				html += '<div class="text-center text-muted small mt-2">برای مشاهده تاریخچه، ابتدا وضعیت تأیید را تغییر دهید.</div>';
			} else {
				html = '<div class="table-responsive"><table class="table table-striped table-hover">';
				html += '<thead class="table-dark"><tr>';
				html += '<th>تاریخ</th>';
				html += '<th>کاربر</th>';
				html += '<th>وضعیت قبلی</th>';
				html += '<th>وضعیت جدید</th>';
				html += '<th>توضیحات</th>';
				html += '</tr></thead><tbody>';

				counterHistory.forEach(function(h) {
					var oldStatus = h.oldStatus !== undefined ? h.oldStatus : h.OldStatus;
					var newStatus = h.newStatus !== undefined ? h.newStatus : h.NewStatus;
					var changedDate = h.changedDateFa !== undefined ? h.changedDateFa : h.ChangedDateFa;
					var description = h.description !== undefined ? h.description : h.Description;
					var changedByUser = h.changedByUserFullName !== undefined ? h.changedByUserFullName : h.ChangedByUserFullName;

					var oldStatusText = oldStatus === 0 ? "معتبر" : "غیرمعتبر";
					var newStatusText = newStatus === 0 ? "معتبر" : "غیرمعتبر";
					var oldStatusClass = oldStatus === 0 ? "text-success" : "text-danger";
					var newStatusClass = newStatus === 0 ? "text-success" : "text-danger";

					html += '<tr>';
					html += '<td>' + changedDate + '</td>';
					html += '<td>' + changedByUser + '</td>';
					html += '<td class="' + oldStatusClass + ' fw-bold">' + oldStatusText + '</td>';
					html += '<td class="' + newStatusClass + ' fw-bold">' + newStatusText + '</td>';
					html += '<td>' + (description || '-') + '</td>';
					html += '</tr>';
				});

				html += '</tbody></table></div>';
			}

			$('#counterValidationHistoryContent').html(html);
			$('#counterValidationHistoryModal').modal('show');
		}
	</script>
