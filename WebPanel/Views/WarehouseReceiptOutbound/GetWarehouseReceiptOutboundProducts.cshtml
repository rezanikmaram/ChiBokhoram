@model SeoWarehouseReceiptOutboundPageDto
@{
    ViewData["Title"] = "افزودن کالا جهت خروج";
    Layout = "~/Views/Shared/AdminLayout.cshtml";

}

<div class="card">

    <div class="card-body pt-0 ">
        <div class="bg-primary rounded-3 mt-4 p-3">
            <div class="row gy-3 align-items-center">
                <div class="col-1">
                    <img src="~/assets/images/GoodsClearance.png" alt="" class="img-fluid">
                </div>
                <div class="col-3">
                    <p class="fs-6 fw-bold">شماره پروانه : @(Model.PageInfo.CaseNumber) </p>
                    <p class="fs-6 fw-bold">تاریخ : @Model.PageInfo.IssueDateFa</p>
                </div>
                <div class="col-3">
                    <p class="fs-6 fw-bold">شرکت: @Model.PageInfo.CompanyAndSwrNumber</p>
                    <p class="fs-6 fw-bold">نماینده قانونی: @Model.PageInfo.Agent</p>
                </div>
                <div class="col-3">
                    <p class="fs-6 fw-bold">مبدا: @Model.PageInfo.Origin</p>
                    <p class="fs-6 fw-bold"> مقصد: @Model.PageInfo.Destination</p>
                </div>
            </div>
        </div>
    </div>

</div>

<div class="col-lg-12">
    <div class="card">
        <div class="card-header pb-0">
            <div class="d-flex justify-content-between align-items-center">

                <h3 class="title">
                    <i class="icon-frane"></i>
                    <a asp-action="Details" asp-route-wroId="@Model.PageInfo.Id"><i class="fa-solid fa-right-to-bracket me-2"></i></a>
                    لیست کالاها
                </h3>
                <div class="d-flex align-items-center">

                    <a style="border-radius:5px; margin:0px 10px" onclick="showCreateWarehouseReceiptOutboundProductModal()"
                       class="btn btn-success d-md-block d-none">
                        <i class="icon-plus"></i>
                        افزودن کالا جهت خروج
                    </a>
                </div>

            </div>
        </div>
        <div class="card-body">
            <div class="col-lg-12">
                <div class="col-lg-12">
                    <div class="table-responsive vh-100 px-3">
                        <table class="table table-bordered table-hover table-striped" id="products-data-table">
                            <thead class="bg-primary">
                                <tr>
                                    <th class="align-middle">ردیف</th>
                                    <th class="align-middle">شماره پرونده</th>
                                    <th class="align-middle">شماره قبض انبار</th>
                                    <th class="align-middle">بارنامه</th>
                                    <th class="align-middle">نام کالا</th>
                                    <th class="px-0"><div class="px-3">تعداد</div> <hr class="my-1" /> <div class="px-3">باقیمانده</div></th>
                                    <th class="px-0"><div class="px-3">وزن خالص</div> <hr class="my-1" /> <div class="px-3">باقیمانده</div></th>
                                    <th class="align-middle">حجم</th>
                                    <th class="align-middle">عملیات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int j = 1;
                                }
                                @foreach (var product in Model.List)
                                {
                                    <tr>
                                        <td class="align-middle">@(j++)</td>
                                        <td class="align-middle">@product.SeoWarehouseReceiptOutboundCaseNumber</td>
                                        <td class="align-middle">
                                            <a target="_blank" asp-action="SeoWarehouseReceipt" asp-controller="Seo"
                                               asp-route-seoId="@product.SeoId">
                                                @product.SeoWarehouseReceiptNumber
                                            </a>

                                        </td>
                                        <td class="align-middle">
                                            <a target="_blank" asp-action="seoAccessPage" asp-controller="Seo"
                                               asp-route-seoId="@product.SeoId">
                                                @product.SeoWarehouseReceiptBillOfLadingNumber
                                            </a>
                                        </td>
                                        <td class="align-middle">@product.ProductName</td>
                                        <td class="align-middle px-0">
                                            <div class="px-3">@product.Count.ToPrice()</div>
                                            <hr class="my-1" />
                                            <div class="px-3">@product.RemainingCount.ToPrice()</div>
                                        </td>
                                        <td class="align-middle px-0">
                                            <div class="px-3">@product.Weight.ToPrice()</div>
                                            <hr class="my-1" />
                                            <div class="px-3">@product.RemainingWeight.ToPrice()</div>
                                        </td>

                                        <td class="align-middle">@product.Volume</td>
                                        <td class="align-middle">
                                            <a onclick="editWarehouseReceiptOutboundProduct('@product.SeoWarehouseReceiptOutboundProductId')" class="btn btn-primary px-2 my-2 rounded">
                                                <i class="fa-solid fa-edit"></i> ویرایش
                                            </a>
                                            @*  <a onclick="deleteOutboundProduct('@product.Id')" class="btn btn-danger px-2 my-2 rounded">
                                        <i class="fa-solid fa-trash"></i> حذف
                                        </a> *@
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<div id="generalmodal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">ثبت کالا جهت خروج</h4>
                <button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalbody">
                <partial name="_CreateWarehouseReceiptOutboundProduct" model="@Model.CreateDto" />

            </div>
        </div>
    </div>
</div>

@section script {
    <script>


        $(document).ready(function () {
            $('.select2').select2();

            $('select[class*="generalmodal"].select2').select2({
                dropdownParent: $('#generalmodal')
            });



        });

        function showCreateWarehouseReceiptOutboundProductModal() {
            $("#Id").val('');
            $('#generalmodal').modal('show')
        }


        function editWarehouseReceiptOutboundProduct(outboundProductId) {

            $.post("@Url.Action("GetWarehouseReceiptOutboundProductById", "WarehouseReceiptOutbound")", { warehouseReceiptOutboudnProductId: outboundProductId })
                .done(function (res) {
                    $('#modalbody').html(res)

                    $("#generalmodal").modal('show');
                });

        }


    </script>
}