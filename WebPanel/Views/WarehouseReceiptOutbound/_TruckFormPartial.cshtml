@model CreateWroTruckPageDto

<form onsubmit="return submitTruckForm(this);">
    <input type="hidden" asp-for="CreateDto.Id" />
    <input type="hidden" asp-for="CreateDto.SeoWarehouseReceiptOutboundId" />

    <div class="row gy-3">
        <div class="form-group col-md-12">
            <label>مجوز پایانه</label>
            <select class="form-control select2" asp-for="CreateDto.DocumentId" asp-items="Model.MojavesPayanes">
                <option value="">در صورت داشتن مجوز پایانه، مجوز را انتخاب کنید</option>
            </select>
        </div>

        <div class="form-group col-md-12">
            <label>نوع پلاک</label>
            <select class="form-control" asp-for="CreateDto.CarPlatesType" id="carPlatesType">
                <option value="1">پلاک ملی</option>
                <option value="2">پلاک بندری</option>
            </select>
        </div>

        <div id="CarPlatesTypeMeli" class="row mt-3 @(Model.CreateDto.CarPlatesType == Common.enumeration.CarPlatesType.Number ? "d-none" : "")">
            <div class="col-md-3">
                <label>ایران</label>
                <input type="text" class="form-control" asp-for="CreateDto.CarPlatesAreaCode" placeholder="ایران" maxlength="2" />
            </div>
            <div class="col-md-3">
                <label>عدد 3 رقمی</label>
                <input type="text" class="form-control" asp-for="CreateDto.CarPlatesRight" placeholder="عدد" maxlength="3" />
            </div>
            <div class="col-md-3">
                <label>حرف</label>
                <select class="form-control select2" asp-for="CreateDto.CarPlatesMiddle">
                    <option value="ع">ع</option>
                    <option value="ک">ک</option>
                    <option value="الف">الف</option>
                    <option value="ب">ب</option>
                    <option value="ت">ت</option>
                    <option value="ج">ج</option>
                    <option value="د">د</option>
                    <option value="س">س</option>
                    <option value="ص">ص</option>
                    <option value="ط">ط</option>
                    <option value="ق">ق</option>
                    <option value="ل">ل</option>
                    <option value="م">م</option>
                    <option value="ن">ن</option>
                    <option value="و">و</option>
                    <option value="ه">ه</option>
                    <option value="ی">ی</option>
                    <option value="پ">پ</option>
                    <option value="گ">گ</option>
                    <option value="ف">ف</option>
                    <option value="ش">ش</option>
                    <option value="ث">ث</option>
                    <option value="ز">ز</option>
                </select>
            </div>
            <div class="col-md-3">
                <label>عدد 2 رقمی</label>
                <input type="text" class="form-control" asp-for="CreateDto.CarPlatesLeft" placeholder="عدد" maxlength="2" />
            </div>
        </div>

        <div id="CarPlatesTypeBandari" class="col-md-12 @(Model.CreateDto.CarPlatesType != Common.enumeration.CarPlatesType.Number ? "d-none" : "")">
            <label>پلاک بندری</label>
            <input type="text" class="form-control" asp-for="CreateDto.CarPlates" placeholder="شماره پلاک بندری" />
        </div>
    </div>
</form>

<script>
    $(document).ready(function () {
        $('#generalModal .select2').select2({
            dropdownParent: $('#generalModal')
        });

        $('#carPlatesType').change(function () {
            if ($(this).val() === "2") {
                $('#CarPlatesTypeMeli').addClass('d-none');
                $('#CarPlatesTypeBandari').removeClass('d-none');
            } else {
                $('#CarPlatesTypeMeli').removeClass('d-none');
                $('#CarPlatesTypeBandari').addClass('d-none');
            }
        });
    });
</script>
