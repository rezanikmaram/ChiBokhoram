@model SeoContainerProductManageDto


@{
	ViewData["Title"] = "مدیریت کالاها درون کانتینر";
	Layout = "~/Views/Shared/AdminLayout.cshtml";
	int i = 1;
}
<div class="col-md-12">
	<div class="p-3 bg-white rounded-3 border-0">
		<div class="d-flex justify-content-between">
			<div>
				<span>
					<i class="icon-frane"></i>
					<a asp-controller="Seo" asp-action="ProductManage" asp-route-seoId="@Model.SeoId"><i class="fa-solid fa-right-to-bracket align-middle me-2"></i></a>
					مدیریت کالاها درون کانتینر
				</span>

				<span class="label label-primary p-1 mx-2 rounded"> شماره بارنامه: @Model.BillOfLadingNumber</span>

				<span class="label label-info p-1 rounded mx-2">@Model.SeoProductDto.ContainerNumber </span>
				
				<span class="label label-info p-1 rounded mx-2">پلمپ  @Model.SeoProductDto.ContainerSealNumber</span>
			</div>
		</div>

		<!-- /.breadcrumb-left -->
	</div><!-- /.breadcrumb-box -->
</div>
<div class="  justify-content-between mt-4">
