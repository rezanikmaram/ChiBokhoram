@section script {
    <script>
                $(document).ready(function () {

                    $('.select2').select2();

                    $('select[class*="ReportMonthlyComparison"].select2').select2({
                        dropdownParent: $('#ReportMonthlyComparisonModalId')
                    });

                    $('select[class*="MonthlyReport"].select2').select2({
                        dropdownParent: $('#ReportMonthlyModal')
                    });

                    $('select[class*="ReportListAllocation"].select2').select2({
                        dropdownParent: $('#ReportListAllocationModal')
                    });

                    $('select[class*="ReportShipInLangargah"].select2').select2({
                        dropdownParent: $('#ReportShipInLangargahModal')
                    });

                    $("#VoyageIdForCreateSeo").select2({
                        dropdownParent: $('#AddSeoModal')
                    });

                    // کد جدید برای تغییر حالت نمایش
                    $('#cardView').hide();
                    $('#tableView').show();

                    $('#discharge').change(function() {
                        if ($(this).is(':checked')) {
                            $('#cardView').show();
                            $('#tableView').hide();
                        }
        });

                    $('#loading').change(function() {
                        if ($(this).is(':checked')) {
                            $('#cardView').hide();
                            $('#tableView').show();
                        }
        });

                });

                kamaDatepicker('Filter_DateFrom', customOptions);
                kamaDatepicker('Filter_DateTo', customOptions);
                kamaDatepicker('DateReportDailyId', customOptions);
    </script>


    <script>
        $(".page-link").click(function (event) {
            event.preventDefault(); // غیرفعال کردن عملکرد پیشفرض href

            var hrefValue = $(this).attr("href");
            $("#pageNumber").val(hrefValue.split("p=")[1]);
            $("#formFilter").submit();
        });
    </script>


    <script>
        function ShowModalAddSeo(event) {
            event.preventDefault();

            $("#AddSeoModal").modal('show');
        }

        function ShowModalReportDaily(event) {
            event.preventDefault();

            $("#ReportDailyModal").modal('show');
        }

        function GetReportDaily(event) {
            $("#ReportDailyModal").modal('hide');
            $("#GetDailyReportPierOperationsExcelId").submit();
        }

        function ShowModalReportMonthly(event) {
            event.preventDefault();

            $("#ReportMonthlyModal").modal('show');
        }

        function GetReportMonthly(event) {
            $("#ReportMonthlyModal").modal('hide');
            $("#GetReportMonthlyExcelId").submit();
        }


        function ShowModalReportShipInLangargah(event) {
            event.preventDefault();

            $("#ReportShipInLangargahModal").modal('show');
        }

        function GetReportShipInLangargah(event) {
            $("#ReportShipInLangargahModal").modal('hide');
            $("#GetReportShipInLangargahId").submit();
        }


         function ShowModalReportListAllocation(event) {
            event.preventDefault();

            $("#ReportListAllocationModal").modal('show');
        }

        function GetReportListAllocation(event) {
            $("#ReportListAllocationModal").modal('hide');
            let selectValue = document.getElementById("listAllocationReportType").value;

            if(selectValue == 0)
                $("#pdf1").click();
            else if(selectValue == 1)
                $("#excel1").click();

        }

         function ShowModalReportMonthlyComparison(event) {
            event.preventDefault();

            $("#ReportMonthlyComparisonModalId").modal('show');
        }

        function GetReportMonthlyComparisonExcelReport() {
            $("#ReportMonthlyComparisonModalId").modal('hide');
            $("#ReportMonthlyComparisonExcelReportId").submit();
        }

        function GetReportSeasonalComparisonExcelReport() {
            $("#ReportMonthlyComparisonModalId").modal('hide');
            $("#ReportSeasonalComparisonExcelReportId").submit();
        }

    </script>
}
