@{
    ViewData["Title"] = "بستن عملیات";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

@section style {

}


<div class="row">
    <div class="card">
        <div class="card-header pb-0">
            <div class="d-flex justify-content-between">
                <h3 class="title">
                    <i class="icon-anchor"></i> بستن CHO(@ViewBag.seoCode)
                </h3>
            </div>
        </div>
        <hr>
        <div class="card-body pt-0">
            <form asp-action="ClosingSeo" method="post">
                <input name="seoId" type="hidden" value="@ViewBag.seoId" />
                <div class="row">
                    <div class="form-body col-9 report-main">
                        <ul class="d-flex justify-content-between col-md-6">
                            <li class="col-md-5 ">
                                <div class="form-group">
                                    <label>تاریخ اتمام عملیات:</label>
                                    <div class="input-group">
                                        <input name="date" id="date" type="text" class=" form-control" autocomplete="off" required>
                                    </div>
                                </div>
                            </li>

                            <li class="col-md-5 ">
                                <div class="form-group clockpicker">
                                    <label>ساعت اتمام عملیات:</label>
                                    <div class="input-group ">
                                        <input name="timeEnd" id="timeEnd" type="text" class=" form-control" autocomplete="off" required>
                                    </div>
                                </div>
                            </li>
                        </ul>
                    </div>
                    <div class="col-12">
                        <div class="media report-perfom" style="float: left;">
                            <div class="form-actions">
                                <button type="submit" class="btn btn-info btn-round">
                                    <i class="icon-check"></i>
                                    ذخیره
                                    <div class="paper-ripple"><div class="paper-ripple__background"></div><div class="paper-ripple__waves"></div></div>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
            <section class="fix"></section>
        </div>
    </div>
</div>
@section script {
 
<script>

    $(document).ready(function () {

        $('.clockpicker').clockpicker({
            placement: 'bottom',
            align: 'left',
            donetext: 'تایید'
        });
    });

    
    kamaDatepicker('date', customOptions);

</script>
    }


