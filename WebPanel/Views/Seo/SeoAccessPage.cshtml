@model SeoAccessPageDto
@{
    ViewData["Title"] = "مدیریت بارنامه";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    bool isModal = ViewBag.IsModal == true;
    bool returnPageToVoyage = (int)ViewBag.returnPage == 100 && Model?.SeoInfo?.VoyageId != null;

    string CollapsClassName = ViewBag.IsEmpty == true ? "show" : "";
    string aria_expandedValue = ViewBag.IsEmpty == true ? "true" : "false";

    var color = "";
    var imageSrc = "";
    switch (Model.SeoInfo.State)
    {
        case SeoState.Active:
            color = "bg-primary";
            imageSrc = "craneShip.png";
            break;
        case SeoState.Stoped:
            color = "bg-warning";
            imageSrc = "ship.png";
            break;
        case SeoState.Finish:
            color = "bg-success2";
            imageSrc = "Eship.png";
            break;
        default:
            color = "bg-primary";
            imageSrc = "craneShip.png";
            break;

    }
}
<div class="row">
    <div class="card">
        <div class="card-header pb-0 px-3">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="title">
                    <i class="icon-frane"></i>
                    @if (returnPageToVoyage)
                    {
                        <a asp-controller="Voyage" asp-action="VoyageSeo" asp-route-voyageId="@Model.SeoInfo.VoyageId"><i class="fa-solid fa-right-to-bracket me-2"></i></a>
                    }
                    else
                    {
                        <a asp-action="Index"><i class="fa-solid fa-right-to-bracket me-2"></i></a>
                    }

                    مدیریت بارنامه
                </h3>
                <div class="d-flex align-items-center">

                    @if (Model?.SeoInfo?.VoyageId != null)
                    {
                        <a asp-controller="Voyage" asp-action="VoyageSeo" asp-route-voyageId="@Model.SeoInfo.VoyageId" class="me-2 btn btn-primary"><i class="fas fa-anchor me-2 align-middle"></i> مشاهده سفر </a>
                    }

                    @if (Model?.SeoInfo?.VoyageId == null)
                    {
                        <a asp-action="CreateSeoOld" asp-route-SeoId="@Model.SeoInfo.Id" class="me-2 btn btn-info"><i class="fa-regular fa-pen-to-square me-2 align-middle"></i> ویرایش </a>
                    }

                    @if (User.IsInRole("admin") || User.IsInRole("adminOnePort"))
                    {
                        <a asp-action="SeoView" asp-route-seoId="@Model.SeoInfo.Id" class="me-2 btn btn-info"><i class="fa-regular fa-circle-info align-middle"></i> نمای کلی </a>

                        <a id="DeleteSeo" onclick="ShowQAlert(event,'DeleteSeo', 'حذف بارنامه' , 'آیا از حذف این بارنامه مطمئن هستید');" asp-controller="Seo" asp-action="DeleteSeo" asp-route-seoId="@Model.SeoInfo.Id" asp-route-VoyageId="@(returnPageToVoyage ? Model.SeoInfo.VoyageId : null)" class=" btn btn-danger"><i class="icon-trash fa-flip-horizontal"></i> حذف </a>

                        @if (Model.SeoInfo.State != SeoState.Finish)
                        {
                            <a id="CloseSeo" onclick="ShowQAlert(event,'CloseSeo' , 'اتمام و بستن بارنامه', 'آیا مایل به بستن بارنامه هستید');" asp-controller="Seo" asp-action="ClosingSeo" asp-route-seoId="@Model.SeoInfo.Id" class=" btn mx-2 btn-success"><i class="fa-solid fa-check me-2 align-middle"></i>اتمام عملیات</a>

                            @* @if (!Model.AlloMinInfo.CanCloseSeo)
							{
								<a onclick="ErrorAllocationNotFinish()" class=" btn mx-2 btn-success"><i class="fa-solid fa-check me-2 align-middle"></i>اتمام عملیات</a>
							}
							else
							{
								<a id="CloseSeo" onclick="ShowQAlert(event,'CloseSeo' , 'اتمام و بستن بارنامه', 'آیا مایل به بستن بارنامه هستید');" asp-controller="Seo" asp-action="ClosingSeo" asp-route-seoId="@Model.SeoInfo.Id" class=" btn mx-2 btn-success"><i class="fa-solid fa-check me-2 align-middle"></i>اتمام عملیات</a>
							} *@
                        }

                        @if (Model.SeoInfo.State == SeoState.Stoped)
                        {
                            <a class="btn btn-primary" id="StartSeo" onclick="ShowQAlert(event,'StartSeo', 'شروع مجدد', 'آیا از شروع مجدد بارنامه مطمئن هستید');" asp-controller="Seo" asp-action="StartSeo" asp-route-seoId="@Model.SeoInfo.Id"> از سرگیری CHO</a>
                        }
                    }
                </div>
            </div>
            <div class="row">
            </div>
        </div>
        <div class="card-body pt-0 px-2">
            <div class="@color rounded-3 mt-4 p-3">
                <div class="row gy-3 align-items-center">
                    <div class="col-1">
                        <img src="~/assets/images/@imageSrc" alt="" class="img-fluid">
                    </div>
                    <div class="col-3">
                        <p class="fs-6 fw-bold">@Model.SeoInfo.ShipShipName (@Model.SeoInfo.BillOfLadingNumber)</p>
