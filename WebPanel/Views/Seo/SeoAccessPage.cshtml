@section script {
    <partial name="_ProductManageScripts" />
    <partial name="~/Views/Company/_AddCompanyScript.cshtml" />
    <partial name="~/Views/Product/_AddProductScript.cshtml" />

    <script>

            $(document).ready(function () {

                $(".select2").select2();

                kamaDatepicker('FristStepSeo_ShipEntranceDateFa', customOptions);
                 
            });
             
             
            function ErrorEmptyForm() {

                Toast.fire({
                    icon: 'error',
                    title: 'بخش تکمیل مشخصات را پر کنید'
                });
            }


            function ErrorAllocationNotFinish() {

                Toast.fire({
                    icon: 'error',
                    title: 'تخلیه و بارگیری به اتمام نرسیده است'
                });
            }

            function ErrorSeoNotVoyage() {

                Toast.fire({
                    icon: 'error',
                    title: 'این بارنامه در یک سفر تعریف نشده است'
                });
            }

            function openSeoProductModal(seoId) {
                const modalEl = document.getElementById('seoProductManageModal');
                if (!modalEl) {
                    return;
                }
                loadSeoProductModalContent(seoId);
                const modalInstance = bootstrap.Modal.getOrCreateInstance(modalEl);
                modalInstance.show();
            }

            function loadSeoProductModalContent(seoId) {
                const body = $("#seoProductModalBody");
                body.html(`<div class="text-center py-5">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-3 mb-0">در حال بارگذاری ...</p>
                            </div>`);

                $.get('@Url.Action("ProductManageModal", "Seo")', { seoId: seoId, _: Date.now() })
                    .done(function (html) {
                        body.html(html);
                        if (window.seoProductManager) {
                            try {
                                window.seoProductManager.init('#productManageWrapper', {
                                    mode: 'modal',
                                    seoId: seoId,
                                    onReload: function () { loadSeoProductModalContent(seoId); }
                                });
                            } catch (e) {
                                console.error('Error initializing product manager:', e);
                                body.html('<div class="alert alert-danger mb-0"><i class="fa-solid fa-circle-exclamation me-2"></i>خطا در راه‌اندازی مدیریت کالا: ' + e.message + '</div>');
                            }
                        } else {
                            body.html('<div class="alert alert-warning mb-0"><i class="fa-solid fa-triangle-exclamation me-2"></i>سیستم مدیریت کالا یافت نشد</div>');
                        }
                    })
                    .fail(function (xhr) {
                        var errorMsg = 'خطا در دریافت اطلاعات کالا';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMsg = xhr.responseJSON.message;
                        } else if (xhr.statusText) {
                            errorMsg = errorMsg + ' (' + xhr.statusText + ')';
                        }
                        body.html('<div class="alert alert-danger mb-0"><i class="fa-solid fa-circle-exclamation me-2"></i>' + errorMsg + '</div>');
                    });
            }

            $('#seoProductManageModal').on('hidden.bs.modal', function (e) {
                if (e.target === this) {
                    if (window.seoProductManager && window.seoProductManager.unbindEvents) {
                        window.seoProductManager.unbindEvents();
                    }
                    if (window.seoProductManager && window.seoProductManager.reset) {
                        window.seoProductManager.reset();
                    }
                    $("#seoProductModalBody").html('');
                }
            });

    </script>
}
