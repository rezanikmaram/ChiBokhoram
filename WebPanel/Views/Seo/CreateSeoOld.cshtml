        $("#ShipId").select2().trigger('change');
        $("#ShipingCompanyId").select2().trigger('change');
        // $("#CompanyPortOperatorId").select2().trigger('change');
        $("#TransportType").select2().trigger('change');
        $("#SeoShipState").select2().trigger('change');


        kamaDatepicker('ContractDateFa', customOptions);
    </script>
