@model CreateCheckListFactorDto


<form asp-action="CreateCheckListFactor" method="post">
	<input asp-for="Id" type="hidden" />
	<div class="card-body pt-0">

		<div class="row">
			<div class="col-md-12">
				<div class="form-body">

					<div class="justify-content-between row gy-4">
						<div class="col-md-12">
							<div class="form-group">
								<label>نام شاخص چک لیست</label>
								<div class="input-group">
									<input type="text" class="form-control rounded" asp-for="Title">
									<span asp-validation-for="Title" class="text-danger"></span>
								</div>
							</div>
						</div>
					</div>
					<div class="modal-footer border-0 px-0">
						<button type="submit" class="btn btn-success btn-round">ذخیره</button>
						<button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>
					</div>
				</div>
			</div>
		</div>
	</div>

</form>


<script src="~/assets/js/validation/jquery.validate.min.js"></script>
<script src="~/assets/js/validation/jquery.validate.unobtrusive.min.js"></script>
<script>
	 
	$(document).ready(function () {
		$('select[class*="generalmodal"].select2').select2({
				dropdownParent: $('#generalmodal')
		});
		
	});
</script>