@model OtherInvoiceServicePageDto
@{
	int j = 1;
}



<div class="card-header">
	<div class="d-flex justify-content-between">

		<h3 class="title">
			<a asp-action="Details" asp-controller="OtherIncomeInvoice"
			   asp-route-invoiceId="@Model.OtherIncomeInvoiceId">
				<i class="fa-solid fa-right-to-bracket me-2 align-middle"></i>
			</a>
			لیست سرویس/خدمات این درخواست
		</h3>
	</div>
	<div class="d-flex justify-content-between align-items-end mt-3">
		<div>

			<div class="input-group d-flex align-items-center">
			</div>
		</div>
		<div class=" text-md-end text-center px-0">
			@if (Model.OtherIncomeInvoiceId != Guid.Empty
					&& Model?.List?.Any() == true
					&& Model?.State != null)
			{
				if (Model?.State == OtherIncomeInvoiceState.Factor)
				{
					<span id="ReportLinkId" class="">
						<a class="btn btn-sm px-2 btn-primary rounded"
						   asp-action="GetFile"
						   asp-route-invoiceId="@Model?.OtherIncomeInvoiceId"
						   asp-route-type="@OtherIncomeInvoiceFileType.Factor">
							<i class="fa-solid fa-download align-middle mx-1"></i> صورتحساب
						</a>


					</span>



				}

				else if (Model?.State == OtherIncomeInvoiceState.PreFactor)
				{
					<span class="">
						<a class="btn btn-sm px-2 btn-primary rounded"
						   asp-action="GetPreviewFactor"
						   asp-route-OtherIncomeInvoiceId="@Model?.OtherIncomeInvoiceId"
						   asp-route-PreviewFactor="@AllocationEquServiceType.Factor">
							<i class="fa-solid fa-download align-middle mx-1"></i> پیش نمایش
						</a>


					</span>
				}

			}



			@if (Model.CanChangeService)
			{
				<a style="border-radius:5px; margin:0px 10px" class="btn btn-primary" onclick="AddService();">
					<i class="icon-plus"></i>
					ثبت سرویس/خدمات
				</a>
			}

			@if (Model.CanChangeService && Model.List?.Any() == true)
			{
				<a id="EndFactorId"
				   style="border-radius:5px; margin:0px 10px" class="btn btn-success"
				   onclick="EndFactor(event, '@Model.OtherIncomeInvoiceId');">اتمام صورتحساب </a>
			}
			else if (Model?.CanChangeService == false && Model?.List?.Any() == true
			&& (Model.State == OtherIncomeInvoiceState.Factor))
			{
				<a id="BackToPreFactorStateId" style="border-radius:5px; margin:0px 10px" class="btn btn-success" onclick="BackToPreFactorState(event, '@Model.OtherIncomeInvoiceId');"> ویرایش صورتحساب </a>
			}

			<!-- /.portlet-title -->
			<div class="buttons-box">

				<i class="icon-size-fullscreen"></i>
				<div class="paper-ripple">
					<div class="paper-ripple__background"></div>
					<div class="paper-ripple__waves"></div>
				</div>
			</div>

		</div>
	</div>
	<!-- /.portlet-heading -->
</div>


<div class="card-body pt-0">
	<div class="table-responsive">
		<table class="table table-sm table-bordered table-hover table-striped" id="data-table">
			<thead class="bg-primary">
				<tr>
					<th class="align-middle" style="width: 5%">ردیف</th>

					<th class="align-middle">شرح کالا/خدمات</th>

					<th class="align-middle">تعداد/مقدار</th>
					<th class="align-middle">قیمت واحد-ريال</th>

					<th class="align-middle">مبلغ </th>

					<td class="align-middle">عملیات</td>
				</tr>
			</thead>
			<tbody>
				@if (Model?.List?.Any() == true)
				{
					foreach (var item in Model?.List)
					{
						<tr>
							<td class="align-middle">@(j++)</td>
							<td class="align-middle">@item.Description </td>
							<td class="align-middle">@item.Count.ToPrice(ToPriceExtention.PriceType.NoType)</td>

							<td class="align-middle">@item.PriceOne.ToPrice(ToPriceExtention.PriceType.NoType)</td>


							<td class="align-middle">@item.TotalPrice.ToPrice(ToPriceExtention.PriceType.NoType)</td>

							<td class="align-middle px-2 text-center">
								@if (Model.CanChangeService)
								{
									<a class="btn btn-warning px-2 btn-sm btn-icon curve" onclick="editService('@item.Id');"><i class="icon-pencil fs-6 align-middle"></i></a>

									<a onclick="DeleteService(event, '@item.Id');" class="btn btn-danger btn-sm btn-icon curve px-2 btn-questions">
										<i class="icon-trash fs-6 align-middle active fa-flip-horizontal"></i>
									</a>
								}
							</td>
						</tr>
					}
				}




			</tbody>
		</table>

	</div>
</div>


@if (Model?.State != null && Model.State == OtherIncomeInvoiceState.Factor)
{
	<p class="m-4">
		<span class="label fw-bold rounded px-2 py-1 label-warning">وضعیت پیش فاکتور اجازه ویرایش سرویس ها را نمی دهد. وضعیت فعلی : @Model.StateTitle</span>
	</p>
}



