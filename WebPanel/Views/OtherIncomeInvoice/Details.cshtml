@model OtherIncomeInvoiceDto
@{
	ViewData["Title"] = "جزئیات درآمد";
	Layout = "~/Views/Shared/AdminLayout.cshtml";
}
<div class="row">
	<div class="card">
		<div class="card-header pb-0 px-3">
			<div class="d-flex justify-content-between align-items-center">
				<h3 class="title">
					<i class="icon-frane"></i>
					<a asp-action="Index"><i class="fa-solid fa-right-to-bracket me-2"></i></a>
					جزئیات درآمد
				</h3>
				<div class="d-flex align-items-center">

					<a id="DeleteSeo" onclick="ShowQAlert(event,'DeleteSeo', 'حذف عملیات' , 'آیا از حذف این عملیات مطمئن هستید');" asp-controller="Seo" asp-action="DeleteSeo" asp-route-seoId="@Model.Id" class=" btn btn-danger"><i class="icon-trash fa-flip-horizontal"></i> حذف </a>

				</div>
			</div>
			<div class="row">
			</div>
		</div>
		<div class="card-body pt-0 px-2">
			<div class="bg-primary rounded-3 mt-4 p-3">
				<div class="row gy-3 align-items-center">
					<div class="col-1">
						<img src="~/assets/images/rial.png" alt="" class="img-fluid">
					</div>
					<div class="col-3">
						<p class="fs-6 fw-bold">@Model.TypeTitle</p>
						<p class="fs-6 fw-bold">تاریخ : @Model.DateFa</p>
					</div>
					<div class="col-3">
						<p class="fs-6 fw-bold">طرف حساب: @Model.CompanyCompanyName</p>
						<p class="fs-6 fw-bold">کالا: @Model.CargoName</p>
					</div>
					<div class="col-3">
						<p class="fs-6 fw-bold">تناژ: @Model.TonnageTitle</p>
						<p class="fs-6 fw-bold"> شناور: @Model.ShipShipName</p>
					</div>


					@* white devider start *@
					<div class="col-12 border-top border-white"></div>
					@* white divider end *@


					@* @if (User.IsInRole("admin") || User.IsInRole("adminOnePort")) *@

					<div class="col-3">

						<a class="btn btn-light w-100 py-3 fs-5" asp-action="DocFiles"   asp-route-reternPage="0"
						   asp-route-invoiceId="@Model.Id">
							<p><i class="fa-solid fa-anchor fs-3  mb-2"></i></p>
							مدیریت اسناد مرتبط
						</a>

					</div>

					 

					@if (Model.State <= OtherIncomeInvoiceState.PreFactor)
					{
						<div class="col-3">

							<a class="btn btn-light w-100 py-3 fs-5" asp-action="PreFactor" asp-route-invoiceId="@Model.Id">
								<p><i class="fa-solid fa-anchor fs-3  mb-2"></i></p>
								پیش فاکتور
							</a>


						</div>
					}
					 
					@if (Model.State >= OtherIncomeInvoiceState.PreFactor)
					{
						<div class="col-3">

							<a class="btn btn-light w-100 py-3 fs-5" asp-action="Factor" asp-route-invoiceId="@Model.Id">
								<p><i class="fa-solid fa-anchor fs-3  mb-2"></i></p>
								صورتحساب
							</a>


						</div>
					}


				</div>
			</div>
		</div>
	</div>
</div>

@section script {


	<script>

		$(document).ready(function () {

		});


	</script>
}

