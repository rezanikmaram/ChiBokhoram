@model CreateVoyagePageDto
@{
	ViewData["Title"] = "تعریف سفر";
	Layout = "~/Views/Shared/AdminLayout.cshtml";
	var drops = ViewBag.drops as SelectList;
}
@section style {

}
<div class="col-12">
	<div class="card">
		<div class="card-header pb-0">
			<div class="d-flex justify-content-between  align-items-baseline">
				<h3 class="title">
					<i class="fa-solid fa-anchor"></i> افزودن سفر
				</h3>
			</div>
			<hr />
		</div>

		<div class="card-body pt-0">
			<form asp-action="CreateVoyage" method="post">
				<input type="hidden" asp-for="CreateDto.Id" />
				<input type="hidden" name="reternPage" value="ViewBag?.reternPage" />

				<div class="row">
					<div class="form-body">

						<div class="row gy-4">
							<div class="col-md-4 col-sm-12">
								<div class="form-group relative">
									<label>کشتی</label>
									<div class="input-group d-flex flex-nowrap">
										<select class="form-control select2 " asp-for="CreateDto.ShipId"
												asp-items="Model.Ships">
										</select>
										<a class="btn btn-success px-2 ms-2 rounded" target="_blank"
										   asp-action="Index" asp-controller="Ship">
											<i class="icon-plus align-bottom"></i>
										</a>
									</div>
									<span asp-validation-for="CreateDto.ShipId"
										  class="text-danger"></span>
								</div>

							</div>
							
							<div class="col-md-4 col-sm-12">
								<div class="form-group">
									<label> بندر بارگیری </label>
									<div class="input-group col-sm-6">
										<input type="text" asp-for="CreateDto.LoadingPort" placeholder="نام بندر را بنویسید" style="border: 0.5px solid #d9d9d9" class="p-2 rounded w-100">
									</div>
									<span asp-validation-for="CreateDto.LoadingPort" class="text-danger"></span>
								</div>
							</div>
							
							<div class="col-md-4 col-sm-12">
								<div class="form-group">
									<label> بندر تخلیه </label>
									<div class="input-group col-sm-6">
										<select class="form-control select2 rounded" asp-for="CreateDto.DischargePortId"
												asp-items="Model.Ports">
											<option value="">نامشخص</option>
										</select>
										<span asp-validation-for="CreateDto.DischargePortId"
											  class="text-danger"></span>
									</div>
								</div>
							</div>
							
							<div class="col-md-4 col-sm-12">
								<div class="form-group">
									<label> بندر ورودی </label>
									<div class="input-group col-sm-6">
										<select class="form-control select2 rounded" asp-for="CreateDto.EntryPortId"
												asp-items="Model.Ports">
											<option value="">نامشخص</option>
										</select>
										<span asp-validation-for="CreateDto.EntryPortId"
											  class="text-danger"></span>
									</div>
								</div>
							</div>
							
							<div class="col-md-2 col-sm-12">
								<div class="form-group">
									<label> پرچم </label>
									<div class="input-group col-sm-6">
										<input type="text" placeholder=" (select2) ایران" style="border: 0.5px solid #d9d9d9" class="p-2 rounded w-100">
									</div>
								</div>
							</div>
							
							<div class="col-md-2 col-sm-12">
								<div class="form-group">
									<label> خدمه </label>
									<div class="input-group col-sm-6">
										<input type="number" asp-for="CreateDto.CrewCount" min="0" placeholder="0" style="border: 0.5px solid #d9d9d9" class="p-2 rounded w-100">
									</div>
									<span asp-validation-for="CreateDto.CrewCount" class="text-danger"></span>
								</div>
							</div>
							
							<div class="col-md-2 col-sm-12">
								<div class="  form-group ">
									<label>تاریخ ورود</label>
									<div class="input-group">
										<input asp-for="CreateDto.EntryDateFa" type="text" class=" form-control rounded" autocomplete="off">
										<span asp-validation-for="CreateDto.EntryDateFa" class="text-danger"></span>
									</div>
								</div>
							</div>
							
							<div class="col-md-2 col-sm-12">
								<div class="  form-group ">
									<label>تاریخ خروج</label>
									<div class="input-group">
										<input asp-for="CreateDto.BerthingDateFa" type="text" class=" form-control rounded" autocomplete="off">
										<span asp-validation-for="CreateDto.BerthingDateFa" class="text-danger"></span>
									</div>
								</div>
							</div>

							<div class="col-md-2 col-sm-12">
								<div class="form-group">
									<label>ساعت پهلوگیری</label>
									<div class="input-group clockpicker">
										<input asp-for="CreateDto.BerthingTime" type="text" class="form-control rounded" autocomplete="off">
										<span class="input-group-addon">
											<span class="glyphicon glyphicon-time"></span>
										</span>
									</div>
								</div>
							</div>
							
							<div class="col-md-4 col-sm-12">
								<div class="form-group">
									<label>موقعیت کشتی</label>
									<div class="input-group col-sm-6">
										<select class="form-control select2 rounded" asp-for="CreateDto.SeoShipState"
												asp-items="Html.GetEnumSelectList<SeoShipState>()">
										</select>
										<span asp-validation-for="CreateDto.SeoShipState"
											  class="text-danger"></span>
									</div>
								</div>
							</div>

							<div class="col-md-4 col-sm-12">
								<div class="form-group relative">
									<label>اسکله</label>
									<div class="input-group d-flex flex-nowrap">
										<select class="form-control select2 " asp-for="CreateDto.WaterfrontId"
										        asp-items="Model.Waterfronts">
											<option value="">نامشخص</option>
										</select>
										<span asp-validation-for="CreateDto.WaterfrontId"
										               class="text-danger"></span>
									</div>
								</div>

							</div>

							<div class="col-md-2 col-sm-12">
								<div class="form-group">
									<label>نوع محموله</label>
									<div class="input-group col-sm-6">
										<select class="form-control select2 rounded" asp-for="CreateDto.TrafficType"
												asp-items="Html.GetEnumSelectList<TrafficType>()">
											<option value="">نامشخص</option>
										</select>
										<span asp-validation-for="CreateDto.TrafficType"
											  class="text-danger"></span>
									</div>
								</div>
							</div>

							<div class="col-md-2 col-sm-12">
								<div class="form-group">
									<label>نوع عملیات</label>
									<div class="input-group col-sm-6">
										<select class="form-control select2 rounded" asp-for="CreateDto.TransportType"
												asp-items="Html.GetEnumSelectList<TransportType>()">
										</select>
										<span asp-validation-for="CreateDto.TransportType"
											  class="text-danger"></span>
									</div>
								</div>
							</div>



							<div class="col-md-2 col-sm-12">
								<div class="form-group">
									<label>تعداد بارنامه</label>
									<div class="input-group">
										<input type="number" asp-for="CreateDto.CountOfSeo" min="1" class="form-control">
									</div>
									<span asp-validation-for="CreateDto.CountOfSeo" class="text-danger"></span>
								</div>
							</div>


							<div class="col-md-2 col-sm-12">
								<div class="form-group">
									<label>وزن کیلوگرم</label>
									<div class="input-group">
										<input type="number" step="0.01" class="form-control" min="0.0" 
											   asp-for="CreateDto.Tonnage">
									</div>
									<span asp-validation-for="CreateDto.Tonnage" class="text-danger"></span>
								</div>
							</div>


							<div class="col-md-2 col-sm-12">
								<div class="form-group">
									<label>تعداد انبار کشتی</label>
									<div class="input-group">
										<price-input asp-for="CreateDto.CountOfShipWarehouse"></price-input>
									</div>
									<span asp-validation-for="CreateDto.CountOfShipWarehouse" class="text-danger"></span>
								</div>
							</div>
							
							<div class="col-md-2 col-sm-12">
								<div class="form-group">
									<label> نام کاپیتان </label>
									<div class="input-group col-sm-6">
										<input type="text" placeholder=" نام کاپیتان را وارد کنید " style="border: 0.5px solid #d9d9d9" class="p-2 rounded w-100">
									</div>
								</div>
							</div>

							<div class="col-md-4 col-sm-12">
								<div class="form-group">
									<label>شرکت کشتیرانی</label>
									<div class="input-group d-flex flex-nowrap">
										<select class="form-control select2 rounded" asp-for="CreateDto.CompanyShippingId"
												asp-items="Model.Companies">
											<option value="">نامشخص</option>
										</select>
										<a class="btn btn-success px-2 ms-2 rounded" target="_blank"
										   asp-action="CreateCompany" asp-controller="Company">
											<i class="icon-plus align-bottom"></i>
										</a>
									</div>
									<span asp-validation-for="CreateDto.CompanyShippingId" class="text-danger"></span>
								</div>
							</div>


							<div class="col-md-4 col-sm-12">
								<div class="form-group">
									<label>شماره دریایی</label>
									<div class="input-group">
										<input type="text" asp-for="CreateDto.PmoNumber" class="form-control">
									</div>
									<span asp-validation-for="CreateDto.PmoNumber" class="text-danger"></span>
								</div>
							</div>

							<div class="col-md-4 col-sm-12">
								<div class="form-group">
									<label>شماره سفر</label>
									<div class="input-group">
										<input type="text" asp-for="CreateDto.VoyageNumber" class="form-control">
									</div>
									<span asp-validation-for="CreateDto.VoyageNumber" class="text-danger"></span>
								</div>
							</div>
							
							
							<div class="col-md-4 col-sm-12 align-content-end">
								<div class="input-group activeor">
									<label>
										<input type="checkbox" asp-for="CreateDto.IsBerthedAtAnotherPort" class="normal">
										پهلوگیری در بندر دیگر بوده؟
									</label>
								</div>
							</div>
							 
						</div>
					</div>
					<div class="col-12 mt-5">
						<div class="media report-perfom" style="float: left;">
							<div class="form-actions">

								@* @if ((int)ViewBag.reternPage == 0) *@
								@if (Model == null || Model?.CreateDto.Id == Guid.Empty)
								{
									if ((CreateVoyageReturnPage)ViewBag.reternPage == CreateVoyageReturnPage.VoyageIndex)
									{
										<a class="btn btn-warning btn-round" asp-action="Index">
											<i class="icon-close align-middle px-1"></i>
											بازگشت
											<div class="paper-ripple"><div class="paper-ripple__background"></div><div class="paper-ripple__waves"></div></div>
										</a>
									}
									else
									{
										<a class="btn btn-warning btn-round" asp-action="Index" asp-controller="Seo">
											<i class="icon-close align-middle px-1"></i>
											بازگشت
											<div class="paper-ripple"><div class="paper-ripple__background"></div><div class="paper-ripple__waves"></div></div>
										</a>
									}

								}
								else
								{
									<a class="btn btn-warning btn-round" asp-action="VoyageSeo" asp-route-voyageId="@Model.CreateDto.Id">
										<i class="icon-close align-middle px-1"></i>
										بازگشت
										<div class="paper-ripple"><div class="paper-ripple__background"></div><div class="paper-ripple__waves"></div></div>
									</a>
								}

								<button type="submit" class="btn btn-info btn-round">
									<i class="icon-check align-middle px-1"></i>
									ذخیره
									<div class="paper-ripple"><div class="paper-ripple__background"></div><div class="paper-ripple__waves"></div></div>
								</button>


							</div>
						</div>
					</div>
				</div>

			</form>
			<section class="fix"></section>
		</div>
	</div>
</div>


@section script {


	<script>

		$(document).ready(function () {
			kamaDatepicker('CreateDto_EntryDateFa', customOptions);
			kamaDatepicker('CreateDto_BerthingDateFa', customOptions);
			$('.clockpicker').clockpicker({
				placement: 'bottom',
				align: 'left',
				donetext: 'تایید'
			});
			$('.select2').select2();
		});


		$("#CreateDto_ShipId").select2().trigger('change');
		$("#CreateDto_CompanyShippingId").select2().trigger('change');
		// $("#CompanyPortOperatorId").select2().trigger('change');
		$("#CreateDto_TransportType").select2().trigger('change');
		$("#CreateDto_TrafficType").select2().trigger('change');
		$("#CreateDto_SeoShipState").select2().trigger('change');



	</script>
}


