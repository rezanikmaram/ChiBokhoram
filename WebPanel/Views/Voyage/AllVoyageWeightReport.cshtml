@model Entities.DTOs.Web.Hirman.AllVoyageWeightReportPageDto
@{
    ViewData["Title"] = "گزارش تناژ همه سفرها";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    int i = 1;
}

