@model TaliGroupByDayPageDto
@{
    ViewData["Title"] = "تالی ها به تفکیک روز";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    int i = 1;
}

<div class="col-md-12">
    <div class="p-3 rounded-3 bg-white shadow-sm">
        <div class="d-flex justify-content-between">
            <div>
                <span class="fs-6">
                    <i class="icon-frane"></i>
                    <a asp-controller="Voyage" asp-action="VoyageSeo" asp-route-VoyageId="@Model.VoyageInfo.Id"><i class="fa-solid fa-right-to-bracket me-2"></i></a>
                     تالی ها به تفکیک روز
                </span>
                <span class="label p-2 mx-2 rounded label-primary">@($"{Model.VoyageInfo.ShipShipName} - {Model.VoyageInfo.PmoNumber}")</span>
                <span class="label p-2 mx-2 rounded label-info">@Model.VoyageInfo.TransportTypeTitle</span>
            </div>

            <div class="d-flex align-items-center">
                @DateTimeOffset.Now.ToLongPersianDateString()
                <i class="icon-calendar"></i>
            </div>
        </div>
    </div>
</div>
<div class="mt-3">
    <div class="row">
        <div class="col-md-12">
            <div class="card rounded-3 min-height-600">
                <div class="card-header pb-0">
                    <div class="d-flex justify-content-between">
                        <h3 class="title m-0">
                            <i class="icon-speech"></i>

                        </h3>
                    </div>
