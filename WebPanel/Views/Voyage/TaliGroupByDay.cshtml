                        </div>
                    </form> *@


                </div>
                <div class="card-body pt-0">
                    <table id="TableUnSelected" class="table table-bordered ">
                        <thead class="bg-primary">
                            <tr>
                                <th>ردیف</th>
                                <th>شماره بارنامه </th>
                                <th> صاحب کالا   </th>
                                <th>تاریخ</th>
                                <th>نوع انبار</th>
                                <th>تعداد</th>
                                <th>وزن</th>
                            </tr>
                        </thead>
                        <tbody>

                            @foreach (var item in Model.TaliGroupByDay)
                            {
                                <tr>
                                    <td>@(i++)</td>
                                    <td>@item.BillOfLadingNumber</td>
                                    <td>@item.OwnerCompanyName</td>
                                    <td>@item.DateFa</td>
                                      <td>@item.WarehouseStorageTypeTitle</td>
                                    <td>@item.Count.ToPrice()</td>
                                    <td>@item.Weight.ToPrice()</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <!-- /.tab-content -->

                </div><!-- /.portlet-body -->
            </div>
        </div>

     </div>
</div>
