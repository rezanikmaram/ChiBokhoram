<!-- Import/Export Excel Modal -->
<div id="voyageSeoImportExportModal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">ورود/خروج Excel بارنامه ها</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row gy-4">
                    <div class="col-12">
                        <div class="alert alert-info">
                            <i class="fa-solid fa-info-circle me-2"></i>
                            <strong>راهنما:</strong>
                            <ul class="mb-0 mt-2">
                                <li>برای <strong>ورود</strong> اطلاعات از Excel، فایل را انتخاب و دکمه بارگذاری را بزنید</li>
                                <li>برای <strong>خروجی</strong> Excel، دکمه خروجی Excel را بزنید</li>
                                <li>کد ملی شرکت صاحب کالا را وارد کنید (در صورت عدم وجود، شرکت جدید ایجاد می‌شود)</li>
                                <li>برای بروزرسانی بارنامه موجود، شناسه آن را در فایل Excel وارد کنید</li>
                            </ul>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card border-primary">
                            <div class="card-header bg-primary text-white">
                                <i class="fa-solid fa-download me-2"></i> خروجی Excel
                            </div>
                            <div class="card-body text-center">
                                <p class="text-muted">دریافت خروجی Excel از بارنامه های فعلی سفر</p>
                                <a asp-action="ExportVoyageSeoDataExcel" asp-route-voyageId="@Model.VoyageId" class="btn btn-primary">
                                    <i class="fa-solid fa-file-excel me-2"></i> دریافت خروجی
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card border-warning">
                            <div class="card-header bg-warning text-dark">
                                <i class="fa-solid fa-upload me-2"></i> ورود از Excel
                            </div>
                            <div class="card-body">
                                <form id="importVoyageSeoForm" enctype="multipart/form-data">
                                    <input type="hidden" name="voyageId" value="@Model.VoyageId" />
                                    <div class="form-group mb-3">
                                        <label for="excelFile">فایل Excel:</label>
                                        <input type="file" id="excelFile" name="excelFile" class="form-control" accept=".xlsx,.xls" required />
                                        <small class="text-muted">فقط فایل‌های .xlsx و .xls مجاز هستند</small>
                                    </div>
                                    <div class="d-grid gap-2">
                                        <a href="@Url.Action("DownloadVoyageSeoTemplate", "Voyage", new { voyageId = Model.VoyageId })" class="btn btn-outline-info btn-sm">
                                            <i class="fa fa-download me-1"></i> دانلود قالب Excel
                                        </a>
                                        <button type="button" id="importVoyageSeoBtn" class="btn btn-warning" onclick="importVoyageSeoFromExcel()">
                                            <i class="fa fa-upload me-2"></i> بارگذاری Excel
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Lookup Tables for Import Fields -->
                <div class="mt-4">
                    <h5 class="mb-3"><i class="fa-solid fa-table-list me-2"></i>جدول کدهای مورد نیاز برای ورود اطلاعات:</h5>

                    <div class="accordion" id="lookupTablesAccordion">
                        <!-- TrafficType Lookup -->
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#trafficTypeLookup">
                                    <i class="fa-solid fa-truck me-2"></i> نوع محموله (TrafficType)
                                </button>
                            </h2>
                            <div id="trafficTypeLookup" class="accordion-collapse collapse" data-bs-parent="#lookupTablesAccordion">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm table-bordered mb-0">
                                        <thead class="table-light">
                                            <tr><th>کد</th><th>نام</th></tr>
                                        </thead>
                                        <tbody>
                                            <tr><td>0</td><td>فله</td></tr>
                                            <tr><td>1</td><td>کالای عمومی</td></tr>
                                            <tr><td>2</td><td>کانتینری</td></tr>
                                            <tr><td>3</td><td>نفتی</td></tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- CustomsProcedure Lookup -->
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#customsProcedureLookup">
                                    <i class="fa-solid fa-building-columns me-2"></i> رویه گمرکی (CustomsProcedure)
                                </button>
                            </h2>
                            <div id="customsProcedureLookup" class="accordion-collapse collapse" data-bs-parent="#lookupTablesAccordion">
                                <div class="accordion-body p-0">
                                    <table class="table table-sm table-bordered mb-0">
                                        <thead class="table-light">
                                            <tr><th>کد</th><th>نام</th></tr>
                                        </thead>
                                        <tbody>
                                            <tr><td>0</td><td>واردات</td></tr>
                                            <tr><td>1</td><td>صادرات</td></tr>
                                            <tr><td>2</td><td>ترانزیت داخلی</td></tr>
                                            <tr><td>3</td><td>ترانزیت خارجی</td></tr>
                                            <tr><td>4</td><td>ترانشیپ داخلی</td></tr>
                                            <tr><td>5</td><td>ترانشیپ خارجی</td></tr>
                                            <tr><td>6</td><td>کاپوتاژ</td></tr>
                                            <tr><td>7</td><td>برگشت از واردات</td></tr>
                                            <tr><td>8</td><td>برگشت از صادرات</td></tr>
                                            <tr><td>9</td><td>صادرات مجدد</td></tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- ProductPacking Lookup -->
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#productPackingLookup">
                                    <i class="fa-solid fa-box me-2"></i> بسته بندی (ProductPacking)
                                </button>
                            </h2>
                            <div id="productPackingLookup" class="accordion-collapse collapse" data-bs-parent="#lookupTablesAccordion">
                                <div class="accordion-body p-0">
                                    <div class="alert alert-info m-2">
                                        <small>لیست بسته بندی‌های موجود در سیستم (از نام انگلیسی برای ورود استفاده کنید):</small>
                                    </div>
                                    <table class="table table-sm table-bordered mb-0" id="productPackingTable">
                                        <thead class="table-light">
                                            <tr><th>نام انگلیسی</th><th>نام فارسی</th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var packing in Model.ProductPackings ?? new List<SelectListItem>())
                                            {
                                                <tr>
                                                    <td><code>@packing.Value</code></td>
                                                    <td>@packing.Text</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Progress/Result Area -->
                    <div id="importVoyageSeoResult" class="mt-4" style="display: none;">
                        <div class="alert" role="alert">
                            <div id="importVoyageSeoMessage"></div>
                            <div id="importVoyageSeoDetails" class="mt-2 small"></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">بستن</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section script {
    <partial name="~/Views/Voyage/_VoyageInfoScript.cshtml" />
    <script>
            kamaDatepicker('DateCloseVoyageId', customOptions);


        $(document).ready(function () {
            $('select[class*="FilterSeo"].select2').select2();

        });

            function ShowCreateSeoModal(event) {
                event.preventDefault();
                const form = $("#CreateSeoForm");
                if (form.length) {
                    form.trigger("reset");
                    $('#CreateSeo_ProductOwnerCompanyId').val('').trigger('change');
                    $('#CreateSeo_ProductOwnerCompanyId').select2({
                    dropdownParent: $('#CreateSeoModal')
                });
                }
                $("#CreateSeoModal").modal('show');
            }

            function ShowModalCloseVoyage(event) {
                event.preventDefault();
                $("#CloseVoyageModal").modal('show');
            }

            function ErrorCanNotDeleteVoyage() {
                Toast.fire({
                    icon: 'error',
                    title: 'این سفر دارای عملیات می باشد. ابتدا عملیات را حذف کنید'
                });
            }

            // کد برای تغییر حالت نمایش
            $(document).ready(function () {

                $('#billOfLadingInput').on('invalid', function() {
                    if (this.validity.valueMissing) {
                        this.setCustomValidity('لطفاً شماره بارنامه را وارد کنید');
                    }
                }).on('input', function() {
                    this.setCustomValidity('');
                });

                // تنظیم حالت اولیه - نمایش لیستی
                $('#cardView').hide();
                $('#tableView').show();

                $('#discharge').change(function() {
                    if ($(this).is(':checked')) {
                        $('#cardView').show();
                        $('#tableView').hide();
                    }
                });

                $('#loading').change(function() {
                    if ($(this).is(':checked')) {
                        $('#cardView').hide();
                        $('#tableView').show();
                    }
                });

                $('#CreateSeo_ProductOwnerCompanyId').select2({
                    dropdownParent: $('#CreateSeoModal')
                });

                $(document).on('click', '.js-open-create-voyage', ShowCreateVoyageModal);
            });

            function ShowCreateVoyageModal(event) {
                if (event) event.preventDefault();
                var $link = $(event && event.currentTarget ? event.currentTarget : this);
                var url = $($link).attr('href');
                if (!url) return;
                if (url.indexOf('isModal=true') === -1) {
                    url += (url.indexOf('?') > -1 ? '&' : '?') + 'isModal=true';
                }
                $.ajax({
                    url: url,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    success: function (html) {
                        $('#CreateVoyageModal .modal-body').html(html);
                        initCreateVoyageModal();
                        $('#CreateVoyageModal').modal('show');
                        bindCreateVoyageForm();
                    }
                });
            }

            function initCreateVoyageModal() {
                try {
                    $('select[class*="CreateVoyageModal"].select2').select2({
                     dropdownParent: $('#CreateVoyageModal')
                 });

                } catch (e) { }
                try { kamaDatepicker('CreateDto_EntryDateFa', customOptions); } catch (e) { }
                try { kamaDatepicker('CreateDto_BerthingDateFa', customOptions); } catch (e) { }
                try {
                    $('#CreateVoyageModal .clockpicker').clockpicker({
                        placement: 'bottom',
                        align: 'left',
                        donetext: 'تایید',
                        autoclose: true
                    });
                } catch (e) { }
            }

            function bindCreateVoyageForm() {
                var form = $('#CreateVoyageForm');
                if (!form.length) return;
                form.off('submit').on('submit', function (e) {
                    e.preventDefault();
                    $.ajax({
                        url: form.attr('action'),
                        type: 'POST',
                        data: form.serialize(),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        success: function (resp) {
                            if (resp && resp.success) {
                                window.location.href = '/Voyage/VoyageSeo?voyageId=' + resp.voyageId;
                            } else {
                                showVoyageError(resp && resp.message);
                            }
                        },
                        error: function (xhr) {
                            var msg = (xhr.responseJSON && xhr.responseJSON.message) || xhr.responseText;
                            try { var obj = JSON.parse(msg); msg = obj && obj.Message ? obj.Message : msg; } catch (_) { }
                            showVoyageError(msg);
                        }
                    });
                });
            }

        function showVoyageError(message) {
                if (typeof Toast !== 'undefined' && Toast.fire) {
                    Toast.fire({ icon: 'error', title: message || 'خطا در ثبت' });
                } else {
                    alert(message || 'خطا در ثبت');
                }
            }

            // Import/Export Excel Functions
            function openVoyageSeoImportExportModal() {
                const modalEl = document.getElementById('voyageSeoImportExportModal');
                if (modalEl) {
                    const modalInstance = bootstrap.Modal.getOrCreateInstance(modalEl);
                    modalInstance.show();
                }
            }

            function importVoyageSeoFromExcel() {
                const form = document.getElementById('importVoyageSeoForm');
                const fileInput = document.getElementById('excelFile');
                const resultDiv = document.getElementById('importVoyageSeoResult');
                const messageDiv = document.getElementById('importVoyageSeoMessage');
                const detailsDiv = document.getElementById('importVoyageSeoDetails');
                const btn = document.getElementById('importVoyageSeoBtn');

                if (!fileInput.files || fileInput.files.length === 0) {
                    if (typeof Toast !== 'undefined' && Toast.fire) {
                        Toast.fire({ icon: 'error', title: 'لطفاً یک فایل Excel انتخاب کنید' });
                    } else {
                        alert('لطفاً یک فایل Excel انتخاب کنید');
                    }
                    return;
                }

                const formData = new FormData(form);

                // Disable button and show loading
                btn.disabled = true;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i> در حال بارگذاری...';

                // Hide previous results
                resultDiv.style.display = 'none';

                $.ajax({
                    url: '@Url.Action("ImportVoyageSeoDataExcel", "Voyage")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    dataType: 'json'
                })
                .done(function(response) {
                    resultDiv.style.display = 'block';

                    if (response.success) {
                        resultDiv.className = 'mt-4 alert alert-success';
                        messageDiv.innerHTML = '<i class="fa-solid fa-check-circle me-2"></i> ' + response.message;

                        if (response.errorDetails && response.errorDetails.length > 0) {
                            detailsDiv.innerHTML = '<strong>جزئیات خطاها:</strong><br/>' +
                                response.errorDetails.map(e => '• ' + e).join('<br/>');
                        } else {
                            detailsDiv.innerHTML = '';
                        }

                        // Reload page after 2 seconds on success
                        setTimeout(function() {
                            window.location.reload();
                        }, 2000);
                    } else {
                        resultDiv.className = 'mt-4 alert alert-danger';
                        messageDiv.innerHTML = '<i class="fa-solid fa-exclamation-circle me-2"></i> ' + response.message;
                        detailsDiv.innerHTML = '';
                    }
                })
                .fail(function() {
                    resultDiv.style.display = 'block';
                    resultDiv.className = 'mt-4 alert alert-danger';
                    messageDiv.innerHTML = '<i class="fa-solid fa-exclamation-circle me-2"></i> خطا در ارتباط با سرور';
                    detailsDiv.innerHTML = '';
                })
                .always(function() {
                    // Re-enable button
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa fa-upload me-2"></i> بارگذاری Excel';
                });
            }

            // Initialize date pickers for filter fields
            $(document).ready(function() {


                try {
                    kamaDatepicker('Filter_DateFrom', {
                        buttons: ["today", "clear"],
                        markToday: true,
                        markHolidays: true,
                        holidays: ["فروردین", "اردیبهشت", "خرداد", "تیر", "مرداد", "شهریور", "مهر", "آبان", "آذر", "دی", "بهمن", "اسفند"]
                    });
                } catch (e) { }

                try {
                    kamaDatepicker('Filter_DateTo', {
                        buttons: ["today", "clear"],
                        markToday: true,
                        markHolidays: true,
                        holidays: ["فروردین", "اردیبهشت", "خرداد", "تیر", "مرداد", "شهریور", "مهر", "آبان", "آذر", "دی", "بهمن", "اسفند"]
                    });
                } catch (e) { }
            });
    </script>
}
