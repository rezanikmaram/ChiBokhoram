<div class="col-lg-12">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between">
                <h3 class="title">
                    <a asp-controller="Voyage" asp-action="VoyageSeo" asp-route-voyageId="@Model.VoyageInfo?.Id"><i class="fa-solid fa-right-to-bracket me-2"></i></a>
                    <i class="icon-frane"></i>اسناد سفر
                </h3>
                <div>
                    <a class="btn mx-2 btn-success rounded"
                       onclick="VoyageDocumentShowModal(null, '@Model.VoyageInfo.Id');">
                        <i class="icon-plus align-middle"></i>
                        سند جدید
                    </a>
                    <div class="buttons-box">
                        <i class="icon-size-fullscreen"></i>
                        <div class="paper-ripple">
                            <div class="paper-ripple__background"></div>
                            <div class="paper-ripple__waves"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body pt-0">
            <div class="table-responsive">
                <table class="table table-sm table-bordered table-hover table-striped" id="data-table">
                    <thead class="bg-primary">
                        <tr>
                            <th class="px-1 text-center">#</th>
                            <th class="px-1 text-center">شناسه سند</th>
                            <th class="px-1 text-center">نوع سند</th>
                            <th class="px-1 text-center">نام فایل</th>
                            <th class="px-1 text-center">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Data)
                        {
                            <tr>
                                <td class="align-middle px-2 text-center">@(i++)</td>
                                <td class="align-middle px-2 text-center">@item.Id</td>
                                <td class="align-middle px-2 text-center">@item.VoyageDocType.ToDisplay(DisplayProperty.Name)</td>
                                <td class="align-middle px-2 text-center">@item.Document.OriginalFileName</td>
                                <td class="align-middle px-2 text-center">
                                    @if (item.Document != null)
                                    {
                                        <a class="btn btn-primary px-2 my-2 rounded"
                                           data-bs-toggle="tooltip" data-bs-placement="top" title="@item.Document.OriginalFileName"
                                           onclick="DownloadDocFile(event, '@item.DocumentId')">
                                            <i class="fa-solid fa-download"></i>
                                        </a>
                                    }
                                    @* <a class="btn btn-warning px-2 btn-sm btn-icon curve"
                                       onclick="VoyageDocumentShowModal('@item.Id', '@Model.VoyageInfo.Id');">
                                        <i class="icon-pencil fs-6 align-middle"></i>
                                    </a> *@
                                    @if (item.VoyageDocType < VoyageDocType.FactorDoc)
                                    {
                                        <a id="DeleteVoyageDocument@(i)"
                                           onclick="ShowQAlert(event,'DeleteVoyageDocument@(i)');"
                                           class="btn btn-danger px-2 btn-sm btn-icon curve btn-questions"
                                           asp-action="DeleteVoyageDocument" asp-route-voyageDocumentId="@item.Id">
                                            <i class="icon-trash fs-6 align-middle fa-flip-horizontal"></i>
                                        </a>
                                    }

                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<form asp-action="GetVoyageDocumentFileById" asp-controller="Voyage"
      method="post" id="FormForDownloadFileId">
    <input type="hidden" id="docIdForDownload" name="docId" />
</form>

<div id="generalmodal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" role="dialog" tabindex="-1">
    <div class="modal-dialog modal modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">ثبت سند سفر</h4>
                <button type="button" class="close btn-close rounded border" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalbody">
                <partial name="_CreateVoyageDocument" model="Model.CreateVoyageDocumentPageDto" />
            </div>
        </div>
    </div>
</div>

@section script {
    <script>
        $(document).ready(function () {
            $('select[class*="generalmodal"].select2').select2({
                 dropdownParent: $('#generalmodal')
             });
        });

        function DownloadDocFile(event, docId) {
            event.preventDefault();
            $("#docIdForDownload").val(docId);
            $("#FormForDownloadFileId").submit();
        }

        function VoyageDocumentShowModal(voyageDocumentId, voyageId) {
            // $.post("@Url.Action("GetCreateVoyageDocumentDtoById", "VoyageDocument")", { voyageDocumentId, voyageId })
            //     .done(function (res) {
            //         $("#modalbody").html(res);
            //         $("#generalmodal").modal('show');
            //     })
            //     .fail(function (xhr, status, error) {
            //         location.reload();
            //     });

            $("#generalmodal").modal('show');

        }
    </script>
}