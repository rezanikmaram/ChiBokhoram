@model ChangeVesselStatusDto

<link href="~/assets/plugins/select2/dist/css/select2.min.css" rel="stylesheet">

<form asp-action="ChangeStatusVessel" method="post">
    <input asp-for="Id" type="hidden" />
    <div class="card-body">

        <div class="col-md-12">
            <div class="form-body row gy-4">
                <div class="col-md-12">
                    <div class="form-group m-l-60">
                        <label>وضعیت شناور</label>
                        <div class="input-group">
                            <select class="form-control" asp-for="EquipmentStatus" asp-items="@ViewBag.ListStatus">
                            </select>
                            <span asp-validation-for="EquipmentStatus" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="form-group">
                        <label>توضیحات </label>
                        <div class="input-group">
                            <textarea type="text" rows="5" class="form-control rounded" asp-for="Description">
                                    
                            </textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <input type="datetime" hidden class="form-control" asp-for="LogDate">
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success btn-round">ذخیره</button>
                    <button type="button" class="btn btn-danger btn-round" data-bs-dismiss="modal">بازگشت</button>
                </div>
            </div>
        </div>

    </div>


</form>


  <script src="~/assets/js/validation/jquery.validate.min.js"></script>
 <script src="~/assets/js/validation/jquery.validate.unobtrusive.min.js"></script>


