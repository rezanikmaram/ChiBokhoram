@model Entities.DTOs.Web.PaymentReceiptReportPageDto
@using DNTPersianUtils.Core
@using Common.enumeration.Hirman
@{
    ViewData["Title"] = "رسیدهای پرداخت آنلاین";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    var page = Model?.Data?.PageNumber ?? 1;
    var size = Model?.Data?.PageSize ?? 20;
    var i = ((page - 1) * size) + 1;
}

<div class="col-lg-12">
    <div class="card">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="title">
                    <i class="fa fa-receipt me-2 text-success"></i> رسیدهای پرداخت آنلاین (تسویه‌شده)
                </h3>
            </div>
        </div>

        <div class="card-body pt-0">
            <form id="formFilter" asp-action="Index" asp-route-p="" method="post">
                <input name="p" id="pageNumber" hidden />
                <div class="row gy-4">
                    <div class="col-md-2 col-sm-12">
                        <div class="form-group">
                            <label>از تاریخ:</label>
                            <div class="input-group">
                                <input asp-for="Filter.FilterDate.FromDate" type="text" class="form-control" autocomplete="off" />
                                <span asp-validation-for="Filter.FilterDate.FromDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-2 col-sm-12">
                        <div class="form-group">
                            <label>تا تاریخ:</label>
                            <div class="input-group">
                                <input asp-for="Filter.FilterDate.ToDate" type="text" class="form-control" autocomplete="off" />
                                <span asp-validation-for="Filter.FilterDate.ToDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-2 col-sm-12 d-flex align-items-end">
                        <button class="btn btn-success w-50" type="submit" style="border-radius:5px;">فیلتر</button>
                    </div>
                </div>
            </form>

            <div class="table-responsive mt-4">
                <table class="table table-bordered table-hover table-striped">
                    <thead class="bg-primary position-sticky top-0">
                        <tr>
                            <th class="px-1 text-center">#</th>
                            <th class="px-1 text-center">سریال تراکنش‌ها</th>
                            <th class="px-1 text-center">دلیل پرداخت</th>
                            <th class="px-1 text-center">مبلغ پرداخت</th>
                            <th class="px-1 text-center">تاریخ ایجاد</th>
                            <th class="px-1 text-center">تاریخ تسویه</th>
                            <th class="px-1 text-center">شماره صورتحساب تخصیص</th>
                            <th class="px-1 text-center">شماره PMO</th>
                            <th class="px-1 text-center">شماره سفر</th>
                            <th class="px-1 text-center">بندر</th>
                            <th class="px-1 text-center">نام شرکت</th>
                            <th class="px-1 text-center">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.Data?.Data != null)
                        {
                            foreach (var item in Model.Data.Data)
                            {
                                <tr>
                                    <td class="align-middle">@i</td>
                                    <td class="align-middle">@item.SerialNumbers</td>
                                    <td class="align-middle">@item.PaymentReasonType.ToDisplay()</td>
                                    <td class="align-middle">@item.Price.ToPrice()</td>
                                    <td class="align-middle" dir="ltr">@(item.GenerateDate.ToShortPersianDateTimeString())</td>
                                    <td class="align-middle" dir="ltr">@(item.SettlementDate?.ToShortPersianDateTimeString())</td>
                                    <td class="align-middle">
                                        @if (item.AllocationOfEquipmentId != null)
                                        {
                                            <a target="_blank" asp-controller="AllocationOfEquipment" asp-action="PreFactor" asp-route-allocationEquId="@item.AllocationOfEquipmentId">
                                                @item.NumberFactor
                                            </a>
                                        }
                                    </td>
                                    <td class="align-middle">@item.PmoNumber</td>
                                    <td class="align-middle">@item.VoyageNumber</td>
                                    <td class="align-middle">@item.PortName</td>
                                    <td class="align-middle">@item.CompanyName</td>
                                    <td class="align-middle">
                                        @if (item.PaymentReasonType == PaymentReasonType.AllocationOfEquCompany && item.AllocationOfEquipmentId != null)
                                        {
                                            <a class="btn btn-primary btn-sm"
                                               asp-controller="AllocationOfEquipment"
                                               asp-action="DocFiles"
                                               asp-route-allocationEquId="@item.AllocationOfEquipmentId"
                                               target="_blank">
                                                مشاهده جزئیات
                                            </a>
                                        }
                                    </td>
                                </tr>
                                i++;
                            }
                        }
                    </tbody>
                </table>

                <div class="mt-4">
                    <cs-pager cs-paging-pagesize="@Model.Data.PageSize"
                              cs-paging-pagenumber="@Model.Data.PageNumber"
                              cs-paging-totalitems="@Model.Data.TotalItems"
                              cs-paging-maxpageritems="10"
                              cs-pagenumber-param="p"
                              cs-show-first-last="true"
                              cs-suppress-empty-nextprev="true"
                              cs-suppress-inactive-firstlast="true"
                              cs-show-numbered="true"
                              cs-first-page-text="ابتدا"
                              cs-last-page-text="انتها"
                              cs-next-page-title="بعدی"
                              cs-previous-page-title="قبلی"
                              cs-first-page-title="ابتدا"
                              cs-last-page-title="انتها"
                              cs-next-page-text="بعدی"
                              cs-previous-page-text="قبلی"
                              cs-pager-li-current-class="page-item active"
                              cs-pager-li-other-class="page-item"
                              cs-pager-li-non-active-class="page-item disabled"
                              cs-pager-link-current-class="page-link"
                              cs-pager-link-other-class="page-link"
                              asp-controller="PaymentReceiptReport"
                              asp-action="Index">
                    </cs-pager>
                </div>
            </div>
        </div>
    </div>
</div>

@section script {
    <script>
        $(document).ready(function () {
            $(".page-link").click(function (event) {
                event.preventDefault();
                var hrefValue = $(this).attr("href");
                $("#pageNumber").val(hrefValue.split("p=")[1]);
                $("#formFilter").submit();
            });
        });

        kamaDatepicker('Filter_FilterDate_FromDate', customOptions);
        kamaDatepicker('Filter_FilterDate_ToDate', customOptions);
    </script>
}
