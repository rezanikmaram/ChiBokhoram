@model List<WarehouseReceiptOutboundInfoDto>
@{
	int i = 1;
}


<div class="col-lg-12">
	<div class="table-responsive vh-100 px-3">
		<table class="table table-bordered table-hover table-striped" id="data-table">
			<thead class="bg-primary">
				<tr>
					<th>ردیف</th>
					<th>شماره پرونده</th>
					<th> ارزش گمرکی  </th>
					<th>شماره کارت</th>
					<th>مبدا حمل</th>
					<th>شماره گواهی مبدا</th>
					<th>مقصد حمل</th>
					<th>تاریخ صدور</th>
					<th>وضعیت</th>
					<th>عملیات</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var item in Model)
				{
					<tr>
						<td class="align-middle">@(i++)</td>
						<td class="align-middle">@item.CaseNumber</td>

						<td class="align-middle">@item.ValueTitle</td>

						<td class="align-middle">@item.CardNumber</td>
						<td class="align-middle">@item.Origin</td>
						<td class="align-middle">@item.OriginCertificateNumber</td>
						<td class="align-middle">@item.Destination</td>
						<td class="align-middle">@item.IssueDateFa</td>
						<td class="align-middle">@item.StatusTitle</td>
						<td class="align-middle">
							<a target="_blank" asp-action="Details" asp-controller="WarehouseReceiptOutbound" asp-route-wroId="@item.Id" class="btn btn-primary px-2 my-2 rounded">
								<i class="fa-solid fa-boxes"></i> مدیریت
							</a>

						</td>
					</tr>
				}
			</tbody>
		</table>

	</div>
</div>

