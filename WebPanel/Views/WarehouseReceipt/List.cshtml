@section script {

    <script>
        $(document).ready(function () {
            $('.select2').select2();
        });


        kamaDatepicker('Filter_DateFrom', customOptions);
        kamaDatepicker('Filter_DateTo', customOptions);


        $(".page-link").click(function (event) {
            event.preventDefault(); // غیرفعال کردن عملکرد پیشفرض href

            var hrefValue = $(this).attr("href");
            $("#pageNumber").val(hrefValue.split("p=")[1]);
            $("#formFilter").submit();
        });


        function showWarehouseReceiptOutbounds(warehouseReceiptId) {
            console.log("warehouseReceiptId")
            $.post("@Url.Action("GetReceiptOutboundsByWarehouseReceiptId", "WarehouseReceipt")", { warehouseReceiptId: warehouseReceiptId })
                .done(function (res) {
                    $("#generalModalBodyId").html(res);
                    $("#generalModal").modal('show');
                });
        }

        function ShowModalReportGroupingByCompany(event) {
            event.preventDefault();

            $("#ReportGroupingByCompanyModal").modal('show');
        }

        function GetReportGroupingByCompany(event) {
            $("#ReportGroupingByCompanyModal").modal('hide');
            let selectValue = document.getElementById("listGroupingByCompanyReportType").value;

            if(selectValue == 0)
                $("#pdf1").click();
            else if(selectValue == 1)
                $("#excel1").click();
        }

        function ShowModalReportGroupingByProductCategory(event) {
            event.preventDefault();

            $("#ReportGroupingByProductCategoryModal").modal('show');
        }

        function GetReportGroupingByProductCategory(event) {
            $("#ReportGroupingByProductCategoryModal").modal('hide');
            let selectValue = document.getElementById("listGroupingByProductCategoryReportType").value;

            if(selectValue == 0)
                $("#pdf2").click();
            else if(selectValue == 1)
                $("#excel2").click();
        }

            function ShowModalReportGroupingByWarehouse(event) {
                event.preventDefault();

                    $("#ReportGroupingByWarehouseModal").modal('show');
            }

                function GetReportGroupingByWarehouse(event) {
                    $("#ReportGroupingByWarehouseModal").modal('hide');
                    let selectValue = document.getElementById("listGroupingByWarehouseReportType").value;

                if(selectValue == 0)
                    $("#pdf3").click();
                else if(selectValue == 1)
                    $("#excel3").click();
            }

        function ShowModalSwrProductFullInfo(swrProductId)
        {
            $.post("@Url.Action("GetswrProductFullInfo", "WarehouseReceipt")",
                {
                    swrProductId
                })
                .done(function (res) {
                    $("#modalSwrFullInfo").html(res);
                    $("#swrProductFullInfoModal").modal('show');
                })
                .fail(function (xhr, status, error) {
                    location.reload();
                });
        }

    </script>
}


