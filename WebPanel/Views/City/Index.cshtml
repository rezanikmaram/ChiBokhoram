@model Entities.DTOs.Web.Common.CityPageDto
@{
    ViewData["Title"] = "لیست شهرها";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
    int i = ((Model.Cities.PageNumber - 1) * Model.Cities.PageSize) + 1;
}

<div class="col-lg-12">
    <div class="card">
        <div class="card-header pb-1">
            <div class="d-flex justify-content-between">
                <h3 class="title">
                    <i class="icon-frane"></i> لیست شهرها ( تعداد کل @Model.AllCityCount.ToPrice() )
                </h3>
                <div>
                    <button type="button" class="alert-icon btn btn-primary round btn-add-city"> <i class="icon-plus align-middle"></i> شهر جدید </button>
                </div>
            </div>
        </div>
        <div class="card-body pt-0">
            <form id="formFilter" asp-action="Index" asp-route-p="" method="post">
                <input name="p" id="pageNumber" hidden />
                <div class="form-body">
                    <div class="row col-md-12">
                        <div class="form-group col-md-3">
                            <label>کشور</label>
                            <div class="input-group">
                                <select asp-for="Filter.CountryId" class="form-control select2" id="Filter_CountryId">
                                    <option value="">همه کشورها</option>
                                    @if (Model.Countries != null)
                                    {
                                        @foreach (var country in Model.Countries)
                                        {
                                            <option value="@country.Id">@country.CountryNameFa</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="form-group col-md-3">
                            <label>استان</label>
                            <div class="input-group">
                                <select asp-for="Filter.ProvinceId" class="form-control select2" id="Filter_ProvinceId">
                                    <option value="">همه استانها</option>
                                    @if (Model.Provinces != null)
                                    {
                                        @foreach (var province in Model.Provinces)
                                        {
                                            <option value="@province.Id">@province.NameFa</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="form-group col-md-3">
                            <label>جستجو</label>
                            <div class="input-group">
                                <input type="text" asp-for="Filter.Search" class="form-control"/>
                            </div>
                        </div>
                        <div class="col-1">
                            <button style="border-radius:5px; margin-top:30px"
                                    class="alert-icon btn btn-success"
                                    type="submit">
                                <p class="px-3"> فیلتر</p>
                            </button>
                        </div>
                        @* <div class="form-group col-md-3 d-flex justify-content-center flex-wrap align-content-center"> *@
                        @*     <button style="border-radius:5px; margin-top:30px; margin-right: 5px;" *@
                        @*             class="alert-icon btn btn-secondary" *@
                        @*             type="button" id="btnClearFilter"> *@
                        @*         <p class="px-3"> پاک کردن</p> *@
                        @*     </button> *@
                        @* </div> *@
                    </div>
                </div>
            </form>
            <div id="table-container">
                @await Html.PartialAsync("_CityTable", Model)
            </div>
        </div>
    </div>
</div>

<!-- Modal for Create/Edit City -->
<div class="modal fade" id="cityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">ثبت/ویرایش شهر</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body"></div>
        </div>
    </div>
</div>

@section script {
    <script>
        var currentPage = @Model.Cities.PageNumber;
        var currentSortColumn = '@(Model.Filter?.SortColumn ?? "namefa")';
        var currentSortDirection = '@(Model.Filter?.SortDirection ?? "asc")';

        $(document).ready(function () {
            $('.select2').select2();

            $('select[class*="citymodal"].select2').select2({
                dropdownParent: $('#cityModal')
            });
        });

        function getFilterData() {
            var selectedCountryId = $("#Filter_CountryId").val();
            var selectedProvinceId = $("#Filter_ProvinceId").val();
            return {
                'filter.Search': $("#Filter_Search").val(),
                'filter.CountryId': selectedCountryId ? parseInt(selectedCountryId) : null,
                'filter.ProvinceId': selectedProvinceId ? parseInt(selectedProvinceId) : null,
                'filter.SortColumn': currentSortColumn,
                'filter.SortDirection': currentSortDirection
            };
        }

        function loadTable(page) {
            currentPage = page || 1;
            var data = Object.assign({ p: currentPage }, getFilterData());
            $.get('@Url.Action("Table","City")', data)
                .done(function (html) {
                    $("#table-container").html(html);
                });
        }

        function loadTableWithSort(sortColumn, sortDirection) {
            currentSortColumn = sortColumn;
            currentSortDirection = sortDirection;
            loadTable(1);
        }

        function openCityModal(url) {
            $.get(url).done(function (html) {
                var $modal = $("#cityModal");
                $modal.find('.modal-body').html(html);
                if ($.validator && $.validator.unobtrusive) {
                    $.validator.unobtrusive.parse($modal);
                }
                
                // Initialize Select2 inside modal with parent element
                $('select[class*="citymodal"].select2').select2({
                    dropdownParent: $('#cityModal')
                });
                
                var modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('cityModal'));
                modal.show();
            });
        }

        $(document).on('submit', '#formFilter', function (e) {
            e.preventDefault();
            loadTable(1);
        });

        $(document).on('click', '#table-container .page-link', function (e) {
            e.preventDefault();
            var hrefValue = $(this).attr("href") || '';
            var match = hrefValue.match(/p=(\d+)/);
            var p = match ? parseInt(match[1]) : 1;
            loadTable(p);
        });

        $(document).on('click', '.btn-add-city', function () {
            var url = '@Url.Action("CreateCityModal","City")';
            var selectedProvinceId = $("#Filter_ProvinceId").val();
            if (selectedProvinceId && selectedProvinceId > 0) {
                url += '?provinceId=' + selectedProvinceId;
            }
            openCityModal(url);
        });

        $(document).on('click', '#btnClearFilter', function () {
            $('#Filter_CountryId').val(null).trigger('change');
            $('#Filter_ProvinceId').val(null).trigger('change');
            $("#Filter_Search").val('');
            loadTable(1);
        });

        $(document).on('click', '.btn-edit-city', function () {
            var id = $(this).data('id');
            openCityModal('@Url.Action("CreateCityModal","City")' + '?cityId=' + id);
        });

        // Cascading dropdown for Country -> Province in filter
        $(document).on('change', '#Filter_CountryId', function () {
            var countryId = $(this).val();
            var $provinceSelect = $('#Filter_ProvinceId');
            
            if (countryId) {
                $.get('@Url.Action("GetProvincesByCountry","City")', { countryId: countryId })
                    .done(function (provinces) {
                        $provinceSelect.empty();
                        $provinceSelect.append('<option value="">همه استانها</option>');
                        $.each(provinces, function (i, province) {
                            $provinceSelect.append($('<option></option>').val(province.id).text(province.nameFa));
                        });
                        $provinceSelect.trigger('change');
                    });
            } else {
                $provinceSelect.empty();
                $provinceSelect.append('<option value="">همه استانها</option>');
                $provinceSelect.trigger('change');
            }
        });

        $(document).on('submit', '#cityModal form', function (e) {
            e.preventDefault();
            var $form = $(this);
            var $btn = $form.find('button[type="submit"]');
            $btn.prop('disabled', true).html('<i class="icon-spinner fa-spin"></i> در حال ذخیره...');
            
            var action = $form.attr('action') || '@Url.Action("SaveCity","City")';
            $.ajax({
                url: action,
                type: 'POST',
                data: $form.serialize(),
                headers: {
                    'RequestVerificationToken': $form.find('input[name="__RequestVerificationToken"]').val()
                }
            }).done(function (resp, status, xhr) {
                if (typeof resp === 'object' && resp !== null && resp.success) {
                    var modalEl = document.getElementById('cityModal');
                    var modal = bootstrap.Modal.getInstance(modalEl);
                    modal.hide();
                    loadTable(currentPage);
                    updateCityCount();
                    showAlert(resp.message, 0);
                } else {
                    var errorMsg = resp.message || 'خطا در ثبت اطلاعات';
                    showAlert(errorMsg, 1);
                    $("#cityModal .modal-body").html(resp);
                    if ($.validator && $.validator.unobtrusive) {
                        $.validator.unobtrusive.parse('#cityModal');
                    }
                    $('#btnSaveCity').prop('disabled', false).html('<i class="icon-check"></i> ذخیره');
                }
            }).fail(function (xhr, status, error) {
                showAlert('خطا در ارسال درخواست: ' + error, 1);
                $('#btnSaveCity').prop('disabled', false).html('<i class="icon-check"></i> ذخیره');
            });
        });

        $(document).on('click', '.btn-delete-city', function () {
            var id = $(this).data('id');
            var name = $(this).data('name');
            
            Swal.fire({
                title: 'آیا از حذف شهر "' + name + '" مطمئن هستید؟',
                text: "این عملیات قابل بازگشت نیست!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'بله، حذف کن',
                cancelButtonText: 'انصراف'
            }).then((result) => {
                if (result.isConfirmed) {
                    deleteCity(id);
                }
            });
        });

        function deleteCity(id) {
            $.ajax({
                url: '@Url.Action("DeleteCity", "City")',
                type: 'POST',
                data: { cityId: id },
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').first().val()
                }
            }).done(function (resp) {
                if (resp.success) {
                    loadTable(currentPage);
                    updateCityCount();
                    showAlert(resp.message, 0);
                } else {
                    showAlert(resp.message, 1);
                }
            }).fail(function (xhr, status, error) {
                showAlert('خطا در حذف شهر: ' + error, 1);
            });
        }

        function updateCityCount() {
            var url = '@Url.Action("GetCityCount", "City")';
            var selectedProvinceId = $("#Filter_ProvinceId").val();
            if (selectedProvinceId && selectedProvinceId > 0) {
                url += '?provinceId=' + selectedProvinceId;
            }
            $.get(url)
                .done(function (resp) {
                    if (resp.count !== undefined) {
                        var titleText = '<i class="icon-frane"></i> لیست شهرها';
                        if (selectedProvinceId && selectedProvinceId > 0) {
                            var provinceName = $("#Filter_ProvinceId option:selected").text();
                            titleText += ' - ' + provinceName;
                        }
                        titleText += ' ( تعداد کل ' + resp.count.toLocaleString('fa-IR') + ' )';
                        $('.title').html(titleText);
                    }
                });
        }
    </script>
}
