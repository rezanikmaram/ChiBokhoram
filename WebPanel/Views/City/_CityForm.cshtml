@model Entities.DTOs.Web.Common.CityDto
@using Entities.DTOs.Web.Common

@{
    var provinces = ViewBag.Provinces as List<ProvinceDto> ?? new List<ProvinceDto>();
}

<form asp-action="SaveCity" method="post" class="needs-validation" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    
    <div class="row gy-4">
        <div class="col-md-12">
            <div class="form-group">
                <label for="ProvinceId">استان <span class="text-danger">*</span></label>
                <select asp-for="ProvinceId" class="form-control select2 citymodal" required>
                    <option value="">-- انتخاب استان --</option>
                    @foreach (var province in provinces)
                    {
                        <option value="@province.Id">@province.NameFa (@province.CountryNameFa)</option>
                    }
                </select>
                <span asp-validation-for="ProvinceId" class="text-danger"></span>
                <small class="form-text text-muted">نام استان به همراه نام کشور در پرانتز</small>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label for="NameFa">نام شهر (فارسی) <span class="text-danger">*</span></label>
                <input asp-for="NameFa" class="form-control" placeholder="نام شهر را به فارسی وارد کنید" required/>
                <span asp-validation-for="NameFa" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label for="NameEn">نام شهر (انگلیسی) <span class="text-danger">*</span></label>
                <input asp-for="NameEn" class="form-control" placeholder="نام شهر را به انگلیسی وارد کنید" required/>
                <span asp-validation-for="NameEn" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-12">
            <div class="form-group">
                <div class="form-check form-switch">
                    <input asp-for="IsPort" class="form-check-input" type="checkbox" role="switch" />
                    <label class="form-check-label" asp-for="IsPort">این شهر بندر است</label>
                </div>
            </div>
        </div>
    </div>
   
    <div class="row mt-3">
        <div class="col-md-12 text-end">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
            <button type="submit" class="btn btn-primary" id="btnSaveCity">
                <i class="icon-check"></i> ذخیره
            </button>
        </div>
    </div>
</form>
