@{
    ViewData["Title"] = "دریافت لیست Seo ها";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}
<div class="col-lg-12">
    <div class="card">
        <div class="card-header pb-0">
            <div class="d-flex justify-content-between">
                <h3 class="title">
                    <i class="fa-solid fa-anchor"></i>
                    دریافت لیست CHO ها در قالب فایل excel
                </h3>
            </div>
        </div>
        <form asp-controller="Report" asp-action="GetSeoExcellFile" method="post">

            <div class="card-body pt-0">
                <div class="form-body my-4 col-9 report-main">
                    <ul class="d-flex col-md-12">
                        <li class="col-md-4 me-4">
                            <div class="form-group">
                                <label>از تاریخ</label>
                                <div style="display:block !important" class="input-group">

                                    <input name="fromdate" id="fromdate" type="text" class=" form-control" autocomplete="off" required>

                                </div>
                            </div>

                        </li>
                        <li class="col-md-4 m-r-15">
                            <div class="form-group">
                                <label>تا تاریخ</label>
                                <div style="display:block !important" class="input-group">
                                    <input name="todate" id="todate" type="text" class=" form-control" autocomplete="off">
                                </div>
                            </div>
                        </li>
                    </ul>
                </div>
                <div class="col-12">
                    <div class="media report-perfom mb-4" style="float: left;">
                        <div class="form-actions" style="float: left;">
                            <button type="submit" class="btn btn-info btn-round">
                                <i class="icon-check align-middle px-1"></i>
                                دریافت لیست Excel
                                <div class="paper-ripple"><div class="paper-ripple__background"></div><div class="paper-ripple__waves"></div></div>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </form>
        <section class="fix"></section>

    </div>
</div>
@section script {
     
    <script>

       
        kamaDatepicker('fromdate', customOptions);
        kamaDatepicker('todate', customOptions);

    </script>
}

